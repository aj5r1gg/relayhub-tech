---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Media Kit | RelayHub"
  description="Official RelayHub media kit including logos, brand colours, product descriptions, founder information, screenshots, and media contact details."
>
  <section class="rh-hero">
    <div class="rh-container rh-hero-inner">
      <p class="rh-eyebrow">Media Kit</p>

      <h1 class="rh-title">
        RelayHub Press & Media Resources
      </h1>

      <p class="rh-subtitle">
        Official information, branding assets, descriptions, screenshots,
        and contact details for journalists, creators, community organisers,
        partners, researchers, and event organisers.
      </p>
    </div>
  </section>

  <section class="rh-section">
    <div class="rh-container">
      <p class="rh-kicker">About RelayHub</p>

      <h2 class="rh-section-title">
        Company Overview
      </h2>

      <p class="rh-section-lead">
        RelayHub is building local-first infrastructure that helps communities
        communicate, coordinate, share knowledge, and remain connected even when
        connectivity is limited, intermittent, or unavailable.
      </p>

      <div class="rh-card">
        <h3 class="rh-card-title">
          Official Description
        </h3>

        <p class="rh-card-text">
          RelayHub provides local-first infrastructure for communication,
          trust, knowledge sharing, trade, coordination, governance,
          and cultural continuity.
        </p>

        <p class="rh-card-text">
          Built around resilient networking technologies and appliance-like
          usability, RelayHub aims to make advanced community communication
          infrastructure accessible to everyday people, households,
          organisations, and communities.
        </p>
      </div>
    </div>
  </section>

  <section class="rh-section rh-bg-soft">
    <div class="rh-container">
      <p class="rh-kicker">Brand Assets</p>

      <h2 class="rh-section-title">
        Logos
      </h2>

      <p class="rh-section-lead">
        Download official RelayHub logos for articles, podcasts, videos,
        conferences, and community presentations.
      </p>

      <div class="rh-grid rh-grid-3">
        <div class="rh-card">
          <h3 class="rh-card-title">Primary Logo</h3>
          <p class="rh-card-text">
            Full RelayHub logo for most use cases.
          </p>
        </div>

        <div class="rh-card">
          <h3 class="rh-card-title">Horizontal Logo</h3>
          <p class="rh-card-text">
            Wide format for banners and websites.
          </p>
        </div>

        <div class="rh-card">
          <h3 class="rh-card-title">Icon Mark</h3>
          <p class="rh-card-text">
            Standalone symbol for avatars and app icons.
          </p>
        </div>
      </div>

      <div class="rh-card" style="margin-top: var(--space-8);">
        <h3 class="rh-card-title">
          Download Package
        </h3>

        <p class="rh-card-text">
          Logo package coming soon:
        </p>

        <ul>
          <li>SVG</li>
          <li>PNG</li>
          <li>Light background versions</li>
          <li>Dark background versions</li>
          <li>Print-ready assets</li>
        </ul>
      </div>
    </div>
  </section>

  <section class="rh-section">
    <div class="rh-container">
      <p class="rh-kicker">Brand Colours</p>

      <h2 class="rh-section-title">
        Trust & Infrastructure Palette
      </h2>

      <div class="rh-grid rh-grid-4">
        <div class="rh-card">
          <strong>Navy</strong>
          <p>#0F172A</p>
        </div>

        <div class="rh-card">
          <strong>Blue</strong>
          <p>#2563EB</p>
        </div>

        <div class="rh-card">
          <strong>Slate</strong>
          <p>#64748B</p>
        </div>

        <div class="rh-card">
          <strong>White</strong>
          <p>#FFFFFF</p>
        </div>
      </div>
    </div>
  </section>

  <section class="rh-section rh-bg-soft">
    <div class="rh-container">
      <p class="rh-kicker">Products</p>

      <h2 class="rh-section-title">
        Product Descriptions
      </h2>

      <div class="rh-grid rh-grid-2">
        <div class="rh-card">
          <h3 class="rh-card-title">RelayHub Hardware</h3>

          <p class="rh-card-text">
            Appliance-style communication nodes designed for simple deployment,
            resilience, and local-first operation.
          </p>
        </div>

        <div class="rh-card">
          <h3 class="rh-card-title">RelayOS</h3>

          <p class="rh-card-text">
            A purpose-built operating environment designed to simplify deployment,
            recovery, and operation of RelayHub infrastructure.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="rh-section">
    <div class="rh-container">
      <p class="rh-kicker">Screenshots</p>

      <h2 class="rh-section-title">
        Product Screenshots
      </h2>

      <p class="rh-section-lead">
        Screenshots and product imagery will be added as development progresses.
      </p>

      <div class="rh-grid rh-grid-3">
        <div class="rh-card">
          UI Screenshot Placeholder
        </div>

        <div class="rh-card">
          Hardware Screenshot Placeholder
        </div>

        <div class="rh-card">
          Community Screenshot Placeholder
        </div>
      </div>
    </div>
  </section>

  <section class="rh-section rh-bg-soft">
    <div class="rh-container">
      <p class="rh-kicker">Founder</p>

      <h2 class="rh-section-title">
        Founder Biography
      </h2>

      <div class="rh-card">
        <p class="rh-card-text">
          Andrew Rigg is the founder of RelayHub.
        </p>

        <p class="rh-card-text">
          His work focuses on building practical, resilient infrastructure
          that helps people communicate, coordinate, organise, and preserve
          knowledge through local-first systems and community-centred design.
        </p>

        <p class="rh-card-text">
          RelayHub was created from the belief that communities benefit from
          communication systems that remain useful during disruption,
          uncertainty, and changing network conditions.
        </p>
      </div>
    </div>
  </section>

  <section class="rh-section">
    <div class="rh-container">
      <p class="rh-kicker">Media Contact</p>

      <h2 class="rh-section-title">
        Contact
      </h2>

      <div class="rh-card">
        <p class="rh-card-text">
          Media enquiries, interviews, podcasts, speaking engagements,
          partnerships, and conference invitations:
        </p>

        <p>
          <strong>Email:</strong>
          <a href="mailto:hello@relayhub.tech">
            hello@relayhub.tech
          </a>
        </p>

        <p>
          <strong>Contact form:</strong>
          <a href="/contact">
            relayhub.tech/contact
          </a>
        </p>
      </div>
    </div>
  </section>
</BaseLayout>