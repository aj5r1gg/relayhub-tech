---
import BaseLayout from "../layouts/BaseLayout.astro";

const pageTitle = "Request Document Access | RelayHub";
const pageDescription =
  "Request access to RelayHub controlled documents. This page records access requests only; download issuing is not active yet.";
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <main class="rh-request-page">
    <section class="rh-request-hero">
      <p class="rh-eyebrow">RelayHub Documents</p>
      <h1>Request document access</h1>
      <p>
        Submit your details to request access to a RelayHub document. Review the
        rendered licence terms first, then acknowledge them before submitting your
        request.
      </p>
    </section>

    <section class="rh-request-grid">
      <form class="rh-request-card" id="document-request-form">
        <div class="rh-form-section">
          <h2>Document</h2>
          <p>
            Choose the document you are requesting. The licence preview updates
            automatically for the selected document.
          </p>

          <label>
            Document
            <select id="document-id" name="document_id" required>
              <option value="relayhub-overview">RelayHub Overview v0.2</option>
            </select>
          </label>
        </div>

        <div class="rh-form-section">
          <h2>Your details</h2>

          <label>
            Name
            <input
              id="name"
              name="name"
              type="text"
              autocomplete="name"
              required
              placeholder="Your name"
            />
          </label>

          <label>
            Email
            <input
              id="email"
              name="email"
              type="email"
              autocomplete="email"
              required
              placeholder="you@example.com"
            />
          </label>

          <label>
            Licence holder type
            <select id="licence-holder-type" name="licence_holder_type">
              <option value="individual">Individual</option>
              <option value="organisation">Organisation</option>
            </select>
          </label>

          <label>
            Organisation name
            <input
              id="organisation-name"
              name="organisation_name"
              type="text"
              autocomplete="organization"
              placeholder="Optional"
            />
          </label>

          <label>
            Recipient category
            <select id="recipient-category" name="recipient_category">
              <option value="supporter">Supporter</option>
              <option value="community_member">Community member</option>
              <option value="developer">Developer</option>
              <option value="partner">Partner</option>
              <option value="researcher">Researcher</option>
              <option value="media">Media</option>
              <option value="other">Other</option>
            </select>
          </label>
        </div>

        <div class="rh-form-section">
          <h2>Terms acknowledgement</h2>
          <p>
            Review the rendered licence preview shown beside this form. Your request
            records acknowledgement of the current rendered licence text for the
            selected document.
          </p>

          <label class="rh-checkbox-row">
            <input id="terms-accepted" name="terms_accepted" type="checkbox" required />
            <span>
              I acknowledge and accept the current rendered licence terms for the
              selected document.
            </span>
          </label>
        </div>

        <div class="rh-form-actions">
          <button class="rh-button rh-button-primary" type="submit">
            Submit access request
          </button>
        </div>

        <div class="rh-form-status" id="form-status" role="status" aria-live="polite">
          Ready.
        </div>
      </form>

      <aside class="rh-request-card rh-request-aside">
        <h2>Rendered licence preview</h2>

        <div class="rh-licence-meta">
          <dl>
            <dt>Terms version</dt>
            <dd id="licence-version">—</dd>
          </dl>

          <dl>
            <dt>Rendered SHA-256</dt>
            <dd id="licence-sha">—</dd>
          </dl>

          <dl>
            <dt>Unresolved placeholders</dt>
            <dd id="licence-unresolved">—</dd>
          </dl>
        </div>

        <div class="rh-form-status" id="licence-status" role="status" aria-live="polite">
          Loading licence preview…
        </div>

        <pre class="rh-licence-preview" id="licence-body">Loading…</pre>

        <div class="rh-note">
          <strong>Current phase:</strong>
          Request intake only. This page does not issue a download link, create a
          licence record, verify email, or generate a personalised PDF yet.
        </div>
      </aside>
    </section>
  </main>

  <style>
    .rh-request-page {
      width: min(1200px, calc(100% - 2rem));
      margin: 0 auto;
      padding: 3rem 0 5rem;
    }

    .rh-request-hero {
      margin-bottom: 1.5rem;
      padding: 2rem;
      border: 1px solid rgba(15, 23, 42, 0.12);
      border-radius: 1.5rem;
      background:
        radial-gradient(circle at top left, rgba(59, 130, 246, 0.12), transparent 36rem),
        linear-gradient(135deg, rgba(255,255,255,0.96), rgba(248,250,252,0.96));
      box-shadow: 0 24px 70px rgba(15, 23, 42, 0.08);
    }

    .rh-request-hero h1 {
      margin: 0.35rem 0 0.75rem;
      font-size: clamp(2rem, 5vw, 3.5rem);
      line-height: 1;
      letter-spacing: -0.05em;
    }

    .rh-request-hero p {
      max-width: 780px;
      margin: 0;
      color: rgba(15, 23, 42, 0.74);
      font-size: 1.05rem;
      line-height: 1.7;
    }

    .rh-eyebrow {
      margin: 0;
      color: #2563eb;
      font-size: 0.78rem;
      font-weight: 800;
      letter-spacing: 0.14em;
      text-transform: uppercase;
    }

    .rh-request-grid {
      display: grid;
      grid-template-columns: minmax(0, 0.95fr) minmax(420px, 1.05fr);
      gap: 1rem;
      align-items: start;
    }

    .rh-request-card {
      border: 1px solid rgba(15, 23, 42, 0.12);
      border-radius: 1.25rem;
      background: rgba(255, 255, 255, 0.96);
      box-shadow: 0 18px 50px rgba(15, 23, 42, 0.07);
      padding: 1.25rem;
    }

    .rh-form-section {
      display: grid;
      gap: 0.9rem;
      padding: 1rem 0;
      border-bottom: 1px solid rgba(15, 23, 42, 0.08);
    }

    .rh-form-section:first-child {
      padding-top: 0;
    }

    .rh-form-section:last-of-type {
      border-bottom: 0;
    }

    .rh-form-section h2,
    .rh-request-aside h2 {
      margin: 0;
      color: #0f172a;
      font-size: 1.25rem;
      letter-spacing: -0.03em;
    }

    .rh-form-section p,
    .rh-request-aside p {
      margin: 0;
      color: rgba(15, 23, 42, 0.68);
      line-height: 1.6;
    }

    .rh-form-section label {
      display: grid;
      gap: 0.35rem;
      color: rgba(15, 23, 42, 0.82);
      font-size: 0.9rem;
      font-weight: 800;
    }

    .rh-form-section input,
    .rh-form-section select {
      width: 100%;
      border: 1px solid rgba(15, 23, 42, 0.18);
      border-radius: 0.85rem;
      padding: 0.8rem 0.9rem;
      background: #fff;
      color: #0f172a;
      font: inherit;
    }

    .rh-checkbox-row {
      display: flex !important;
      grid-template-columns: none !important;
      align-items: flex-start;
      gap: 0.7rem !important;
      font-weight: 700 !important;
      line-height: 1.55;
    }

    .rh-checkbox-row input {
      width: auto;
      margin-top: 0.25rem;
      accent-color: #0f172a;
    }

    .rh-form-actions {
      display: flex;
      justify-content: flex-end;
      padding-top: 1rem;
    }

    .rh-button {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 2.75rem;
      border: 1px solid transparent;
      border-radius: 999px;
      padding: 0.65rem 1rem;
      font: inherit;
      font-weight: 800;
      cursor: pointer;
      transition:
        transform 150ms ease,
        background 150ms ease,
        border-color 150ms ease,
        color 150ms ease;
      white-space: nowrap;
    }

    .rh-button:hover {
      transform: translateY(-1px);
    }

    .rh-button-primary {
      background: #0f172a;
      color: #fff;
      border-color: #0f172a;
    }

    .rh-button-primary:hover {
      background: #1e293b;
      color: #fff;
    }

    .rh-button[disabled] {
      cursor: not-allowed;
      opacity: 0.65;
      transform: none;
    }

    .rh-form-status {
      margin-top: 1rem;
      padding: 0.85rem 1rem;
      border-radius: 0.9rem;
      background: #f8fafc;
      color: rgba(15, 23, 42, 0.75);
      font-size: 0.95rem;
      line-height: 1.55;
    }

    .rh-form-status[data-state="error"] {
      background: #fef2f2;
      color: #991b1b;
    }

    .rh-form-status[data-state="success"] {
      background: #f0fdf4;
      color: #166534;
    }

    .rh-request-aside {
      position: sticky;
      top: 1rem;
      max-height: calc(100vh - 2rem);
      overflow: auto;
    }

    .rh-licence-meta {
      display: grid;
      gap: 0.65rem;
      margin: 1rem 0;
    }

    .rh-licence-meta dl {
      margin: 0;
      padding: 0.75rem;
      border-radius: 0.85rem;
      background: #f8fafc;
    }

    .rh-licence-meta dt {
      color: rgba(15, 23, 42, 0.55);
      font-size: 0.72rem;
      font-weight: 900;
      letter-spacing: 0.07em;
      text-transform: uppercase;
    }

    .rh-licence-meta dd {
      margin: 0.25rem 0 0;
      color: #0f172a;
      word-break: break-word;
      line-height: 1.5;
    }

    .rh-licence-preview {
      margin: 1rem 0 0;
      padding: 1rem;
      max-height: 560px;
      overflow: auto;
      white-space: pre-wrap;
      border-radius: 0.9rem;
      background: #0f172a;
      color: #e2e8f0;
      line-height: 1.6;
      font-size: 0.9rem;
    }

    .rh-note {
      margin-top: 1rem;
      padding: 1rem;
      border-radius: 1rem;
      background: #f8fafc;
      color: rgba(15, 23, 42, 0.74);
      line-height: 1.6;
    }

    .rh-note strong {
      color: #0f172a;
    }

    @media (max-width: 980px) {
      .rh-request-grid {
        grid-template-columns: 1fr;
      }

      .rh-request-aside {
        position: static;
        max-height: none;
      }
    }

    @media (max-width: 640px) {
      .rh-request-page {
        width: min(100% - 1rem, 1200px);
        padding-top: 1rem;
      }

      .rh-request-hero,
      .rh-request-card {
        padding: 1rem;
        border-radius: 1rem;
      }

      .rh-form-actions {
        justify-content: stretch;
      }

      .rh-form-actions .rh-button {
        width: 100%;
      }
    }
  </style>

  <script is:inline>
    // @ts-nocheck

    const form = document.getElementById("document-request-form");
    const statusBox = document.getElementById("form-status");
    const documentSelect = document.getElementById("document-id");
    const licenceStatus = document.getElementById("licence-status");
    const licenceBody = document.getElementById("licence-body");
    const licenceVersion = document.getElementById("licence-version");
    const licenceSha = document.getElementById("licence-sha");
    const licenceUnresolved = document.getElementById("licence-unresolved");
    const termsAccepted = document.getElementById("terms-accepted");

    let licencePreviewReady = false;
    let licencePreviewTimer = null;

    function setStatus(message, mode = "neutral") {
      statusBox.textContent = message;
      statusBox.dataset.state = mode;
    }

    function setLicenceStatus(message, mode = "neutral") {
      licenceStatus.textContent = message;
      licenceStatus.dataset.state = mode;
    }

    function applyDocumentFromQuery() {
      const params = new URLSearchParams(window.location.search);
      const documentId = params.get("document_id") || params.get("document");

      if (!documentId) {
        return;
      }

      const option = Array.from(documentSelect.options).find(
        (item) => item.value === documentId
      );

      if (option) {
        documentSelect.value = documentId;
      }
    }

    function formToPayload() {
      const formData = new FormData(form);
      const payload = {};

      for (const [key, value] of formData.entries()) {
        payload[key] = value;
      }

      payload.terms_accepted = formData.get("terms_accepted") === "on";

      return payload;
    }

    function previewPayload() {
      const payload = formToPayload();

      payload.licensed_name = payload.name || "";
      payload.licensed_email = payload.email || "";
      payload.licensed_organisation = payload.organisation_name || "";

      return payload;
    }

    function scheduleLicencePreview() {
      window.clearTimeout(licencePreviewTimer);

      licencePreviewTimer = window.setTimeout(() => {
        loadLicencePreview();
      }, 350);
    }

    async function loadLicencePreview() {
      const payload = previewPayload();

      licencePreviewReady = false;
      termsAccepted.checked = false;
      termsAccepted.disabled = true;

      setLicenceStatus("Loading rendered licence preview…");
      licenceBody.textContent = "Loading…";
      licenceVersion.textContent = "—";
      licenceSha.textContent = "—";
      licenceUnresolved.textContent = "—";

      let response;
      let data;

      try {
        response = await fetch("/api/document-access/rendered-licence", {
          method: "POST",
          headers: {
            "content-type": "application/json",
          },
          body: JSON.stringify(payload),
        });

        data = await response.json();
      } catch (error) {
        setLicenceStatus(`Could not load rendered licence: ${error.message}`, "error");
        licenceBody.textContent = "Could not load rendered licence.";
        return;
      }

      if (!response.ok || !data.ok) {
        setLicenceStatus(
          data?.message || data?.error || "Rendered licence could not be loaded.",
          "error"
        );
        licenceBody.textContent = "Rendered licence could not be loaded.";
        return;
      }

      licenceVersion.textContent = data.terms?.version || "—";
      licenceSha.textContent = data.rendered_sha256 || "—";

      const unresolved = Array.isArray(data.unresolved_placeholders)
        ? data.unresolved_placeholders
        : [];

      licenceUnresolved.textContent = unresolved.length
        ? unresolved.join(", ")
        : "None";

      licenceBody.textContent = data.rendered_body || "No rendered licence body returned.";

      if (unresolved.length) {
        setLicenceStatus(
          `Rendered licence loaded, but ${unresolved.length} placeholder(s) remain unresolved.`,
          "error"
        );
        licencePreviewReady = false;
        termsAccepted.disabled = true;
        return;
      }

      licencePreviewReady = true;
      termsAccepted.disabled = false;
      setLicenceStatus("Rendered licence preview loaded. You may now accept the terms.", "success");
    }

    function shouldRefreshLicencePreview(event) {
      const target = event.target;

      if (!(target instanceof HTMLElement)) {
        return false;
      }

      /*
       * Do not reload the licence preview when the user ticks the terms checkbox.
       * Reloading the preview deliberately clears the checkbox because any
       * changed requester/document details create a different rendered licence.
       */
      if (target.id === "terms-accepted" || target.name === "terms_accepted") {
        return false;
      }

      return true;
    }

    form.addEventListener("input", (event) => {
      if (shouldRefreshLicencePreview(event)) {
        scheduleLicencePreview();
      }
    });

    form.addEventListener("change", (event) => {
      if (shouldRefreshLicencePreview(event)) {
        scheduleLicencePreview();
      }
    });

    form.addEventListener("submit", async (event) => {
      event.preventDefault();

      if (!licencePreviewReady) {
        setStatus("The rendered licence preview must load cleanly before submitting.", "error");
        return;
      }

      const button = form.querySelector("button[type='submit']");
      const payload = formToPayload();

      button.disabled = true;
      setStatus("Submitting document access request…");

      let response;
      let data;

      try {
        response = await fetch("/api/document-access/request", {
          method: "POST",
          headers: {
            "content-type": "application/json",
          },
          body: JSON.stringify(payload),
        });

        data = await response.json();
      } catch (error) {
        setStatus(`The request could not be submitted: ${error.message}`, "error");
        button.disabled = false;
        return;
      }

      if (!response.ok || !data.ok) {
        setStatus(
          data?.message || data?.error || "The request could not be submitted.",
          "error"
        );
        button.disabled = false;
        return;
      }

      setStatus(
        `Request recorded. Request ID: ${data.request_id}. Email verification and download issuing are not active yet.`,
        "success"
      );

      form.reset();
      applyDocumentFromQuery();
      button.disabled = false;
      scheduleLicencePreview();
    });

    applyDocumentFromQuery();
    termsAccepted.disabled = true;
    loadLicencePreview();
  </script>
</BaseLayout>