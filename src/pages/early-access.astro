---
import BaseLayout from "../layouts/BaseLayout.astro";

const submitted = Astro.url.searchParams.get("submitted") === "true";
const error = Astro.url.searchParams.get("error");

const errorMessages = {
  "invalid-email": "Please enter a valid email address and try again.",
  "rate-limited": "Too many requests have been sent from your connection. Please try again later.",
  "submission-failed": "Something went wrong while sending your request. Please try again shortly.",
  "email-failed": "Your request could not be emailed. Please try again shortly.",
};

const errorMessage =
  error && Object.prototype.hasOwnProperty.call(errorMessages, error)
    ? errorMessages[error as keyof typeof errorMessages]
    : null;
---

<BaseLayout
  title="Early Access | RelayHub"
  description="Register interest in RelayHub early access, community pilots, developer participation, product updates, and field testing."
>
  <section class="rh-hero">
    <div class="rh-container rh-hero-inner">
      <p class="rh-eyebrow">Early access</p>

      <h1 class="rh-title">
        Help shape the first RelayHub nodes.
      </h1>

      <p class="rh-subtitle">
        Register interest in RelayHub updates, field testing, community pilots,
        developer participation, product availability, and future documentation releases.
      </p>

      <div class="rh-actions">
        <a class="rh-button rh-button-primary" href="#register">
          Register interest
        </a>
        <a class="rh-button rh-button-secondary" href="/products">
          View products
        </a>
      </div>
    </div>
  </section>

  <section class="rh-section">
    <div class="rh-container">
      <p class="rh-kicker">Current status</p>

      <h2 class="rh-section-title">
        RelayHub is being designed, validated, and prepared carefully.
      </h2>

      <p class="rh-section-lead">
        Early access does not mean the product is already finished. It means you
        can follow development, express interest, help test carefully, and shape
        what becomes useful before supported release.
      </p>

      <div class="rh-grid rh-grid-3" style="margin-top: var(--space-10);">
        <article class="rh-card">
          <span class="rh-status rh-status-local">Design</span>
          <h3 class="rh-card-title" style="margin-top: var(--space-5);">
            Product design
          </h3>
          <p class="rh-card-text">
            Website, product language, documentation, onboarding flows, and
            appliance behaviour are being defined.
          </p>
        </article>

        <article class="rh-card">
          <span class="rh-status rh-status-degraded">Validation</span>
          <h3 class="rh-card-title" style="margin-top: var(--space-5);">
            Testing pathway
          </h3>
          <p class="rh-card-text">
            Hardware classes, recovery paths, update safety, local-first operation,
            and support boundaries must be proven.
          </p>
        </article>

        <article class="rh-card">
          <span class="rh-status rh-status-ready">Future</span>
          <h3 class="rh-card-title" style="margin-top: var(--space-5);">
            Product release
          </h3>
          <p class="rh-card-text">
            Product-supported nodes will only be offered when capability, recovery,
            documentation, and validation are ready.
          </p>
        </article>
      </div>
    </div>
  </section>

  <section class="rh-section rh-dark">
    <div class="rh-container">
      <p class="rh-kicker">Who should register?</p>

      <h2 class="rh-section-title">
        Early access is for serious users, builders, and communities.
      </h2>

      <p class="rh-section-lead">
        RelayHub is especially interested in people who care about practical
        communication, local-first infrastructure, recovery, usability, and real
        community operation.
      </p>

      <div class="rh-grid rh-grid-3" style="margin-top: var(--space-10);">
        <article class="rh-card rh-card-dark">
          <h3 class="rh-card-title">Households</h3>
          <p class="rh-card-text">
            People who want a simple local communication appliance for home,
            family, rural property, or preparedness use.
          </p>
        </article>

        <article class="rh-card rh-card-dark">
          <h3 class="rh-card-title">Communities</h3>
          <p class="rh-card-text">
            Groups, clubs, local networks, field teams, events, towns, and
            regional communities exploring local coordination.
          </p>
        </article>

        <article class="rh-card rh-card-dark">
          <h3 class="rh-card-title">Developers</h3>
          <p class="rh-card-text">
            Builders interested in NixOS, Reticulum, local web interfaces,
            hardware validation, documentation, or community applications.
          </p>
        </article>
      </div>
    </div>
  </section>

  <section class="rh-section">
    <div class="rh-container">
      <p class="rh-kicker">What you may receive</p>

      <h2 class="rh-section-title">
        Updates first. Testing later. Supported products only when ready.
      </h2>

      <div class="rh-grid rh-grid-4" style="margin-top: var(--space-10);">
        <article class="rh-card">
          <h3 class="rh-card-title">Build updates</h3>
          <p class="rh-card-text">
            Progress notes on RelayHub, RelayOS, product pages, hardware testing,
            documentation, and release planning.
          </p>
        </article>

        <article class="rh-card">
          <h3 class="rh-card-title">Documentation</h3>
          <p class="rh-card-text">
            Early guides, setup explanations, recovery notes, privacy reality
            pages, and product status information.
          </p>
        </article>

        <article class="rh-card">
          <h3 class="rh-card-title">Pilot invitations</h3>
          <p class="rh-card-text">
            Possible invitations to small testing programs when hardware, support,
            and safety boundaries are ready.
          </p>
        </article>

        <article class="rh-card">
          <h3 class="rh-card-title">Availability notices</h3>
          <p class="rh-card-text">
            Notifications when products, Etsy listings, support material, or
            developer resources become available.
          </p>
        </article>
      </div>
    </div>
  </section>

  <section id="register" class="rh-section rh-bg-soft">
    <div class="rh-container rh-grid rh-grid-2">
      <div>
        <p class="rh-kicker">Register</p>

        <h2 class="rh-section-title">
          Tell us how RelayHub could be useful to you.
        </h2>

        <p class="rh-section-lead">
          This form submits through the RelayHub Cloudflare Worker endpoint.
          Submissions are emailed and stored securely for early access follow-up.
        </p>

        <div class="rh-card" style="margin-top: var(--space-8);">
          <h3 class="rh-card-title">No hype. No false promises.</h3>
          <p class="rh-card-text">
            Registering interest does not guarantee acceptance into a test program,
            product availability, pricing, delivery dates, or support status.
            RelayHub will only claim supported capability after validation.
          </p>
        </div>
      </div>

      <form
        id="early-access-form"
        class="rh-card"
        name="early-access"
        method="POST"
        action="/api/early-access"
        novalidate
      >
        {
          submitted && (
            <div class="rh-form-message rh-form-message-success">
              <strong>Request received.</strong>
              <span>Thank you. We’ll be in touch as RelayHub early access opens.</span>
            </div>
          )
        }

        {
          errorMessage && (
            <div class="rh-form-message rh-form-message-error">
              <strong>Something needs attention.</strong>
              <span>{errorMessage}</span>
            </div>
          )
        }

        <div
          id="early-access-status"
          class="rh-form-status"
          aria-live="polite"
          role="status"
        ></div>

        <input
          id="startedAt"
          name="startedAt"
          type="hidden"
          value=""
        />

        <div class="honeypot" aria-hidden="true">
          <label for="website">Website</label>
          <input
            id="website"
            name="website"
            type="text"
            tabindex="-1"
            autocomplete="off"
          />
        </div>

        <label class="rh-label" for="name">Name</label>
        <input
          class="rh-input"
          id="name"
          name="name"
          type="text"
          autocomplete="name"
          required
        />

        <div style="height: var(--space-5);"></div>

        <label class="rh-label" for="email">Email</label>
        <input
          class="rh-input"
          id="email"
          name="email"
          type="email"
          autocomplete="email"
          required
        />

        <div style="height: var(--space-5);"></div>

        <label class="rh-label" for="community">Community / organisation</label>
        <input
          class="rh-input"
          id="community"
          name="community"
          type="text"
          placeholder="Example: household, community group, club, field team, organisation"
        />

        <div style="height: var(--space-5);"></div>

        <label class="rh-label" for="role">How would you describe your interest?</label>
        <select class="rh-input" id="role" name="role">
          <option value="">Select one if relevant</option>
          <option value="Household user">Household user</option>
          <option value="Community organiser">Community organiser</option>
          <option value="Developer">Developer</option>
          <option value="Infrastructure operator">Infrastructure operator</option>
          <option value="Partner organisation">Partner organisation</option>
          <option value="Media / researcher">Media / researcher</option>
          <option value="Other">Other</option>
        </select>

        <div style="height: var(--space-5);"></div>

        <label class="rh-label" for="message">What would you use RelayHub for?</label>
        <textarea
          class="rh-textarea"
          id="message"
          name="message"
          rows="6"
          placeholder="Tell us about your household, group, community, field use, developer interest, or infrastructure idea."
        ></textarea>

        <div style="height: var(--space-6);"></div>

        <button id="early-access-submit" class="rh-button rh-button-accent" type="submit">
          Register interest
        </button>

        <p class="rh-help">
          By submitting this form, you agree to be contacted about RelayHub updates.
          Personal information is handled according to the <a href="/privacy">Privacy Policy</a>.
        </p>

        <div
          class="cf-turnstile"
          data-sitekey="0x4AAAAAADdzV1P6vMlkCRfJ"
        ></div>

        <noscript>
          <p class="rh-help">
            JavaScript is disabled, so this form will submit directly to the RelayHub API.
          </p>
        </noscript>
      </form>
    </div>
  </section>

  <section class="rh-section">
    <div class="rh-container">
      <p class="rh-kicker">Participation expectations</p>

      <h2 class="rh-section-title">
        Early access should improve the product, not create false confidence.
      </h2>

      <div class="rh-grid rh-grid-3" style="margin-top: var(--space-10);">
        <article class="rh-card">
          <h3 class="rh-card-title">Be realistic</h3>
          <p class="rh-card-text">
            Early builds may be incomplete, limited, unstable, or unsuitable for
            critical use.
          </p>
        </article>

        <article class="rh-card">
          <h3 class="rh-card-title">Give useful feedback</h3>
          <p class="rh-card-text">
            The most valuable feedback explains what worked, what failed, what
            confused people, and what recovery steps were unclear.
          </p>
        </article>

        <article class="rh-card">
          <h3 class="rh-card-title">Respect boundaries</h3>
          <p class="rh-card-text">
            Do not present early builds as certified, supported, emergency-ready,
            legally universal, or suitable for every user.
          </p>
        </article>
      </div>
    </div>
  </section>

  <script is:inline>
  (() => {
    const form = document.getElementById("early-access-form");
    const status = document.getElementById("early-access-status");
    const startedAt = document.getElementById("startedAt");

    const messages = {
      "invalid-email": "Please enter a valid email address and try again.",
      "rate-limited": "Too many requests have been sent from your connection. Please try again later.",
      "submission-failed": "Something went wrong while sending your request. Please try again shortly.",
      "email-failed": "Your request could not be emailed. Please try again shortly.",
    };

    function resetStartedAt() {
      if (startedAt) {
        startedAt.value = String(Date.now());
      }
    }

    function isEarlyAccessPath(pathname) {
      return pathname === "/early-access" || pathname === "/early-access/";
    }

    resetStartedAt();

    if (!form || !status) return;

    form.addEventListener("submit", async (event) => {
      event.preventDefault();

      const submitButton = form.querySelector('button[type="submit"]');

      status.textContent = "Submitting your request...";
      status.className = "rh-form-status is-loading";

      if (submitButton) {
        submitButton.disabled = true;
        submitButton.setAttribute("aria-busy", "true");
      }

      try {
        const formData = new FormData(form);

        const response = await fetch("/api/early-access", {
          method: "POST",
          body: formData,
          headers: {
            Accept: "application/json, text/html",
          },
        });

        const finalUrl = new URL(response.url || window.location.href, window.location.origin);
        const contentType = response.headers.get("content-type") || "";

        const redirectedToSuccess =
          isEarlyAccessPath(finalUrl.pathname) &&
          finalUrl.searchParams.get("submitted") === "true";

        const redirectedToError =
          isEarlyAccessPath(finalUrl.pathname) &&
          finalUrl.searchParams.has("error");

        let result = null;

        if (contentType.includes("application/json")) {
          result = await response.json().catch(() => null);
        }

        if (redirectedToError) {
          const errorCode = finalUrl.searchParams.get("error") || "submission-failed";
          throw new Error(messages[errorCode] || "Your request could not be submitted. Please try again.");
        }

        if (!response.ok) {
          throw new Error("Your request could not be submitted. Please try again.");
        }

        if (result && result.ok !== true) {
          const message =
            result.error ||
            result.message ||
            "Your request could not be submitted. Please try again.";
          throw new Error(message);
        }

        if (!result && !redirectedToSuccess && contentType.includes("text/html")) {
          throw new Error("Your request could not be submitted. Please try again.");
        }

        status.textContent =
          "Thank you. Your early access request has been received.";
        status.className = "rh-form-status is-success";

        form.reset();
        resetStartedAt();

        if (window.turnstile && typeof window.turnstile.reset === "function") {
          window.turnstile.reset();
        }

        const registerSection = document.getElementById("register");
        if (registerSection) {
          registerSection.scrollIntoView({ behavior: "smooth", block: "start" });
        }
      } catch (error) {
        status.textContent =
          error instanceof Error && error.message
            ? error.message
            : "Something went wrong. Please try again.";
        status.className = "rh-form-status is-error";
      } finally {
        if (submitButton) {
          submitButton.disabled = false;
          submitButton.removeAttribute("aria-busy");
        }
      }
    });
  })();
</script>

  <style is:global>
    .rh-form-status {
      min-height: 1.5rem;
      margin-bottom: var(--space-5);
      font-weight: 700;
      line-height: 1.5;
    }

    .rh-form-status:empty {
      display: none;
    }

    .rh-form-status.is-loading {
      color: var(--rh-muted, #5b6472);
    }

    .rh-form-status.is-success {
      color: #166534;
    }

    .rh-form-status.is-error {
      color: #b91c1c;
    }

    .rh-form button[disabled],
    #early-access-form button[disabled] {
      opacity: 0.65;
      cursor: wait;
    }
  </style>
</BaseLayout>