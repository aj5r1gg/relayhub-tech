---
import BaseLayout from "../layouts/BaseLayout.astro";

type DownloadStatus =
  | "Final"
  | "Current"
  | "Preparing"
  | "Drafting"
  | "Planned"
  | "Not released";

type AccessMode =
  | "public"
  | "controlled"
  | "private"
  | "paid"
  | "preparing"
  | "planned"
  | "not-released";

type DownloadItem = {
  title: string;
  status: DownloadStatus;
  accessMode: AccessMode;
  type?: string;
  version?: string;
  description: string;
  href?: string;
  filename?: string;
  documentId?: string;
  accessNote?: string;
};

type ReleaseDownloadItem = {
  title: string;
  status: DownloadStatus;
  maturity: string;
  description: string;
  imageHref?: string;
  imageFilename?: string;
  checksumHref?: string;
  checksumFilename?: string;
  signatureHref?: string;
  signatureFilename?: string;
};

