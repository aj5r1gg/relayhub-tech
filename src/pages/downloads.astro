const hardwareDownloads = [
  "Bills of materials",
  "Assembly guides",
  "Hardware compatibility lists",
  "Capability manifests",
  "Power and thermal notes",
  "Radio policy notes",
  "Certification documents",
  "Manufacturing test checklists",
];

const downloadRules = [
  {
    title: "Respect access state",
    text: "Some documents are public downloads. Controlled documents are delivered through RelayHub’s controlled document access workflow so the correct version, licence terms, and access record are preserved.",
  },
  {
    title: "No raw links for controlled files",
    text: "Controlled documents must not expose raw storage links. They should route through the document access workflow and controlled download landing page.",
  },
  {
    title: "No dead public links",
    text: "Preparing, Drafting, Planned, and Not released files are listed for transparency but do not expose broken links.",
  },
  {
    title: "Version everything",
    text: "Every public file should include a version, date, maturity state, or release label.",
  },
  {
    title: "Do not imply support early",
    text: "Experimental, planned, prototype, and unsupported files must be labelled clearly.",
  },
  {
    title: "Keep releases verifiable",
    text: "Software images should be accompanied by checksums, signatures, release notes, and recovery notes.",
  },
  {
    title: "Separate public from private",
    text: "Never publish private keys, support bundles, unpublished builds, recovery material, or user data in a public bucket.",
  },
  {
    title: "Preserve recovery",
    text: "Downloads must not encourage workflows that make rollback, reset, transfer, or recovery harder.",
  },
  {
    title: "Tell the truth",
    text: "Downloads should distinguish implemented, planned, experimental, compatible, certified, and product-supported material.",
  },
];

const r2Structure = [
  "/docs/",
  "/guides/",
  "/releases/",
  "/brand/",
  "/media/",
  "/field-trials/",
  "/validation/",
  "/hardware/",
];

const renderDownloadStatus = (status: DownloadStatus) => {
  if (status === "Final") return "rh-download-status rh-download-status-available";
  if (status === "Current") return "rh-download-status rh-download-status-available";
  if (status === "Preparing") return "rh-download-status rh-download-status-preparing";
  if (status === "Drafting") return "rh-download-status rh-download-status-preparing";
  if (status === "Planned") return "rh-download-status rh-download-status-planned";
  return "rh-download-status rh-download-status-muted";
};

const renderAccessClass = (mode: AccessMode) => {
  if (mode === "public") return "rh-access-pill rh-access-public";
  if (mode === "controlled") return "rh-access-pill rh-access-controlled";
  if (mode === "private") return "rh-access-pill rh-access-private";
  if (mode === "paid") return "rh-access-pill rh-access-paid";
  if (mode === "preparing") return "rh-access-pill rh-access-preparing";
  if (mode === "planned") return "rh-access-pill rh-access-planned";
  return "rh-access-pill rh-access-muted";
};

const renderAccessLabel = (mode: AccessMode) => {
  if (mode === "public") return "Public download";
  if (mode === "controlled") return "Controlled access";
  if (mode === "private") return "Private access";
  if (mode === "paid") return "Paid access";
  if (mode === "preparing") return "Preparing";
  if (mode === "planned") return "Planned";
  return "Not released";
};

const getDocumentAccessHref = (item: DownloadItem) => {
  const documentId = item.documentId || item.title.toLowerCase().replace(/[^a-z0-9]+/g, "-");
  return `/document-access?document=${encodeURIComponent(documentId)}`;
};

const hasPublicDownload = (item: DownloadItem) => {
  return item.status === "Final" && item.accessMode === "public" && Boolean(item.href);
};

const getDownloadFilename = (item: DownloadItem) => {
  if (item.filename) return item.filename;
  if (!item.href) return undefined;

  const cleanHref = item.href.split("?")[0];
  const filename = cleanHref.split("/").pop();

  return filename || undefined;
};

const getReleaseFilename = (href?: string, filename?: string) => {
  if (filename) return filename;
  if (!href) return undefined;

  const cleanHref = href.split("?")[0];
  const derivedFilename = cleanHref.split("/").pop();

  return derivedFilename || undefined;
};
---

<BaseLayout
  title="Downloads | RelayHub"
  description="RelayHub downloads hub for public documents, controlled-access documents, guides, brand assets, field trial resources, future RelayOS images, checksums, signatures, hardware resources, and validation artefacts."
>
  <section class="rh-hero">
    <div class="rh-container rh-hero-inner">
      <p class="rh-eyebrow">Downloads</p>

      <h1 class="rh-title">
        RelayHub documents and downloads.
      </h1>

      <p class="rh-subtitle">
        Some documents are public downloads. Controlled documents are delivered
        through RelayHub’s document access workflow so the correct version,
        licence terms, and access record are preserved.
      </p>

      <div class="rh-actions">
        <a class="rh-button rh-button-primary" href="#documents">
          View documents
        </a>
        <a class="rh-button rh-button-secondary" href="#releases">
          Release status
        </a>
      </div>
    </div>
  </section>

  <section class="rh-section" id="documents">
    <div class="rh-container">
      <p class="rh-kicker">Documents</p>

      <h2 class="rh-section-title">
        Foundational RelayHub documents.
      </h2>

      <p class="rh-section-lead">
        Public documents can be downloaded directly. Controlled documents use
        RelayHub’s document access workflow and are not served through raw public
        storage links.
      </p>

      <div class="rh-download-grid">
        {documentDownloads.map((item) => (
          <article class="rh-download-card">
            <div class="rh-download-card-top">
              <span class={renderDownloadStatus(item.status)}>
                {item.status}
              </span>
              {item.type && <span class="rh-download-type">{item.type}</span>}
            </div>

            <div class="rh-access-row">
              <span class={renderAccessClass(item.accessMode)}>
                {renderAccessLabel(item.accessMode)}
              </span>
            </div>

            <h3 class="rh-download-title">{item.title}</h3>

            {item.version && <p class="rh-download-meta">{item.version}</p>}

            <p class="rh-download-text">{item.description}</p>

            {item.accessNote && (
              <p class="rh-download-note">{item.accessNote}</p>
            )}

            <div class="rh-download-actions">
              {hasPublicDownload(item) ? (
                <a
                  class="rh-download-button"
                  href={item.href}
                  download={getDownloadFilename(item)}
                >
                  Download
                </a>
              ) : item.accessMode === "controlled" ? (
                <a
                  class="rh-download-button"
                  href={getDocumentAccessHref(item)}
                >
                  Request access
                </a>
              ) : item.accessMode === "private" ? (
                <span class="rh-download-unavailable">
                  Private access
                </span>
              ) : item.accessMode === "paid" ? (
                <span class="rh-download-unavailable">
                  Paid access coming soon
                </span>
              ) : (
                <span class="rh-download-unavailable">
                  Download not available yet
                </span>
              )}
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="rh-section rh-bg-soft" id="guides">
    <div class="rh-container">
      <p class="rh-kicker">Guides</p>

      <h2 class="rh-section-title">
        Practical guides for setup, recovery, hardware, and validation.
      </h2>

      <p class="rh-section-lead">
        RelayHub documentation should remain useful for ordinary people, not
        just developers. Setup, recovery, and validation guidance should be
        available offline wherever practical.
      </p>

      <div class="rh-download-grid rh-download-grid-2">
        {guideDownloads.map((item) => (
          <article class="rh-download-card">
            <div class="rh-download-card-top">
              <span class={renderDownloadStatus(item.status)}>
                {item.status}
              </span>
              {item.type && <span class="rh-download-type">{item.type}</span>}
            </div>

            <div class="rh-access-row">
              <span class={renderAccessClass(item.accessMode)}>
                {renderAccessLabel(item.accessMode)}
              </span>
            </div>

            <h3 class="rh-download-title">{item.title}</h3>
            <p class="rh-download-text">{item.description}</p>

            <div class="rh-download-actions">
              {hasPublicDownload(item) ? (
                <a
                  class="rh-download-button"
                  href={item.href}
                  download={getDownloadFilename(item)}
                >
                  Download
                </a>
              ) : (
                <span class="rh-download-unavailable">
                  Download not available yet
                </span>
              )}
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="rh-section rh-dark" id="releases">
    <div class="rh-container">
      <p class="rh-kicker">RelayOS releases</p>

      <h2 class="rh-section-title">
        No public RelayOS images are available yet.
      </h2>

      <p class="rh-section-lead">
        RelayOS images should not be published merely because a build exists.
        A release must have a clear hardware class, support state, checksum,
        signature, release notes, rollback path, and recovery path.
      </p>

      <div class="rh-download-grid">
        {releaseDownloads.map((item) => (
          <article class="rh-download-card rh-download-card-dark">
            <div class="rh-download-card-top">
              <span class={renderDownloadStatus(item.status)}>
                {item.status}
              </span>
              <span class="rh-download-type">{item.maturity}</span>
            </div>

            <h3 class="rh-download-title">{item.title}</h3>
            <p class="rh-download-text">{item.description}</p>

            <div class="rh-download-actions rh-download-actions-stacked">
              {item.imageHref ? (
                <a
                  class="rh-download-button"
                  href={item.imageHref}
                  download={getReleaseFilename(item.imageHref, item.imageFilename)}
                >
                  Download image
                </a>
              ) : (
                <span class="rh-download-button rh-download-button-disabled">
                  Image not available
                </span>
              )}

              {item.checksumHref ? (
                <a
                  class="rh-download-link"
                  href={item.checksumHref}
                  download={getReleaseFilename(item.checksumHref, item.checksumFilename)}
                >
                  SHA256 checksum
                </a>
              ) : (
                <span class="rh-download-link-muted">Checksum pending</span>
              )}

              {item.signatureHref ? (
                <a
                  class="rh-download-link"
                  href={item.signatureHref}
                  download={getReleaseFilename(item.signatureHref, item.signatureFilename)}
                >
                  Signature
                </a>
              ) : (
                <span class="rh-download-link-muted">Signature pending</span>
              )}
            </div>
          </article>
        ))}
      </div>

      <div class="rh-actions">
        <a class="rh-button rh-button-accent" href="/validation">
          Validation
        </a>
        <a class="rh-button rh-button-secondary" href="/recovery">
          Recovery
        </a>
      </div>
    </div>
  </section>

  <section class="rh-section" id="brand">
    <div class="rh-container">
      <p class="rh-kicker">Brand and media</p>

      <h2 class="rh-section-title">
        Brand assets should keep RelayHub consistent.
      </h2>

      <p class="rh-section-lead">
        Logos, colour references, media assets, and public identity material
        should match the RelayHub brand and terminology rules.
      </p>

      <div class="rh-download-grid rh-download-grid-3">
        {brandDownloads.map((item) => (
          <article class="rh-download-card">
            <div class="rh-download-card-top">
              <span class={renderDownloadStatus(item.status)}>
                {item.status}
              </span>
              {item.type && <span class="rh-download-type">{item.type}</span>}
            </div>

            <div class="rh-access-row">
              <span class={renderAccessClass(item.accessMode)}>
                {renderAccessLabel(item.accessMode)}
              </span>
            </div>

            <h3 class="rh-download-title">{item.title}</h3>
            <p class="rh-download-text">{item.description}</p>

            <div class="rh-download-actions">
              {hasPublicDownload(item) ? (
                <a
                  class="rh-download-button"
                  href={item.href}
                  download={getDownloadFilename(item)}
                >
                  Download
                </a>
              ) : (
                <span class="rh-download-unavailable">
                  Download not available yet
                </span>
              )}
            </div>
          </article>
        ))}
      </div>

      <div class="rh-actions">
        <a class="rh-button rh-button-secondary" href="/media">
          Media page
        </a>
      </div>
    </div>
  </section>

  <section class="rh-section rh-bg-soft" id="field-trials">
    <div class="rh-container">
      <p class="rh-kicker">Field trials</p>

      <h2 class="rh-section-title">
        Resources for pilots, testing, and real-world feedback.
      </h2>

      <p class="rh-section-lead">
        Field trial files should help communities test onboarding, local-only
        operation, no-peers behaviour, recovery, support export, and user
        comprehension before scaling.
      </p>

      <div class="rh-download-grid rh-download-grid-3">
        {fieldTrialDownloads.map((item) => (
          <article class="rh-download-card">
            <div class="rh-download-card-top">
              <span class={renderDownloadStatus(item.status)}>
                {item.status}
              </span>
              {item.type && <span class="rh-download-type">{item.type}</span>}
            </div>

            <div class="rh-access-row">
              <span class={renderAccessClass(item.accessMode)}>
                {renderAccessLabel(item.accessMode)}
              </span>
            </div>

            <h3 class="rh-download-title">{item.title}</h3>
            <p class="rh-download-text">{item.description}</p>

            <div class="rh-download-actions">
              {hasPublicDownload(item) ? (
                <a
                  class="rh-download-button"
                  href={item.href}
                  download={getDownloadFilename(item)}
                >
                  Download
                </a>
              ) : (
                <span class="rh-download-unavailable">
                  Download not available yet
                </span>
              )}
            </div>
          </article>
        ))}
      </div>

      <div class="rh-actions">
        <a class="rh-button rh-button-secondary" href="/pilot-program">
          Pilot program
        </a>
        <a class="rh-button rh-button-secondary" href="/field-trials">
          Field trials
        </a>
      </div>
    </div>
  </section>

  <section class="rh-section" id="hardware">
    <div class="rh-container rh-grid rh-grid-2">
      <div>
        <p class="rh-kicker">Hardware resources</p>

        <h2 class="rh-section-title">
          Hardware files must not imply support before validation.
        </h2>

        <p class="rh-section-lead">
          Future hardware downloads should clearly identify whether they are
          concept, experimental, compatible, verified, certified, or officially
          supported.
        </p>

        <div class="rh-actions">
          <a class="rh-button rh-button-secondary" href="/hardware">
            Hardware
          </a>
          <a class="rh-button rh-button-secondary" href="/hardware-comparison">
            Compare hardware
          </a>
          <a class="rh-button rh-button-secondary" href="/certification">
            Certification
          </a>
        </div>
      </div>

      <article class="rh-card">
        <ul class="rh-download-list">
          {hardwareDownloads.map((item) => <li>{item}</li>)}
        </ul>
      </article>
    </div>
  </section>

  <section class="rh-section rh-bg-soft" id="cloudflare">
    <div class="rh-container rh-grid rh-grid-2">
      <div>
        <p class="rh-kicker">Cloudflare R2 structure</p>

        <h2 class="rh-section-title">
          Upload files to the matching R2 folders.
        </h2>

        <p class="rh-section-lead">
          Public files may live behind the public download path. Controlled
          documents should be managed through CDAS and should not expose raw
          storage links on this page.
        </p>
      </div>

      <article class="rh-card">
        <ul class="rh-download-list rh-mono-list">
          {r2Structure.map((item) => <li>{item}</li>)}
        </ul>
      </article>
    </div>
  </section>

  <section class="rh-section">
    <div class="rh-container">
      <p class="rh-kicker">Download rules</p>

      <h2 class="rh-section-title">
        Every document should carry status, scope, and access state.
      </h2>

      <p class="rh-section-lead">
        RelayHub should avoid publishing files that create false expectations.
        Downloads should explain their version, maturity, access model, support
        boundary, and recovery implications.
      </p>

      <div class="rh-download-grid rh-download-grid-3">
        {downloadRules.map((item) => (
          <article class="rh-card">
            <h3 class="rh-card-title">{item.title}</h3>
            <p class="rh-card-text">{item.text}</p>
          </article>
        ))}
      </div>
    </div>
