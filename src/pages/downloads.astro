  },
];

const fieldTrialDownloads: DownloadItem[] = [
  {
    title: "Pilot Program Pack",
    status: "Planned",
    accessMode: "planned",
    type: "PDF",
    description:
      "Pilot readiness notes, participant expectations, onboarding flow, field observations, and feedback capture.",
  },
  {
    title: "Field Trial Checklist",
    status: "Planned",
    accessMode: "planned",
    type: "PDF",
    description:
      "Task checklist for testing setup, local-only operation, no-peers state, recovery, support export, and comprehension.",
  },
  {
    title: "Recovery Drill Worksheet",
    status: "Planned",
    accessMode: "planned",
    type: "PDF",
    description:
      "Worksheet for rehearsing recovery without assuming terminal access or live internet.",
  },
