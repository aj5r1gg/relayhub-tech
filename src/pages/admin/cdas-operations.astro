    async function workflowFetch(path, options = {}) {
      const token = getAdminToken();

      if (!token) {
        throw new Error("Admin token is required before workflow actions can be submitted.");
      }

      const response = await fetch(path, {
        method: options.method || "GET",
        headers: {
          accept: "application/json",
          authorization: `Bearer ${token}`,
          ...(options.body ? { "content-type": "application/json" } : {}),
        },
        body: options.body ? JSON.stringify(options.body) : undefined,
      });

      const data = await response.json();

      if (!response.ok || !data.ok) {
        const blockers = Array.isArray(data.blockers) && data.blockers.length
          ? ` Blockers: ${data.blockers.join(", ")}.`
          : "";

        throw new Error(
          `${data.message || data.error || `Workflow action failed with ${response.status}`}.${blockers}`,
        );
      }

      return data;
    }

    function promptLandingUrl() {
      return window.prompt(
        "Paste the one-time landing URL or raw rh_dl_ token. It is not stored in D1 and cannot be recovered by the Operations Centre.",
        "",
      );
    }

    async function handleCdasWorkflowAction(action, button) {
      const licenceId = button.getAttribute("data-licence-id") || "";
      const downloadLinkId = button.getAttribute("data-download-link-id") || "";

      const setWorkflowResult = (kind, message) => {
        setReviewActionResult(kind, message);
        setInlineWorkflowActionResult(button, kind, message);
      };

      try {
        if (action === "check-pdf") {
          setWorkflowResult("loading", `Checking PDF eligibility for ${licenceId}…`);
          const data = await workflowFetch(
            `/api/admin/cdas/licences/${encodeURIComponent(licenceId)}/pdf-eligibility`,
          );

          setWorkflowResult(
            data.eligible ? "success" : "info",
            data.eligible
              ? `PDF generation is eligible for ${data.licence_number || licenceId}.`
              : `PDF generation is blocked. Blockers: ${(data.blockers || []).join(", ") || "none reported"}.`,
          );
          return;
        }

        if (action === "generate-pdf") {
          const note = window.prompt(
            "Generate personalised PDF note:",
            "Operations Centre: generate personalised PDF only. Do not create a download link, send email, or serve PDF.",
          );
          if (note === null) return;

          setWorkflowResult("loading", `Generating personalised PDF for ${licenceId}…`);
          const data = await workflowFetch(
            `/api/admin/cdas/licences/${encodeURIComponent(licenceId)}/generate-pdf`,
            {
              method: "POST",
              body: { actor: "operations-centre", note },
            },
          );

          setWorkflowResult(
            "success",
            `PDF generated for ${data.licence?.licence_number || licenceId}. No link or email was created.`,
          );
          await loadOperations();
          return;
        }

        if (action === "check-link") {
          setWorkflowResult("loading", `Checking download-link eligibility for ${licenceId}…`);
          const data = await workflowFetch(
            `/api/admin/cdas/licences/${encodeURIComponent(licenceId)}/download-link-eligibility`,
          );

          setWorkflowResult(
            data.eligible ? "success" : "info",
            data.eligible
              ? `Download-link creation is eligible for ${data.licence_number || licenceId}.`
              : `Download-link creation is blocked. Blockers: ${(data.blockers || []).join(", ") || "none reported"}.`,
          );
          return;
        }

        if (action === "create-link") {
          const daysRaw = window.prompt("Link expiry in days:", "7");
          if (daysRaw === null) return;

          const expiresInDays = Number(daysRaw || 7);

          setWorkflowResult("loading", `Creating controlled download link for ${licenceId}…`);
          const data = await workflowFetch(
            `/api/admin/cdas/licences/${encodeURIComponent(licenceId)}/issue-download-link`,
            {
              method: "POST",
              body: {
                actor: "operations-centre",
                note: "Operations Centre: create controlled link only. Do not activate, email, or serve PDF.",
                expires_in_days: Number.isFinite(expiresInDays) ? expiresInDays : 7,
              },
            },
          );

          setWorkflowResult(
            "success",
            `Controlled link created in ${data.download_link?.status}. Copy this one-time URL now: ${data.download_link?.landing_url || data.download_link?.url || "not returned"}`,
          );
          await loadOperations();
          return;
        }

        if (action === "check-activation") {
          setWorkflowResult("loading", `Checking activation eligibility for ${downloadLinkId}…`);
          const data = await workflowFetch(
            `/api/admin/cdas/download-links/${encodeURIComponent(downloadLinkId)}/activation-eligibility`,
          );

          setWorkflowResult(
            data.eligible ? "success" : "info",
            data.eligible
              ? `Download link ${data.download_reference || downloadLinkId} can be activated.`
              : `Activation is blocked. Blockers: ${(data.blockers || []).join(", ") || "none reported"}.`,
          );
          return;
        }

        if (action === "activate-link") {
          const note = window.prompt(
            "Activation note:",
            "Operations Centre: activate existing controlled download link only. Do not email or serve PDF.",
          );
          if (note === null) return;

          setWorkflowResult("loading", `Activating download link ${downloadLinkId}…`);
          const data = await workflowFetch(
            `/api/admin/cdas/download-links/${encodeURIComponent(downloadLinkId)}/activate`,
            {
              method: "POST",
              body: { actor: "operations-centre", note },
            },
          );

          setWorkflowResult(
            "success",
            `Download link ${data.download_link?.download_reference || downloadLinkId} activated. No email was sent.`,
          );
          await loadOperations();
          return;
        }

        if (action === "prepare-delivery") {
          const landingUrl = promptLandingUrl();
          if (landingUrl === null) return;

          setWorkflowResult("loading", `Preparing delivery payload for ${downloadLinkId}…`);
          const data = await workflowFetch(
            `/api/admin/cdas/download-links/${encodeURIComponent(downloadLinkId)}/prepare-delivery`,
            {
              method: "POST",
              body: {
                actor: "operations-centre",
                note: "Operations Centre: prepare delivery payload only. Do not email or serve PDF.",
                landing_url: landingUrl,
              },
            },
          );

          setWorkflowResult(
            "success",
            `Delivery payload prepared for ${data.delivery_payload?.to || "recipient"}. No email was sent.`,
          );
          return;
        }

        if (action === "send-email") {
          const landingUrl = promptLandingUrl();
          if (landingUrl === null) return;

          const confirmed = window.confirm(
            "Send the controlled delivery email now? This will not serve the PDF or consume the link.",
          );

          if (!confirmed) {
            setWorkflowResult("info", "Email send cancelled.");
            return;
          }

          setWorkflowResult("loading", `Sending delivery email for ${downloadLinkId}…`);
          const data = await workflowFetch(
            `/api/admin/cdas/download-links/${encodeURIComponent(downloadLinkId)}/send-delivery-email`,
            {
              method: "POST",
              body: {
                actor: "operations-centre",
                note: "Operations Centre: send controlled delivery email only. Do not serve PDF or consume link.",
                landing_url: landingUrl,
              },
            },
          );

          setWorkflowResult(
            "success",
            `Delivery email sent via ${data.email_result?.provider || "provider"}: ${data.email_result?.provider_message_id || "message id not returned"}.`,
          );
          await loadOperations();
          return;
        }


        if (action === "check-reissue") {
          const downloadReference =
            button.getAttribute("data-download-reference") || downloadLinkId;

          setWorkflowResult(
            "loading",
            `Checking reissue eligibility for ${downloadReference}…`,
          );

          const data = await workflowFetch(
            `/api/admin/cdas/download-links/${encodeURIComponent(downloadLinkId)}/reissue-eligibility`,
          );

          const blockers = (data.blockers || []).join(", ") || "none reported";

          setWorkflowResult(
            data.eligible ? "success" : "info",
            data.eligible
              ? `${downloadReference} is eligible for controlled reissue. Next action: ${niceLabel(data.next_allowed_action || "create replacement pending activation link")}.`
              : `${downloadReference} cannot be reissued now. Blockers: ${blockers}.`,
          );

          return;
        }

        if (action === "reissue-link") {
          const downloadReference =
            button.getAttribute("data-download-reference") || downloadLinkId;

          const note = window.prompt(
            `Controlled reissue note for ${downloadReference}:`,
            "Operations Centre: create replacement pending_activation link only. Do not activate, email, serve PDF, modify licence, or delete R2.",
          );

          if (note === null) {
            setWorkflowResult("info", "Controlled reissue cancelled.");
            return;
          }

          const confirmed = window.confirm(
            `Create a replacement controlled download link for ${downloadReference}? This returns a one-time landing URL. It does not activate the link, email anyone, serve the PDF, modify the licence, or delete R2.`,
          );

          if (!confirmed) {
            setWorkflowResult("info", "Controlled reissue cancelled.");
            return;
          }

          setWorkflowResult(
            "loading",
            `Creating replacement controlled link for ${downloadReference}…`,
          );

          const data = await workflowFetch(
            `/api/admin/cdas/download-links/${encodeURIComponent(downloadLinkId)}/reissue`,
            {
              method: "POST",
              body: {
                actor: "operations-centre",
                note,
                expires_in_days: 7,
              },
            },
          );

          const newLink = data.new_download_link || {};
          const landingUrl = newLink.landing_url || newLink.url || "";

          setWorkflowResult(
            "success",
            `Replacement link ${newLink.download_reference || newLink.id || ""} created in ${newLink.status || "pending_activation"}. Copy this one-time URL now: ${landingUrl || "not returned"}`,
          );

          await loadOperations();
          return;
        }

        setWorkflowResult("error", `Unknown workflow action: ${action}`);
      } catch (error) {
        setWorkflowResult("error", error?.message || "Workflow action failed.");
      }
    }

    function table(targetId, rows, columns, emptyText, options = {}) {
      const target = document.getElementById(targetId);
      if (!target) return;

      if (!Array.isArray(rows) || rows.length === 0) {
        tablePages.delete(targetId);
        target.innerHTML = emptyMessage(emptyText);
        return;
      }

      const pageSize = Number(options.pageSize || TABLE_PAGE_SIZE);
      const totalPages = Math.max(1, Math.ceil(rows.length / pageSize));
      const currentPage = Math.min(
        Math.max(1, Number(tablePages.get(targetId) || 1)),
        totalPages,
      );

      tablePages.set(targetId, currentPage);

      const startIndex = (currentPage - 1) * pageSize;
      const visibleRows = rows.slice(startIndex, startIndex + pageSize);

      target.innerHTML = `
        <div class="rh-table-wrap">
          <table class="rh-table">
            <thead>
              <tr>
                ${columns
                  .map((column) => `<th>${escapeHtml(column.label)}</th>`)
                  .join("")}
              </tr>
            </thead>
            <tbody>
              ${visibleRows
                .map((row) => {
                  const mainRow = `
                    <tr>
                      ${columns
                        .map((column) => {
                          const wrapClass = column.wrap ? "rh-wrap" : "";

                          if (column.renderHtml) {
                            return `<td class="${wrapClass}">${column.renderHtml(row)}</td>`;
                          }

                          const value = column.render
                            ? column.render(row)
                            : row[column.key];

                          return `<td class="${wrapClass}">${escapeHtml(value ?? "")}</td>`;
                        })
                        .join("")}
                    </tr>
                  `;

                  const expandedRow = options.renderExpandedHtml
                    ? `<tr><td class="rh-request-action-row" colspan="${columns.length}">${options.renderExpandedHtml(row)}</td></tr>`
                    : "";

                  return mainRow + expandedRow;
                })
                .join("")}
            </tbody>
          </table>
          ${
            rows.length > pageSize
              ? `<div class="rh-table-pager">
                  <span>Showing ${startIndex + 1}-${Math.min(
                    startIndex + pageSize,
                    rows.length,
                  )} of ${rows.length}</span>
                  <span class="rh-request-action-row-inner">
                    <button class="rh-mini-button" type="button" data-table-page="prev" data-table-id="${escapeHtml(targetId)}" ${currentPage <= 1 ? "disabled" : ""}>Previous</button>
                    <span>Page ${currentPage} of ${totalPages}</span>
                    <button class="rh-mini-button" type="button" data-table-page="next" data-table-id="${escapeHtml(targetId)}" ${currentPage >= totalPages ? "disabled" : ""}>Next</button>
                  </span>
                </div>`
              : ""
          }
        </div>
      `;
    }

    function renderStatus(data) {
      const warnings = Array.isArray(data.warnings) ? data.warnings : [];
      const notices = Array.isArray(data.notices) ? data.notices : [];
      const status = data.status || "unknown";

      if (!statusPanel) return;

      statusPanel.dataset.status = status;

      statusPanel.innerHTML = `
        <p class="rh-eyebrow">CDAS Operations</p>
        <h2>System status: ${escapeHtml(niceLabel(status))}</h2>
        <p>
          Generated at: ${escapeHtml(data.generated_at || "unknown")}.
          This page is read-only and intended for daily operational awareness.
        </p>

        ${
          warnings.length
            ? `<h3>Warnings</h3><div class="rh-pill-list">${warnings
                .map(
                  (item) =>
                    `<span class="rh-pill rh-pill-warning">${escapeHtml(
                      niceLabel(item),
                    )}</span>`,
                )
                .join("")}</div>`
            : ""
        }

        ${
          notices.length
            ? `<h3>Notices</h3><div class="rh-pill-list">${notices
                .map(
                  (item) =>
                    `<span class="rh-pill rh-pill-notice">${escapeHtml(
                      niceLabel(item),
                    )}</span>`,
                )
                .join("")}</div>`
            : ""
        }

        ${
          !warnings.length && !notices.length
            ? `<p>No current warnings or notices reported by the operations endpoint.</p>`
            : ""
        }
      `;
    }


    function badge(label, kind = "muted", title = "") {
      const safeKind = ["success", "info", "warning", "danger", "muted"].includes(kind)
        ? kind
        : "muted";

      return `<span class="rh-state-badge rh-state-badge-${safeKind}" title="${escapeHtml(title || label)}">${escapeHtml(label)}</span>`;
    }

    function linkStateBadges(row) {
      const badges = [];
      const linkStatus = String(row.latest_download_link_status || "");

      if (row.generated_pdf_status === "generated") {
        badges.push(badge("PDF generated", "success", row.generated_pdf_sha256 || ""));
      } else {
        badges.push(badge(`PDF ${niceLabel(row.generated_pdf_status || "not generated")}`, "warning"));
      }

      if (!row.latest_download_link_id) {
        badges.push(badge("No link", "muted"));
      } else if (linkStatus === "pending_activation") {
        badges.push(badge("Replacement pending activation", "warning", row.latest_download_reference || ""));
      } else if (linkStatus === "active") {
        badges.push(badge("Link active", "success", row.latest_download_reference || ""));
      } else if (linkStatus === "used") {
        badges.push(badge("Downloaded", "success", row.latest_download_link_used_at || ""));
      } else if (linkStatus === "revoked") {
        badges.push(badge("Link revoked", "danger", row.latest_download_link_revoked_at || ""));
      } else if (linkStatus === "superseded") {
        badges.push(badge("Link superseded", "danger", row.latest_download_link_superseded_at || ""));
      } else {
        badges.push(badge(`Link ${niceLabel(linkStatus || "unknown")}`, "info"));
      }

      if (Number(row.open_download_link_count || 0) > 0) {
        badges.push(badge("Further reissue blocked", "warning", `${row.open_download_link_count} open link(s)`));
      }

      if (row.latest_reissue_event_at) {
        badges.push(badge("Reissue event recorded", "info", row.latest_reissue_event_at));
      }

      return `<div class="rh-state-badges">${badges.join("")}</div>`;
    }

    function reissueEvidence(row) {
      const items = [];

      if (row.latest_download_link_id) {
        items.push(
          `Latest link: ${escapeHtml(row.latest_download_reference || row.latest_download_link_id)} (${escapeHtml(niceLabel(row.latest_download_link_status || "unknown"))})`,
        );
      }

      if (row.latest_reissue_event_at) {
        items.push(`Reissue event: ${escapeHtml(row.latest_reissue_event_at)}`);
      }

      if (row.latest_reissue_detail) {
        items.push(`Reissue detail: ${escapeHtml(row.latest_reissue_detail)}`);
      }

      if (row.latest_superseded_reference) {
        items.push(
          `Replaced/superseded link: ${escapeHtml(row.latest_superseded_reference)} (${escapeHtml(niceLabel(row.latest_superseded_link_status || "unknown"))}) at ${escapeHtml(row.latest_superseded_at || "unknown time")}`,
        );
      }

      if (Number(row.pending_activation_link_count || 0) > 0) {
        items.push("Open replacement link is pending activation; further reissue is blocked until it is resolved.");
      }

      if (items.length === 0) {
        return `<span class="rh-muted">No reissue evidence recorded.</span>`;
      }

      return `<div class="rh-evidence-mini">${items.map((item) => `<span>${item}</span>`).join("")}</div>`;
    }

    function downloadEventBadges(row) {
      const eventType = String(row.event_type || "");
      const success = Number(row.success) === 1;
      const badges = [];

      if (eventType === "download_link_reissued_pending_activation") {
        badges.push(badge("Reissued pending activation", "info", row.failure_reason || ""));
      } else if (eventType === "download_link_revoked") {
        badges.push(badge("Link revoked", "danger", row.failure_reason || ""));
      } else if (eventType === "download_link_revocation_notice_sent") {
        badges.push(badge("Revocation notice sent", "info", row.failure_reason || ""));
      } else if (eventType === "document_downloaded") {
        badges.push(badge("Downloaded", "success", row.event_at || ""));
      } else {
        badges.push(badge(niceLabel(eventType || "event"), success ? "info" : "warning", row.failure_reason || ""));
      }

      badges.push(success ? badge("Success", "success") : badge("Blocked / failed", "warning"));

      if (row.download_link_status) {
        badges.push(badge(`Link ${niceLabel(row.download_link_status)}`, "info"));
      }

      return `<div class="rh-state-badges">${badges.join("")}</div>`;
    }

    function clearRenderedData() {
      [
        "coreMetrics",
        "emailMetrics",
        "workflowMetrics",
        "licenceMetrics",
        "downloadMetrics",
        "integrityMetrics",
        "failedEmails",
        "pendingRequests",
        "recentLicences",
        "recentDownloads",
      ].forEach((id) => {
        const el = document.getElementById(id);
        if (el) el.innerHTML = "";
      });

      if (rawPayload) {
        rawPayload.textContent = "";
      }
    }

    async function loadOperations() {
      const token = getAdminToken();
      updateTokenStatus();

      if (!token) {
        clearRenderedData();
        setStatusPanel(
          "fault",
          "Admin authentication",
          "Admin token required",
          "Paste and save the admin token above, then refresh operations status.",
        );
        return;
      }

      setStatusPanel(
        "loading",
        "Loading",
        "Loading CDAS operations status…",
        "Fetching the latest operational state from the protected Worker endpoint.",
      );

      try {
        const response = await fetch(API_URL, {
          headers: {
            Accept: "application/json",
            Authorization: `Bearer ${token}`,
          },
        });

        const data = await response.json();

        if (!response.ok || !data.ok) {
          throw new Error(data.error || `Request failed with ${response.status}`);
        }

        renderStatus(data);

        metricGrid("coreMetrics", data.core);
        metricGrid("emailMetrics", data.email);
        metricGrid("workflowMetrics", data.workflow);
        metricGrid("licenceMetrics", data.licences);
        metricGrid("downloadMetrics", data.downloads);
        metricGrid("integrityMetrics", data.integrity);

        table(
          "failedEmails",
          data.recent?.failed_emails,
          [
            { key: "created_at", label: "Created" },
            { key: "recipient_email", label: "Recipient" },
            { key: "email_type", label: "Type" },
            { key: "subject", label: "Subject", wrap: true },
            { key: "status", label: "Status" },
            { key: "retry_count", label: "Retries" },
            {
              key: "resolved",
              label: "Resolved",
              render: (row) => (row.resolved_at ? "Yes" : "No"),
            },
            {
              key: "actions",
              label: "Actions",
              renderHtml: (row) =>
                adminActionLinks([
                  {
                    label: "Email event",
                    href: adminUrl("/admin/cdas-email-events/", {
                      id: row.id,
                    }),
                  },
                  row.related_type === "access_request"
                    ? {
                        label: "Request",
                        href: adminUrl("/admin/cdas-access-requests/", {
                          id: row.related_id,
                        }),
                      }
                    : null,
                ]),
            },
          ],
          "No recent failed emails.",
          { pageSize: 8 },
        );

        table(
          "pendingRequests",
          data.recent?.pending_requests,
          [
            {
              key: "id",
              label: "Request ID",
              wrap: true,
              render: (row) => row.id || "",
            },
            { key: "requested_at", label: "Requested" },
            { key: "document_id", label: "Document", wrap: true },
            { key: "document_version", label: "Version" },
            { key: "email", label: "Email", wrap: true },
            { key: "status", label: "Status", render: (row) => niceLabel(row.status) },
            {
              key: "verified",
              label: "Verified",
              render: (row) => (row.email_verified_at ? "Yes" : "No"),
            },
            {
              key: "risk_score",
              label: "Risk",
              render: (row) => row.risk_score ?? 0,
            },
            {
              key: "latest_review_event",
              label: "Last Review Event",
              render: (row) =>
                row.latest_review_event ? niceLabel(row.latest_review_event) : "",
            },
          ],
          "No access requests currently require review.",
          {
            pageSize: 8,
            renderExpandedHtml: (row) => reviewActionButtons(row),
          },
        );

        recentLicenceCards(
          "recentLicences",
          data.recent?.recent_licences,
        );

        table(
          "recentDownloads",
          data.recent?.recent_downloads,
          [
            { key: "event_at", label: "Event Time" },
            {
              key: "event_type",
              label: "Event",
              render: (row) => niceLabel(row.event_type || "event"),
            },
            { key: "download_reference", label: "Reference" },
            { key: "download_id", label: "Download ID", wrap: true },
            { key: "licence_number", label: "Licence" },
            {
              key: "evidence",
              label: "Evidence",
              wrap: true,
              renderHtml: (row) => downloadEventBadges(row),
            },
          ],
          "No recent downloads.",
        );


        if (rawPayload) {
          rawPayload.textContent = JSON.stringify(data, null, 2);
        }

        updateTokenStatus("Operations data loaded successfully.");
      } catch (error) {
        clearRenderedData();

        const message = error instanceof Error ? error.message : String(error);

        setStatusPanel(
          "fault",
          "Operations error",
          "Operations status could not be loaded",
          `${message}. Check the Worker route, admin authentication, and D1 schema.`,
        );

        updateTokenStatus("Operations request failed. Check the saved admin token.");
      }
    }

    document.addEventListener("click", (event) => {
      const pageButton = event.target.closest("[data-table-page][data-table-id]");

      if (pageButton) {
        const tableId = pageButton.getAttribute("data-table-id");
        const direction = pageButton.getAttribute("data-table-page");
        const current = Number(tablePages.get(tableId) || 1);

        tablePages.set(
          tableId,
          direction === "next" ? current + 1 : Math.max(1, current - 1),
        );

        loadOperations();
        return;
      }

      const workflowButton = event.target.closest("[data-cdas-workflow-action]");

      if (workflowButton) {
        const action = workflowButton.getAttribute("data-cdas-workflow-action");

        if (action) {
          handleCdasWorkflowAction(action, workflowButton);
          return;
        }
      }

      const recoveryButton = event.target.closest("[data-recovery-action][data-download-link-id]");

      if (recoveryButton) {
        const action = recoveryButton.getAttribute("data-recovery-action");

        if (action) {
          handleRecoveryAction(action, recoveryButton);
          return;
        }
      }

      const licenceButton = event.target.closest("[data-licence-action][data-request-id]");

      if (licenceButton) {
        const action = licenceButton.getAttribute("data-licence-action");
        const requestId = licenceButton.getAttribute("data-request-id");

        if (action === "eligibility" && requestId) {
          checkLicenceEligibility(requestId);
          return;
        }

        if (action === "issue" && requestId) {
          issueReviewedLicence(requestId);
          return;
        }
      }

      const button = event.target.closest("[data-review-action][data-request-id]");
      if (!button) return;

      const action = button.getAttribute("data-review-action");
      const requestId = button.getAttribute("data-request-id");

      if (!action || !requestId) return;

      submitReviewAction(requestId, action);
    });

    refreshBtn?.addEventListener("click", () => {
      loadOperations();
    });

    window.relayhubAdminTokenUpdated = () => {
      updateTokenStatus(
        "Admin token saved for this browser session. Refreshing operations data…",
      );
      loadOperations();
    };

    window.relayhubAdminTokenCleared = () => {
      clearRenderedData();
      updateTokenStatus();
      setStatusPanel(
        "fault",
        "Admin authentication",
        "Admin token required",
        "Paste and save the admin token above, then refresh operations status.",
      );
    };

    updateTokenStatus();
    loadOperations();
  </script>
</BaseLayout>