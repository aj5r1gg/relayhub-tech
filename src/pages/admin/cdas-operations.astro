---
import BaseLayout from "../../layouts/BaseLayout.astro";
import AdminTokenPanel from "../../components/AdminTokenPanel.astro";

const title = "CDAS Operations Centre | RelayHub";
const description =
  "Operational command centre for the RelayHub Controlled Document Access System.";
---

<BaseLayout title={title} description={description} noindex={true}>
  <main class="rh-admin-page">
    <section class="rh-admin-hero">
      <p class="rh-eyebrow">RelayHub Admin</p>
      <h1>CDAS Operations Centre</h1>
      <p>
        Single-pane operational view for document access, email delivery,
        licence issue, download links, workflow backlog, and evidence integrity.
        This page includes safe manual review controls. It does not issue
        licences, generate PDFs, or create download links.
      </p>
    </section>

    <AdminTokenPanel />

    <section class="rh-admin-card rh-admin-token-card">
      <div>
        <h2>Operations status</h2>
        <p id="token-status">Checking browser session…</p>
      </div>

      <div class="rh-admin-token-actions">
        <button class="rh-button rh-button-primary" id="refreshBtn" type="button">
          Refresh operations status
        </button>
      </div>
    </section>

    <nav class="rh-admin-linkbar" aria-label="CDAS admin links">
      <a href="/admin/">Admin hub</a>
      <a href="/admin/cdas-health/">Full health dashboard</a>
      <a href="/admin/cdas-email-events/">Email events</a>
      <a href="/admin/cdas-access-requests/">Access requests</a>
      <a href="/admin/cdas-licences/">Licences</a>
      <a href="/admin/cdas-download-links/">Download links</a>
      <a href="/admin/cdas-documents/">Documents</a>
      <a href="/admin/downloads/">Download analytics</a>
    </nav>

    <section id="statusPanel" class="rh-admin-status-card" data-status="loading">
      <p class="rh-eyebrow">Loading</p>
      <h2>Loading CDAS operations status…</h2>
      <p>Fetching the latest operational state.</p>
    </section>

    <section
      class="rh-admin-grid rh-admin-metrics-grid"
      aria-label="CDAS operational metrics"
    >
      <article class="rh-admin-card">
        <div class="rh-card-heading">
          <p class="rh-eyebrow">System</p>
          <h2>Core Metrics</h2>
        </div>
        <div id="coreMetrics" class="rh-metric-grid"></div>
      </article>

      <article class="rh-admin-card">
        <div class="rh-card-heading">
          <p class="rh-eyebrow">Delivery</p>
          <h2>Email Operations</h2>
        </div>
        <div id="emailMetrics" class="rh-metric-grid"></div>
      </article>

      <article class="rh-admin-card">
        <div class="rh-card-heading">
          <p class="rh-eyebrow">Workflow</p>
          <h2>Workflow Backlog</h2>
        </div>
        <div id="workflowMetrics" class="rh-metric-grid"></div>
      </article>

      <article class="rh-admin-card">
        <div class="rh-card-heading">
          <p class="rh-eyebrow">Licensing</p>
          <h2>Licence Operations</h2>
        </div>
        <div id="licenceMetrics" class="rh-metric-grid"></div>
      </article>

      <article class="rh-admin-card">
        <div class="rh-card-heading">
          <p class="rh-eyebrow">Downloads</p>
          <h2>Download Link Operations</h2>
        </div>
        <div id="downloadMetrics" class="rh-metric-grid"></div>
      </article>

      <article class="rh-admin-card">
        <div class="rh-card-heading">
          <p class="rh-eyebrow">Evidence</p>
          <h2>Evidence Integrity</h2>
        </div>
        <div id="integrityMetrics" class="rh-metric-grid"></div>
      </article>
    </section>

    <section
      class="rh-admin-grid rh-admin-tables-grid"
      aria-label="Recent CDAS operational records"
    >
      <article class="rh-admin-card rh-operations-wide-card">
        <div class="rh-card-heading">
          <p class="rh-eyebrow">Email</p>
          <h2>Recent Failed Emails</h2>
        </div>
        <div id="failedEmails"></div>
      </article>

      <article class="rh-admin-card rh-operations-wide-card rh-review-queue-card">
        <div class="rh-card-heading">
          <p class="rh-eyebrow">Requests</p>
          <h2>Manual Review Queue</h2>
          <p>
            Safe review controls only. These actions do not issue licences,
            generate PDFs, or create download links.
          </p>
        </div>
        <div id="reviewActionResult" class="rh-review-action-result" aria-live="polite"></div>
        <div id="pendingRequests"></div>
      </article>

      <article class="rh-admin-card">
        <div class="rh-card-heading">
          <p class="rh-eyebrow">Licences</p>
          <h2>Recent Licences</h2>
        </div>
        <div id="recentLicences"></div>
      </article>

      <article class="rh-admin-card">
        <div class="rh-card-heading">
          <p class="rh-eyebrow">Downloads</p>
          <h2>Recent Downloads</h2>
        </div>
        <div id="recentDownloads"></div>
      </article>
    </section>

    <section class="rh-admin-card">
      <details>
        <summary>Raw operations payload</summary>
        <pre id="rawPayload"></pre>
      </details>
    </section>
  </main>

  <style>
    .rh-admin-page {
      width: min(1180px, calc(100% - 2rem));
      margin: 0 auto;
      padding: 3rem 0 5rem;
    }

    .rh-admin-hero {
      margin-bottom: 1.5rem;
      padding: 2rem;
      border: 1px solid rgba(15, 23, 42, 0.12);
      border-radius: 1.5rem;
      background:
        radial-gradient(circle at top left, rgba(59, 130, 246, 0.12), transparent 36rem),
        linear-gradient(135deg, rgba(255, 255, 255, 0.96), rgba(248, 250, 252, 0.96));
      box-shadow: 0 24px 70px rgba(15, 23, 42, 0.08);
    }

    .rh-admin-hero h1 {
      margin: 0.35rem 0 0.75rem;
      color: #0f172a;
      font-size: clamp(2rem, 5vw, 3.5rem);
      line-height: 1;
      letter-spacing: -0.05em;
    }

    .rh-admin-hero p {
      max-width: 820px;
      margin: 0;
      color: rgba(15, 23, 42, 0.74);
      font-size: 1.05rem;
      line-height: 1.7;
    }

    .rh-eyebrow {
      margin: 0;
      color: #2563eb;
      font-size: 0.78rem;
      font-weight: 800;
      letter-spacing: 0.14em;
      text-transform: uppercase;
    }

    .rh-admin-card,
    .rh-admin-status-card {
      border: 1px solid rgba(15, 23, 42, 0.12);
      border-radius: 1.25rem;
      background: rgba(255, 255, 255, 0.96);
      box-shadow: 0 18px 50px rgba(15, 23, 42, 0.07);
    }

    .rh-admin-card {
      padding: 1.25rem;
      margin-bottom: 1rem;
    }

    .rh-admin-status-card {
      padding: 1.5rem;
      margin: 1rem 0;
    }

    .rh-admin-status-card h2,
    .rh-admin-card h2 {
      margin: 0.25rem 0 0;
      color: #0f172a;
      font-size: 1.25rem;
      letter-spacing: -0.03em;
    }

    .rh-admin-status-card h3 {
      margin: 1rem 0 0;
      color: #0f172a;
      font-size: 1rem;
      letter-spacing: -0.02em;
    }

    .rh-admin-status-card p:not(.rh-eyebrow),
    .rh-admin-card p:not(.rh-eyebrow) {
      margin: 0.45rem 0 0;
      color: rgba(15, 23, 42, 0.67);
      line-height: 1.6;
    }

    .rh-admin-status-card[data-status="healthy"] {
      border-color: rgba(22, 163, 74, 0.32);
      background:
        radial-gradient(circle at top left, rgba(22, 163, 74, 0.1), transparent 32rem),
        rgba(255, 255, 255, 0.96);
    }

    .rh-admin-status-card[data-status="notice"],
    .rh-admin-status-card[data-status="attention"] {
      border-color: rgba(217, 119, 6, 0.32);
      background:
        radial-gradient(circle at top left, rgba(245, 158, 11, 0.13), transparent 32rem),
        rgba(255, 255, 255, 0.96);
    }

    .rh-admin-status-card[data-status="warning"],
    .rh-admin-status-card[data-status="fault"] {
      border-color: rgba(220, 38, 38, 0.34);
      background:
        radial-gradient(circle at top left, rgba(239, 68, 68, 0.11), transparent 32rem),
        rgba(255, 255, 255, 0.96);
    }

    .rh-admin-token-card {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 1rem;
    }

    .rh-admin-token-actions {
      display: flex;
      gap: 0.5rem;
      flex-wrap: wrap;
      justify-content: flex-end;
    }

    .rh-button {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 2.75rem;
      border: 1px solid transparent;
      border-radius: 999px;
      padding: 0.65rem 1rem;
      font: inherit;
      font-weight: 800;
      cursor: pointer;
      transition:
        transform 150ms ease,
        background 150ms ease,
        border-color 150ms ease,
        color 150ms ease;
      white-space: nowrap;
    }

    .rh-button:hover {
      transform: translateY(-1px);
    }

    .rh-button-primary {
      background: #2563eb;
      color: #fff;
      border-color: rgba(37, 99, 235, 0.95);
    }

    .rh-button-primary:hover {
      background: #1d4ed8;
      border-color: #1d4ed8;
    }

    .rh-admin-linkbar {
      display: flex;
      flex-wrap: wrap;
      gap: 0.65rem;
      margin: 1rem 0;
    }

    .rh-admin-linkbar a {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 2.5rem;
      border: 1px solid rgba(15, 23, 42, 0.13);
      border-radius: 999px;
      padding: 0.55rem 0.85rem;
      background: rgba(255, 255, 255, 0.96);
      color: #0f172a;
      text-decoration: none;
      font-weight: 800;
      font-size: 0.92rem;
      box-shadow: 0 10px 26px rgba(15, 23, 42, 0.045);
      transition:
        transform 150ms ease,
        border-color 150ms ease,
        background 150ms ease;
    }

    .rh-admin-linkbar a:hover {
      transform: translateY(-1px);
      border-color: rgba(37, 99, 235, 0.35);
      background: #f8fafc;
    }

    .rh-admin-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 1rem;
    }

    .rh-admin-metrics-grid,
    .rh-admin-tables-grid {
      margin-top: 1rem;
    }

    .rh-operations-wide-card {
      grid-column: 1 / -1;
    }

    .rh-request-action-row {
      padding: 0.85rem 0.7rem 1rem;
      background: #f8fafc;
    }

    .rh-request-action-row-inner {
      display: flex;
      flex-wrap: wrap;
      gap: 0.45rem;
      align-items: center;
    }

    .rh-request-action-label {
      margin-right: 0.25rem;
      color: rgba(15, 23, 42, 0.62);
      font-size: 0.78rem;
      font-weight: 900;
      letter-spacing: 0.06em;
      text-transform: uppercase;
    }

    .rh-table-pager {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      align-items: center;
      justify-content: space-between;
      padding: 0.75rem;
      border-top: 1px solid rgba(15, 23, 42, 0.08);
      background: #f8fafc;
      color: rgba(15, 23, 42, 0.68);
      font-size: 0.84rem;
      font-weight: 700;
    }

    .rh-table-id {
      font-family:
        ui-monospace,
        SFMono-Regular,
        Menlo,
        Monaco,
        Consolas,
        "Liberation Mono",
        "Courier New",
        monospace;
      font-size: 0.8rem;
      white-space: normal;
      overflow-wrap: anywhere;
    }

    .rh-card-heading {
      margin-bottom: 1rem;
    }

    .rh-metric-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 0.75rem;
    }

    .rh-metric {
      border: 1px solid rgba(15, 23, 42, 0.08);
      border-radius: 1rem;
      padding: 0.9rem;
      background: #f8fafc;
    }

    .rh-metric strong {
      display: block;
      color: #0f172a;
      font-size: 1.55rem;
      line-height: 1.05;
      letter-spacing: -0.04em;
    }

    .rh-metric span {
      display: block;
      margin-top: 0.35rem;
      color: rgba(15, 23, 42, 0.64);
      font-size: 0.88rem;
      font-weight: 700;
    }

    .rh-pill-list {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      margin-top: 0.9rem;
    }

    .rh-pill {
      display: inline-flex;
      align-items: center;
      border-radius: 999px;
      padding: 0.38rem 0.65rem;
      background: #f1f5f9;
      color: #0f172a;
      font-size: 0.85rem;
      font-weight: 800;
    }

    .rh-pill-warning {
      background: #fee2e2;
      color: #991b1b;
    }

    .rh-pill-notice {
      background: #fef3c7;
      color: #92400e;
    }

    .rh-table-wrap {
      overflow-x: auto;
      border: 1px solid rgba(15, 23, 42, 0.08);
      border-radius: 1rem;
      background: #fff;
    }

    .rh-table {
      width: 100%;
      border-collapse: collapse;
      font-size: 0.9rem;
    }

    .rh-table th,
    .rh-table td {
      padding: 0.7rem;
      border-bottom: 1px solid rgba(15, 23, 42, 0.08);
      color: #0f172a;
      text-align: left;
      vertical-align: top;
      white-space: nowrap;
    }

    .rh-table th {
      background: #f8fafc;
      color: rgba(15, 23, 42, 0.72);
      font-size: 0.78rem;
      font-weight: 900;
      letter-spacing: 0.06em;
      text-transform: uppercase;
    }

    .rh-table tr:last-child td {
      border-bottom: 0;
    }

    .rh-table td.rh-wrap {
      min-width: 220px;
      white-space: normal;
    }

    .rh-row-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 0.45rem;
      min-width: 150px;
    }

    .rh-table-action {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      border: 1px solid rgba(37, 99, 235, 0.22);
      border-radius: 999px;
      padding: 0.35rem 0.55rem;
      background: #eff6ff;
      color: #1d4ed8;
      font-size: 0.78rem;
      font-weight: 900;
      line-height: 1;
      text-decoration: none;
      white-space: nowrap;
    }

    .rh-table-action:hover {
      border-color: rgba(37, 99, 235, 0.42);
      background: #dbeafe;
    }

    .rh-review-action-result {
      margin: 1rem 0;
      padding: 0.85rem 1rem;
      border: 1px solid rgba(15, 23, 42, 0.12);
      border-radius: 0.9rem;
      background: rgba(248, 250, 252, 0.9);
      color: rgba(15, 23, 42, 0.72);
      font-size: 0.92rem;
    }

    .rh-review-action-result:empty {
      display: none;
    }

    .rh-review-action-result[data-kind="success"] {
      border-color: rgba(22, 163, 74, 0.28);
      background: rgba(240, 253, 244, 0.92);
      color: #166534;
    }

    .rh-review-action-result[data-kind="error"] {
      border-color: rgba(220, 38, 38, 0.28);
      background: rgba(254, 242, 242, 0.92);
      color: #991b1b;
    }

    .rh-review-action-result[data-kind="loading"],
    .rh-review-action-result[data-kind="info"] {
      border-color: rgba(37, 99, 235, 0.24);
      background: rgba(239, 246, 255, 0.92);
      color: #1d4ed8;
    }

    .rh-review-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 0.35rem;
      min-width: 15rem;
    }

    .rh-review-queue-card {
      grid-column: 1 / -1;
    }

    .rh-table-pager {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      align-items: center;
      justify-content: space-between;
      padding: 0.75rem;
      border-top: 1px solid rgba(15, 23, 42, 0.08);
      background: #f8fafc;
      color: rgba(15, 23, 42, 0.68);
      font-size: 0.84rem;
      font-weight: 700;
    }

    .rh-table-pager .rh-review-actions {
      min-width: auto;
    }

    .rh-mini-button {
      appearance: none;
      border: 1px solid rgba(15, 23, 42, 0.16);
      border-radius: 999px;
      background: #ffffff;
      color: #0f172a;
      cursor: pointer;
      font-size: 0.76rem;
      font-weight: 800;
      line-height: 1;
      padding: 0.45rem 0.65rem;
    }

    .rh-mini-button:hover:not(:disabled) {
      border-color: rgba(37, 99, 235, 0.44);
      color: #1d4ed8;
    }

    .rh-mini-button:disabled {
      cursor: not-allowed;
      opacity: 0.45;
    }

    .rh-mini-button-success {
      border-color: rgba(22, 163, 74, 0.28);
      background: rgba(240, 253, 244, 0.92);
      color: #166534;
    }

    .rh-mini-button-primary {
      border-color: rgba(37, 99, 235, 0.28);
      background: rgba(37, 99, 235, 0.08);
      color: #1d4ed8;
    }

    .rh-mini-button-danger {
      border-color: rgba(220, 38, 38, 0.28);
      background: rgba(254, 242, 242, 0.92);
      color: #991b1b;
    }

    .rh-muted {
      margin: 0;
      color: rgba(15, 23, 42, 0.62);
      line-height: 1.6;
    }

    details summary {
      color: #0f172a;
      cursor: pointer;
      font-weight: 900;
    }

    pre {
      overflow: auto;
      max-height: 520px;
      margin: 1rem 0 0;
      padding: 1rem;
      border: 1px solid rgba(15, 23, 42, 0.1);
      border-radius: 1rem;
      background: #0f172a;
      color: #e2e8f0;
      font-size: 0.85rem;
      line-height: 1.5;
    }

    @media (max-width: 900px) {
      .rh-admin-grid,
      .rh-metric-grid {
        grid-template-columns: 1fr;
      }

      .rh-admin-token-card {
        display: grid;
      }

      .rh-admin-token-actions {
        justify-content: stretch;
      }

      .rh-admin-token-actions .rh-button {
        width: 100%;
      }
    }

    @media (max-width: 640px) {
      .rh-admin-page {
        width: min(100% - 1rem, 1180px);
        padding-top: 1rem;
      }

      .rh-admin-hero,
      .rh-admin-card,
      .rh-admin-status-card {
        padding: 1rem;
        border-radius: 1rem;
      }

      .rh-admin-linkbar a {
        width: 100%;
      }
    }
  </style>

  <script is:inline>
    // @ts-nocheck

    const TOKEN_STORAGE_KEY = "relayhub_admin_token";
    const API_URL = "/api/admin/cdas/operations";
    const TABLE_PAGE_SIZE = 8;
    const tablePages = new Map();

    const statusPanel = document.getElementById("statusPanel");
    const refreshBtn = document.getElementById("refreshBtn");
    const rawPayload = document.getElementById("rawPayload");
    const tokenStatus = document.getElementById("token-status");

    function getAdminToken() {
      return sessionStorage.getItem(TOKEN_STORAGE_KEY) || "";
    }

    function escapeHtml(value) {
      return String(value ?? "")
        .replaceAll("&", "&amp;")
        .replaceAll("<", "&lt;")
        .replaceAll(">", "&gt;")
        .replaceAll('"', "&quot;")
        .replaceAll("'", "&#039;");
    }

    function niceLabel(key) {
      return String(key || "")
        .replaceAll("_", " ")
        .replace(/\b\w/g, (c) => c.toUpperCase());
    }

    function updateTokenStatus(message) {
      if (!tokenStatus) return;

      const token = getAdminToken();

      if (message) {
        tokenStatus.textContent = message;
        return;
      }

      tokenStatus.textContent = token
        ? "Admin token is loaded in this browser session. Operations data can be fetched from the protected Worker endpoint."
        : "No admin token is loaded in this browser session. Paste and save the admin token above.";
    }

    function setStatusPanel(status, eyebrow, heading, body) {
      if (!statusPanel) return;

      statusPanel.dataset.status = status || "unknown";
      statusPanel.innerHTML = `
        <p class="rh-eyebrow">${escapeHtml(eyebrow)}</p>
        <h2>${escapeHtml(heading)}</h2>
        <p>${escapeHtml(body)}</p>
      `;
    }

    function metricGrid(targetId, data) {
      const target = document.getElementById(targetId);
      if (!target) return;

      target.innerHTML = Object.entries(data || {})
        .map(([key, value]) => {
          return `
            <div class="rh-metric">
              <strong>${escapeHtml(value ?? 0)}</strong>
              <span>${escapeHtml(niceLabel(key))}</span>
            </div>
          `;
        })
        .join("");
    }

    function emptyMessage(message) {
      return `<p class="rh-muted">${escapeHtml(message)}</p>`;
    }

    function adminUrl(path, params = {}) {
      const query = Object.entries(params)
        .filter(([, value]) => value !== undefined && value !== null && value !== "")
        .map(
          ([key, value]) =>
            `${encodeURIComponent(key)}=${encodeURIComponent(String(value))}`,
        )
        .join("&");

      return query ? `${path}?${query}` : path;
    }

    function adminActionLinks(links) {
      const safeLinks = Array.isArray(links) ? links : [];

      if (!safeLinks.length) {
        return "";
      }

      return `
        <div class="rh-row-actions">
          ${safeLinks
            .filter((link) => link && link.href && link.label)
            .map(
              (link) =>
                `<a class="rh-table-action" href="${escapeHtml(link.href)}">${escapeHtml(
                  link.label,
                )}</a>`,
            )
            .join("")}
        </div>
      `;
    }

    function reviewActionButtons(row) {
      const id = escapeHtml(row.id || "");
      const status = String(row.status || "");

      const requestLink = `<a class="rh-table-action" href="${escapeHtml(
        adminUrl("/admin/cdas-access-requests/", { id: row.id }),
      )}">Open Request</a>`;

      const noteButton = `<button class="rh-mini-button" type="button" data-review-action="note" data-request-id="${id}">Note</button>`;
      const holdButton = `<button class="rh-mini-button" type="button" data-review-action="hold" data-request-id="${id}">Hold</button>`;
      const rejectButton = `<button class="rh-mini-button rh-mini-button-danger" type="button" data-review-action="reject" data-request-id="${id}">Reject</button>`;
      const approveButton = `<button class="rh-mini-button rh-mini-button-primary" type="button" data-review-action="approve_review" data-request-id="${id}">Approve Review</button>`;

      const eligibilityButton = `<button class="rh-mini-button" type="button" data-licence-action="eligibility" data-request-id="${id}">Check Eligibility</button>`;
      const issueLicenceButton = `<button class="rh-mini-button rh-mini-button-success" type="button" data-licence-action="issue" data-request-id="${id}">Issue Licence</button>`;

      const reviewButtons =
        status === "rejected" || status === "review_approved" || status === "licence_issued"
          ? noteButton
          : `${noteButton}${holdButton}${rejectButton}${approveButton}`;

      const licenceButtons =
        status === "review_approved"
          ? `${eligibilityButton}${issueLicenceButton}`
          : eligibilityButton;

      return `
        <div class="rh-request-action-row-inner">
          <span class="rh-request-action-label">Review actions</span>
          ${requestLink}
          ${reviewButtons}
          <span class="rh-request-action-label">Licence handoff</span>
          ${licenceButtons}
        </div>
      `;
    }

    function setReviewActionResult(kind, message) {
      const target = document.getElementById("reviewActionResult");
      if (!target) return;

      target.dataset.kind = kind || "info";
      target.textContent = message || "";
    }

    async function submitReviewAction(requestId, action) {
      const token = getAdminToken();

      if (!token) {
        setReviewActionResult("error", "Admin token is required before review actions can be submitted.");
        return;
      }

      const defaultNote =
        action === "note"
          ? "Admin review note."
          : action === "hold"
            ? "Placed on hold from Operations Centre."
            : action === "reject"
              ? "Rejected from Operations Centre."
              : "Approved for the next manual review step.";

      const note = window.prompt(`Enter note/reason for ${niceLabel(action)}:`, defaultNote);

      if (note === null) {
        setReviewActionResult("info", "Review action cancelled.");
        return;
      }

      setReviewActionResult("loading", `Submitting ${niceLabel(action)} for ${requestId}…`);

      try {
        const response = await fetch(
          `/api/admin/cdas/access-requests/${encodeURIComponent(requestId)}/review`,
          {
            method: "POST",
            headers: {
              accept: "application/json",
              authorization: `Bearer ${token}`,
              "content-type": "application/json",
            },
            body: JSON.stringify({
              action,
              actor: "operations-centre",
              reason: note,
              note,
            }),
          },
        );

        const data = await response.json();

        if (!response.ok || !data.ok) {
          throw new Error(data.message || data.error || `Review action failed with ${response.status}`);
        }

        setReviewActionResult(
          "success",
          `${niceLabel(action)} recorded for ${requestId}. Status: ${data.previous_status} → ${data.new_status}.`,
        );

        await loadOperations();
      } catch (error) {
        setReviewActionResult("error", error?.message || "Review action failed.");
      }
    }



    async function checkLicenceEligibility(requestId) {
      const token = getAdminToken();

      if (!token) {
        setReviewActionResult("error", "Admin token is required before licence eligibility can be checked.");
        return;
      }

      setReviewActionResult("loading", `Checking licence eligibility for ${requestId}…`);

      try {
        const response = await fetch(
          `/api/admin/cdas/access-requests/${encodeURIComponent(requestId)}/licence-eligibility`,
          {
            method: "GET",
            headers: {
              accept: "application/json",
              authorization: `Bearer ${token}`,
            },
          },
        );

        const data = await response.json();

        if (!response.ok || !data.ok) {
          throw new Error(data.message || data.error || `Eligibility check failed with ${response.status}`);
        }

        if (data.eligible) {
          setReviewActionResult(
            "success",
            `${requestId} is eligible for licence issue. Existing licences: ${data.counts?.existing_licences_for_request ?? 0}.`,
          );
        } else {
          setReviewActionResult(
            "info",
            `${requestId} is not eligible. Blockers: ${(data.blockers || []).join(", ") || "none reported"}.`,
          );
        }
      } catch (error) {
        setReviewActionResult("error", error?.message || "Licence eligibility check failed.");
      }
    }

    async function issueReviewedLicence(requestId) {
      const token = getAdminToken();

      if (!token) {
        setReviewActionResult("error", "Admin token is required before a licence can be issued.");
        return;
      }

      const note = window.prompt(
        "Enter licence issue note:",
        "Issue licence only. Do not generate PDF, create download link, or send email.",
      );

      if (note === null) {
        setReviewActionResult("info", "Licence issue cancelled.");
        return;
      }

      setReviewActionResult("loading", `Issuing licence for ${requestId}…`);

      try {
        const response = await fetch(
          `/api/admin/cdas/access-requests/${encodeURIComponent(requestId)}/issue-licence`,
          {
            method: "POST",
            headers: {
              accept: "application/json",
              authorization: `Bearer ${token}`,
              "content-type": "application/json",
            },
            body: JSON.stringify({
              actor: "operations-centre",
              note,
            }),
          },
        );

        const data = await response.json();

        if (!response.ok || !data.ok) {
          const blockers = Array.isArray(data.blockers) && data.blockers.length
            ? ` Blockers: ${data.blockers.join(", ")}.`
            : "";

          throw new Error(
            `${data.message || data.error || `Licence issue failed with ${response.status}`}.${blockers}`,
          );
        }

        setReviewActionResult(
          "success",
          `Licence issued for ${requestId}: ${data.licence_number}. No PDF, download link, or email was created.`,
        );

        await loadOperations();
      } catch (error) {
        setReviewActionResult("error", error?.message || "Licence issue failed.");
      }
    }

    function table(targetId, rows, columns, emptyText, options = {}) {
      const target = document.getElementById(targetId);
      if (!target) return;

      if (!Array.isArray(rows) || rows.length === 0) {
        tablePages.delete(targetId);
        target.innerHTML = emptyMessage(emptyText);
        return;
      }

      const pageSize = Number(options.pageSize || TABLE_PAGE_SIZE);
      const totalPages = Math.max(1, Math.ceil(rows.length / pageSize));
      const currentPage = Math.min(
        Math.max(1, Number(tablePages.get(targetId) || 1)),
        totalPages,
      );

      tablePages.set(targetId, currentPage);

      const startIndex = (currentPage - 1) * pageSize;
      const visibleRows = rows.slice(startIndex, startIndex + pageSize);

      target.innerHTML = `
        <div class="rh-table-wrap">
          <table class="rh-table">
            <thead>
              <tr>
                ${columns
                  .map((column) => `<th>${escapeHtml(column.label)}</th>`)
                  .join("")}
              </tr>
            </thead>
            <tbody>
              ${visibleRows
                .map((row) => {
                  const mainRow = `
                    <tr>
                      ${columns
                        .map((column) => {
                          const wrapClass = column.wrap ? "rh-wrap" : "";

                          if (column.renderHtml) {
                            return `<td class="${wrapClass}">${column.renderHtml(row)}</td>`;
                          }

                          const value = column.render
                            ? column.render(row)
                            : row[column.key];

                          return `<td class="${wrapClass}">${escapeHtml(value ?? "")}</td>`;
                        })
                        .join("")}
                    </tr>
                  `;

                  const expandedRow = options.renderExpandedHtml
                    ? `<tr><td class="rh-request-action-row" colspan="${columns.length}">${options.renderExpandedHtml(row)}</td></tr>`
                    : "";

                  return mainRow + expandedRow;
                })
                .join("")}
            </tbody>
          </table>
          ${
            rows.length > pageSize
              ? `<div class="rh-table-pager">
                  <span>Showing ${startIndex + 1}-${Math.min(
                    startIndex + pageSize,
                    rows.length,
                  )} of ${rows.length}</span>
                  <span class="rh-request-action-row-inner">
                    <button class="rh-mini-button" type="button" data-table-page="prev" data-table-id="${escapeHtml(targetId)}" ${currentPage <= 1 ? "disabled" : ""}>Previous</button>
                    <span>Page ${currentPage} of ${totalPages}</span>
                    <button class="rh-mini-button" type="button" data-table-page="next" data-table-id="${escapeHtml(targetId)}" ${currentPage >= totalPages ? "disabled" : ""}>Next</button>
                  </span>
                </div>`
              : ""
          }
        </div>
      `;
    }

    function renderStatus(data) {
      const warnings = Array.isArray(data.warnings) ? data.warnings : [];
      const notices = Array.isArray(data.notices) ? data.notices : [];
      const status = data.status || "unknown";

      if (!statusPanel) return;

      statusPanel.dataset.status = status;

      statusPanel.innerHTML = `
        <p class="rh-eyebrow">CDAS Operations</p>
        <h2>System status: ${escapeHtml(niceLabel(status))}</h2>
        <p>
          Generated at: ${escapeHtml(data.generated_at || "unknown")}.
          This page is read-only and intended for daily operational awareness.
        </p>

        ${
          warnings.length
            ? `<h3>Warnings</h3><div class="rh-pill-list">${warnings
                .map(
                  (item) =>
                    `<span class="rh-pill rh-pill-warning">${escapeHtml(
                      niceLabel(item),
                    )}</span>`,
                )
                .join("")}</div>`
            : ""
        }

        ${
          notices.length
            ? `<h3>Notices</h3><div class="rh-pill-list">${notices
                .map(
                  (item) =>
                    `<span class="rh-pill rh-pill-notice">${escapeHtml(
                      niceLabel(item),
                    )}</span>`,
                )
                .join("")}</div>`
            : ""
        }

        ${
          !warnings.length && !notices.length
            ? `<p>No current warnings or notices reported by the operations endpoint.</p>`
            : ""
        }
      `;
    }

    function clearRenderedData() {
      [
        "coreMetrics",
        "emailMetrics",
        "workflowMetrics",
        "licenceMetrics",
        "downloadMetrics",
        "integrityMetrics",
        "failedEmails",
        "pendingRequests",
        "recentLicences",
        "recentDownloads",
      ].forEach((id) => {
        const el = document.getElementById(id);
        if (el) el.innerHTML = "";
      });

      if (rawPayload) {
        rawPayload.textContent = "";
      }
    }

    async function loadOperations() {
      const token = getAdminToken();
      updateTokenStatus();

      if (!token) {
        clearRenderedData();
        setStatusPanel(
          "fault",
          "Admin authentication",
          "Admin token required",
          "Paste and save the admin token above, then refresh operations status.",
        );
        return;
      }

      setStatusPanel(
        "loading",
        "Loading",
        "Loading CDAS operations status…",
        "Fetching the latest operational state from the protected Worker endpoint.",
      );

      try {
        const response = await fetch(API_URL, {
          headers: {
            Accept: "application/json",
            Authorization: `Bearer ${token}`,
          },
        });

        const data = await response.json();

        if (!response.ok || !data.ok) {
          throw new Error(data.error || `Request failed with ${response.status}`);
        }

        renderStatus(data);

        metricGrid("coreMetrics", data.core);
        metricGrid("emailMetrics", data.email);
        metricGrid("workflowMetrics", data.workflow);
        metricGrid("licenceMetrics", data.licences);
        metricGrid("downloadMetrics", data.downloads);
        metricGrid("integrityMetrics", data.integrity);

        table(
          "failedEmails",
          data.recent?.failed_emails,
          [
            { key: "created_at", label: "Created" },
            { key: "recipient_email", label: "Recipient" },
            { key: "email_type", label: "Type" },
            { key: "subject", label: "Subject", wrap: true },
            { key: "status", label: "Status" },
            { key: "retry_count", label: "Retries" },
            {
              key: "resolved",
              label: "Resolved",
              render: (row) => (row.resolved_at ? "Yes" : "No"),
            },
            {
              key: "actions",
              label: "Actions",
              renderHtml: (row) =>
                adminActionLinks([
                  {
                    label: "Email event",
                    href: adminUrl("/admin/cdas-email-events/", {
                      id: row.id,
                    }),
                  },
                  row.related_type === "access_request"
                    ? {
                        label: "Request",
                        href: adminUrl("/admin/cdas-access-requests/", {
                          id: row.related_id,
                        }),
                      }
                    : null,
                ]),
            },
          ],
          "No recent failed emails.",
          { pageSize: 8 },
        );

        table(
          "pendingRequests",
          data.recent?.pending_requests,
          [
            {
              key: "id",
              label: "Request ID",
              wrap: true,
              render: (row) => row.id || "",
            },
            { key: "requested_at", label: "Requested" },
            { key: "document_id", label: "Document", wrap: true },
            { key: "document_version", label: "Version" },
            { key: "email", label: "Email", wrap: true },
            { key: "status", label: "Status", render: (row) => niceLabel(row.status) },
            {
              key: "verified",
              label: "Verified",
              render: (row) => (row.email_verified_at ? "Yes" : "No"),
            },
            {
              key: "risk_score",
              label: "Risk",
              render: (row) => row.risk_score ?? 0,
            },
            {
              key: "latest_review_event",
              label: "Last Review Event",
              render: (row) =>
                row.latest_review_event ? niceLabel(row.latest_review_event) : "",
            },
          ],
          "No access requests currently require review.",
          {
            pageSize: 8,
            renderExpandedHtml: (row) => reviewActionButtons(row),
          },
        );

        table(
          "recentLicences",
          data.recent?.recent_licences,
          [
            { key: "issued_at", label: "Issued" },
            { key: "licence_number", label: "Licence" },
            {
              key: "holder",
              label: "Holder",
              render: (row) =>
                row.organisation_name || row.licence_holder_name || "",
            },
            { key: "document_id", label: "Document" },
            { key: "document_version", label: "Version" },
            { key: "status", label: "Status" },
            {
              key: "actions",
              label: "Actions",
              renderHtml: (row) =>
                adminActionLinks([
                  {
                    label: "Licence",
                    href: adminUrl("/admin/cdas-licences/", {
                      id: row.id,
                      licence_number: row.licence_number,
                    }),
                  },
                  {
                    label: "Document",
                    href: adminUrl("/admin/cdas-documents/", {
                      document_id: row.document_id,
                      version: row.document_version,
                    }),
                  },
                  {
                    label: "Links",
                    href: adminUrl("/admin/cdas-download-links/", {
                      licence_number: row.licence_number,
                    }),
                  },
                ]),
            },
          ],
          "No recent licences.",
        );

        table(
          "recentDownloads",
          data.recent?.recent_downloads,
          [
            { key: "event_at", label: "Downloaded" },
            { key: "download_id", label: "Download ID" },
            { key: "licence_number", label: "Licence" },
            { key: "document_id", label: "Document" },
            { key: "document_version", label: "Version" },
            {
              key: "success",
              label: "Result",
              render: (row) =>
                Number(row.success) === 1
                  ? "Success"
                  : row.failure_reason || "Failed",
            },
            {
              key: "actions",
              label: "Actions",
              renderHtml: (row) =>
                adminActionLinks([
                  {
                    label: "Download links",
                    href: adminUrl("/admin/cdas-download-links/", {
                      id: row.download_id,
                      licence_number: row.licence_number,
                    }),
                  },
                  {
                    label: "Licence",
                    href: adminUrl("/admin/cdas-licences/", {
                      licence_number: row.licence_number,
                    }),
                  },
                  {
                    label: "Analytics",
                    href: adminUrl("/admin/downloads/", {
                      event_id: row.id,
                      download_id: row.download_id,
                    }),
                  },
                ]),
            },
          ],
          "No recent downloads.",
        );

        if (rawPayload) {
          rawPayload.textContent = JSON.stringify(data, null, 2);
        }

        updateTokenStatus("Operations data loaded successfully.");
      } catch (error) {
        clearRenderedData();

        const message = error instanceof Error ? error.message : String(error);

        setStatusPanel(
          "fault",
          "Operations error",
          "Operations status could not be loaded",
          `${message}. Check the Worker route, admin authentication, and D1 schema.`,
        );

        updateTokenStatus("Operations request failed. Check the saved admin token.");
      }
    }

    document.addEventListener("click", (event) => {
      const pageButton = event.target.closest("[data-table-page][data-table-id]");

      if (pageButton) {
        const tableId = pageButton.getAttribute("data-table-id");
        const direction = pageButton.getAttribute("data-table-page");
        const current = Number(tablePages.get(tableId) || 1);

        tablePages.set(
          tableId,
          direction === "next" ? current + 1 : Math.max(1, current - 1),
        );

        loadOperations();
        return;
      }

      const licenceButton = event.target.closest("[data-licence-action][data-request-id]");

      if (licenceButton) {
        const action = licenceButton.getAttribute("data-licence-action");
        const requestId = licenceButton.getAttribute("data-request-id");

        if (action === "eligibility" && requestId) {
          checkLicenceEligibility(requestId);
          return;
        }

        if (action === "issue" && requestId) {
          issueReviewedLicence(requestId);
          return;
        }
      }

      const button = event.target.closest("[data-review-action][data-request-id]");
      if (!button) return;

      const action = button.getAttribute("data-review-action");
      const requestId = button.getAttribute("data-request-id");

      if (!action || !requestId) return;

      submitReviewAction(requestId, action);
    });

    refreshBtn?.addEventListener("click", () => {
      loadOperations();
    });

    window.relayhubAdminTokenUpdated = () => {
      updateTokenStatus(
        "Admin token saved for this browser session. Refreshing operations data…",
      );
      loadOperations();
    };

    window.relayhubAdminTokenCleared = () => {
      clearRenderedData();
      updateTokenStatus();
      setStatusPanel(
        "fault",
        "Admin authentication",
        "Admin token required",
        "Paste and save the admin token above, then refresh operations status.",
      );
    };

    updateTokenStatus();
    loadOperations();
  </script>
</BaseLayout>