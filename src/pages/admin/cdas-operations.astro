---
import BaseLayout from "../../layouts/BaseLayout.astro";
import AdminTokenPanel from "../../components/AdminTokenPanel.astro";

const title = "CDAS Operations Centre | RelayHub";
const description =
  "Operational command centre for the RelayHub Controlled Document Access System.";
---

<BaseLayout title={title} description={description} noindex={true}>
  <main class="rh-admin-page">
    <section class="rh-admin-hero">
      <p class="rh-eyebrow">RelayHub Admin</p>
      <h1>CDAS Operations Centre</h1>
      <p>
        Single-pane operational view for document access, email delivery,
        licence issue, download links, workflow backlog, and evidence integrity.
        This page includes guarded workflow controls for the proven CDAS
        lifecycle. Each state transition remains explicit and validation-gated.
      </p>
    </section>

    <AdminTokenPanel />

    <section class="rh-admin-card rh-admin-token-card">
      <div>
        <h2>Operations status</h2>
        <p id="token-status">Checking browser session…</p>
      </div>

      <div class="rh-admin-token-actions">
        <button class="rh-button rh-button-primary" id="refreshBtn" type="button">
          Refresh operations status
        </button>
      </div>
    </section>

    <nav class="rh-admin-linkbar" aria-label="CDAS admin links">
      <a href="/admin/">Admin hub</a>
      <a href="/admin/cdas-health/">Full health dashboard</a>
      <a href="/admin/cdas-email-events/">Email events</a>
      <a href="/admin/cdas-access-requests/">Access requests</a>
      <a href="/admin/cdas-licences/">Licences</a>
      <a href="/admin/cdas-download-links/">Download links</a>
      <a href="/admin/cdas-documents/">Documents</a>
      <a href="/admin/downloads/">Download analytics</a>
    </nav>

    <section id="statusPanel" class="rh-admin-status-card" data-status="loading">
      <p class="rh-eyebrow">Loading</p>
      <h2>Loading CDAS operations status…</h2>
      <p>Fetching the latest operational state.</p>
    </section>

    <section
      class="rh-admin-grid rh-admin-metrics-grid"
      aria-label="CDAS operational metrics"
    >
      <article class="rh-admin-card">
        <div class="rh-card-heading">
          <p class="rh-eyebrow">System</p>
          <h2>Core Metrics</h2>
        </div>
        <div id="coreMetrics" class="rh-metric-grid"></div>
      </article>

      <article class="rh-admin-card">
        <div class="rh-card-heading">
          <p class="rh-eyebrow">Delivery</p>
          <h2>Email Operations</h2>
        </div>
        <div id="emailMetrics" class="rh-metric-grid"></div>
      </article>

      <article class="rh-admin-card">
        <div class="rh-card-heading">
          <p class="rh-eyebrow">Workflow</p>
          <h2>Workflow Backlog</h2>
        </div>
        <div id="workflowMetrics" class="rh-metric-grid"></div>
      </article>

      <article class="rh-admin-card">
        <div class="rh-card-heading">
          <p class="rh-eyebrow">Licensing</p>
          <h2>Licence Operations</h2>
        </div>
        <div id="licenceMetrics" class="rh-metric-grid"></div>
      </article>

      <article class="rh-admin-card">
        <div class="rh-card-heading">
          <p class="rh-eyebrow">Downloads</p>
          <h2>Download Link Operations</h2>
        </div>
        <div id="downloadMetrics" class="rh-metric-grid"></div>
      </article>

      <article class="rh-admin-card">
        <div class="rh-card-heading">
          <p class="rh-eyebrow">Evidence</p>
          <h2>Evidence Integrity</h2>
        </div>
        <div id="integrityMetrics" class="rh-metric-grid"></div>
      </article>
    </section>

    <section
      class="rh-admin-grid rh-admin-tables-grid"
      aria-label="Recent CDAS operational records"
    >
      <article class="rh-admin-card rh-operations-wide-card">
        <div class="rh-card-heading">
          <p class="rh-eyebrow">Email</p>
          <h2>Recent Failed Emails</h2>
        </div>
        <div id="failedEmails"></div>
      </article>

      <article class="rh-admin-card rh-operations-wide-card rh-review-queue-card">
        <div class="rh-card-heading">
          <p class="rh-eyebrow">Requests</p>
          <h2>Manual Review Queue</h2>
          <p>
            Safe review controls only. These actions do not issue licences,
            generate PDFs, or create download links.
          </p>
        </div>
        <div id="reviewActionResult" class="rh-review-action-result" aria-live="polite"></div>
        <div id="pendingRequests"></div>
      </article>

      <article class="rh-admin-card rh-operations-wide-card">
        <div class="rh-card-heading">
          <p class="rh-eyebrow">Licences</p>
          <h2>Recent Licences</h2>
          <p class="rh-muted">
            Lifecycle evidence for licence issue, PDF generation, controlled link
            creation, activation, delivery email, download, and replay denial.
          </p>
        </div>
        <div id="recentLicences"></div>
      </article>

      <article class="rh-admin-card rh-operations-wide-card">
        <div class="rh-card-heading">
          <p class="rh-eyebrow">Downloads</p>
          <h2>Recent Downloads</h2>
          <p class="rh-muted">
            Recent audit events from the controlled download lifecycle.
          </p>
        </div>
        <div id="recentDownloads"></div>
      </article>
    </section>

    <section class="rh-admin-card">
      <details>
        <summary>Raw operations payload</summary>
        <pre id="rawPayload"></pre>
      </details>
    </section>
  </main>

  <style>
    .rh-admin-page {
      width: min(1180px, calc(100% - 2rem));
      margin: 0 auto;
      padding: 3rem 0 5rem;
    }

    .rh-admin-hero {
      margin-bottom: 1.5rem;
      padding: 2rem;
      border: 1px solid rgba(15, 23, 42, 0.12);
      border-radius: 1.5rem;
      background:
        radial-gradient(circle at top left, rgba(59, 130, 246, 0.12), transparent 36rem),
        linear-gradient(135deg, rgba(255, 255, 255, 0.96), rgba(248, 250, 252, 0.96));
      box-shadow: 0 24px 70px rgba(15, 23, 42, 0.08);
    }

    .rh-admin-hero h1 {
      margin: 0.35rem 0 0.75rem;
      color: #0f172a;
      font-size: clamp(2rem, 5vw, 3.5rem);
      line-height: 1;
      letter-spacing: -0.05em;
    }

    .rh-admin-hero p {
      max-width: 820px;
      margin: 0;
      color: rgba(15, 23, 42, 0.74);
      font-size: 1.05rem;
      line-height: 1.7;
    }

    .rh-eyebrow {
      margin: 0;
      color: #2563eb;
      font-size: 0.78rem;
      font-weight: 800;
      letter-spacing: 0.14em;
      text-transform: uppercase;
    }

    .rh-admin-card,
    .rh-admin-status-card {
      border: 1px solid rgba(15, 23, 42, 0.12);
      border-radius: 1.25rem;
      background: rgba(255, 255, 255, 0.96);
      box-shadow: 0 18px 50px rgba(15, 23, 42, 0.07);
    }

    .rh-admin-card {
      padding: 1.25rem;
      margin-bottom: 1rem;
    }

    .rh-admin-status-card {
      padding: 1.5rem;
      margin: 1rem 0;
    }

    .rh-admin-status-card h2,
    .rh-admin-card h2 {
      margin: 0.25rem 0 0;
      color: #0f172a;
      font-size: 1.25rem;
      letter-spacing: -0.03em;
    }

    .rh-admin-status-card h3 {
      margin: 1rem 0 0;
      color: #0f172a;
      font-size: 1rem;
      letter-spacing: -0.02em;
    }

    .rh-admin-status-card p:not(.rh-eyebrow),
    .rh-admin-card p:not(.rh-eyebrow) {
      margin: 0.45rem 0 0;
      color: rgba(15, 23, 42, 0.67);
      line-height: 1.6;
    }

    .rh-admin-status-card[data-status="healthy"] {
      border-color: rgba(22, 163, 74, 0.32);
      background:
        radial-gradient(circle at top left, rgba(22, 163, 74, 0.1), transparent 32rem),
        rgba(255, 255, 255, 0.96);
    }

    .rh-admin-status-card[data-status="notice"],
    .rh-admin-status-card[data-status="attention"] {
      border-color: rgba(217, 119, 6, 0.32);
      background:
        radial-gradient(circle at top left, rgba(245, 158, 11, 0.13), transparent 32rem),
        rgba(255, 255, 255, 0.96);
    }

    .rh-admin-status-card[data-status="warning"],
    .rh-admin-status-card[data-status="fault"] {
      border-color: rgba(220, 38, 38, 0.34);
      background:
        radial-gradient(circle at top left, rgba(239, 68, 68, 0.11), transparent 32rem),
        rgba(255, 255, 255, 0.96);
    }

    .rh-admin-token-card {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 1rem;
    }

    .rh-admin-token-actions {
      display: flex;
      gap: 0.5rem;
      flex-wrap: wrap;
      justify-content: flex-end;
    }

    .rh-button {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 2.75rem;
      border: 1px solid transparent;
      border-radius: 999px;
      padding: 0.65rem 1rem;
      font: inherit;
      font-weight: 800;
      cursor: pointer;
      transition:
        transform 150ms ease,
        background 150ms ease,
        border-color 150ms ease,
        color 150ms ease;
      white-space: nowrap;
    }

    .rh-button:hover {
      transform: translateY(-1px);
    }

    .rh-button-primary {
      background: #2563eb;
      color: #fff;
      border-color: rgba(37, 99, 235, 0.95);
    }

    .rh-button-primary:hover {
      background: #1d4ed8;
      border-color: #1d4ed8;
    }

    .rh-admin-linkbar {
      display: flex;
      flex-wrap: wrap;
      gap: 0.65rem;
      margin: 1rem 0;
    }

    .rh-admin-linkbar a {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 2.5rem;
      border: 1px solid rgba(15, 23, 42, 0.13);
      border-radius: 999px;
      padding: 0.55rem 0.85rem;
      background: rgba(255, 255, 255, 0.96);
      color: #0f172a;
      text-decoration: none;
      font-weight: 800;
      font-size: 0.92rem;
      box-shadow: 0 10px 26px rgba(15, 23, 42, 0.045);
      transition:
        transform 150ms ease,
        border-color 150ms ease,
        background 150ms ease;
    }

    .rh-admin-linkbar a:hover {
      transform: translateY(-1px);
      border-color: rgba(37, 99, 235, 0.35);
      background: #f8fafc;
    }

    .rh-admin-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 1rem;
    }

    .rh-admin-metrics-grid,
    .rh-admin-tables-grid {
      margin-top: 1rem;
    }

    .rh-operations-wide-card {
      grid-column: 1 / -1;
    }

    .rh-request-action-row {
      padding: 0.85rem 0.7rem 1rem;
      background: #f8fafc;
    }

    .rh-request-action-row-inner {
      display: flex;
      flex-wrap: wrap;
      gap: 0.45rem;
      align-items: center;
    }

    .rh-request-action-label {
      margin-right: 0.25rem;
      color: rgba(15, 23, 42, 0.62);
      font-size: 0.78rem;
      font-weight: 900;
      letter-spacing: 0.06em;
      text-transform: uppercase;
    }

    .rh-table-pager {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      align-items: center;
      justify-content: space-between;
      padding: 0.75rem;
      border-top: 1px solid rgba(15, 23, 42, 0.08);
      background: #f8fafc;
      color: rgba(15, 23, 42, 0.68);
      font-size: 0.84rem;
      font-weight: 700;
    }

    .rh-table-id {
      font-family:
        ui-monospace,
        SFMono-Regular,
        Menlo,
        Monaco,
        Consolas,
        "Liberation Mono",
        "Courier New",
        monospace;
      font-size: 0.8rem;
      white-space: normal;
      overflow-wrap: anywhere;
    }

    .rh-card-heading {
      margin-bottom: 1rem;
    }

    .rh-metric-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 0.75rem;
    }

    .rh-metric {
      border: 1px solid rgba(15, 23, 42, 0.08);
      border-radius: 1rem;
      padding: 0.9rem;
      background: #f8fafc;
    }

    .rh-metric strong {
      display: block;
      color: #0f172a;
      font-size: 1.55rem;
      line-height: 1.05;
      letter-spacing: -0.04em;
    }

    .rh-metric span {
      display: block;
      margin-top: 0.35rem;
      color: rgba(15, 23, 42, 0.64);
      font-size: 0.88rem;
      font-weight: 700;
    }

    .rh-pill-list {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      margin-top: 0.9rem;
    }

    .rh-pill {
      display: inline-flex;
      align-items: center;
      border-radius: 999px;
      padding: 0.38rem 0.65rem;
      background: #f1f5f9;
      color: #0f172a;
      font-size: 0.85rem;
      font-weight: 800;
    }

    .rh-pill-warning {
      background: #fee2e2;
      color: #991b1b;
    }

    .rh-pill-notice {
      background: #fef3c7;
      color: #92400e;
    }

    .rh-table-wrap {
      overflow-x: auto;
      border: 1px solid rgba(15, 23, 42, 0.08);
      border-radius: 1rem;
      background: #fff;
    }

    .rh-table {
      width: 100%;
      border-collapse: collapse;
      font-size: 0.9rem;
    }

    .rh-table th,
    .rh-table td {
      padding: 0.7rem;
      border-bottom: 1px solid rgba(15, 23, 42, 0.08);
      color: #0f172a;
      text-align: left;
      vertical-align: top;
      white-space: nowrap;
    }

    .rh-table th {
      background: #f8fafc;
      color: rgba(15, 23, 42, 0.72);
      font-size: 0.78rem;
      font-weight: 900;
      letter-spacing: 0.06em;
      text-transform: uppercase;
    }

    .rh-table tr:last-child td {
      border-bottom: 0;
    }

    .rh-table td.rh-wrap {
      min-width: 220px;
      white-space: normal;
    }

    .rh-row-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 0.45rem;
      min-width: 150px;
    }

    .rh-table-action {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      border: 1px solid rgba(37, 99, 235, 0.22);
      border-radius: 999px;
      padding: 0.35rem 0.55rem;
      background: #eff6ff;
      color: #1d4ed8;
      font-size: 0.78rem;
      font-weight: 900;
      line-height: 1;
      text-decoration: none;
      white-space: nowrap;
    }

    .rh-table-action:hover {
      border-color: rgba(37, 99, 235, 0.42);
      background: #dbeafe;
    }

    .rh-review-action-result {
      margin: 1rem 0;
      padding: 0.85rem 1rem;
      border: 1px solid rgba(15, 23, 42, 0.12);
      border-radius: 0.9rem;
      background: rgba(248, 250, 252, 0.9);
      color: rgba(15, 23, 42, 0.72);
      font-size: 0.92rem;
    }

    .rh-review-action-result:empty {
      display: none;
    }

    .rh-review-action-result[data-kind="success"] {
      border-color: rgba(22, 163, 74, 0.28);
      background: rgba(240, 253, 244, 0.92);
      color: #166534;
    }

    .rh-review-action-result[data-kind="error"] {
      border-color: rgba(220, 38, 38, 0.28);
      background: rgba(254, 242, 242, 0.92);
      color: #991b1b;
    }

    .rh-review-action-result[data-kind="loading"],
    .rh-review-action-result[data-kind="info"] {
      border-color: rgba(37, 99, 235, 0.24);
      background: rgba(239, 246, 255, 0.92);
      color: #1d4ed8;
    }

    .rh-review-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 0.35rem;
      min-width: 15rem;
    }

    .rh-review-queue-card {
      grid-column: 1 / -1;
    }

    .rh-table-pager {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      align-items: center;
      justify-content: space-between;
      padding: 0.75rem;
      border-top: 1px solid rgba(15, 23, 42, 0.08);
      background: #f8fafc;
      color: rgba(15, 23, 42, 0.68);
      font-size: 0.84rem;
      font-weight: 700;
    }

    .rh-table-pager .rh-review-actions {
      min-width: auto;
    }

    .rh-mini-button {
      appearance: none;
      border: 1px solid rgba(15, 23, 42, 0.16);
      border-radius: 999px;
      background: #ffffff;
      color: #0f172a;
      cursor: pointer;
      font-size: 0.76rem;
      font-weight: 800;
      line-height: 1;
      padding: 0.45rem 0.65rem;
    }

    .rh-mini-button:hover:not(:disabled) {
      border-color: rgba(37, 99, 235, 0.44);
      color: #1d4ed8;
    }

    .rh-mini-button:disabled {
      cursor: not-allowed;
      opacity: 0.45;
    }

    .rh-mini-button-success {
      border-color: rgba(22, 163, 74, 0.28);
      background: rgba(240, 253, 244, 0.92);
      color: #166534;
    }

    .rh-mini-button-primary {
      border-color: rgba(37, 99, 235, 0.28);
      background: rgba(37, 99, 235, 0.08);
      color: #1d4ed8;
    }

    .rh-mini-button-danger {
      border-color: rgba(220, 38, 38, 0.28);
      background: rgba(254, 242, 242, 0.92);
      color: #991b1b;
    }

    .rh-mini-button-warning {
      border-color: rgba(217, 119, 6, 0.28);
      background: rgba(255, 251, 235, 0.95);
      color: #92400e;
    }

    .rh-state-badges,
    .rh-evidence-row {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 0.45rem;
    }

    .rh-state-badge {
      display: inline-flex;
      align-items: center;
      gap: 0.3rem;
      border: 1px solid rgba(100, 116, 139, 0.18);
      border-radius: 999px;
      padding: 0.35rem 0.55rem;
      background: #f1f5f9;
      color: #475569;
      font-size: 0.76rem;
      font-weight: 900;
      line-height: 1;
      white-space: nowrap;
    }

    .rh-state-badge-success {
      border-color: rgba(22, 163, 74, 0.25);
      background: rgba(240, 253, 244, 0.95);
      color: #166534;
    }

    .rh-state-badge-info {
      border-color: rgba(37, 99, 235, 0.22);
      background: rgba(239, 246, 255, 0.95);
      color: #1d4ed8;
    }

    .rh-state-badge-warning {
      border-color: rgba(217, 119, 6, 0.28);
      background: rgba(255, 251, 235, 0.95);
      color: #92400e;
    }

    .rh-state-badge-danger {
      border-color: rgba(220, 38, 38, 0.26);
      background: rgba(254, 242, 242, 0.95);
      color: #991b1b;
    }

    .rh-evidence-panel {
      display: grid;
      gap: 0.8rem;
      padding: 0.85rem;
      border: 1px solid rgba(15, 23, 42, 0.08);
      border-radius: 1rem;
      background: #f8fafc;
      white-space: normal;
    }

    .rh-evidence-note {
      margin: 0;
      color: rgba(15, 23, 42, 0.66);
      font-size: 0.86rem;
      line-height: 1.55;
      white-space: normal;
      overflow-wrap: anywhere;
    }

    .rh-token-warning {
      border: 1px solid rgba(217, 119, 6, 0.26);
      border-radius: 0.85rem;
      padding: 0.75rem 0.85rem;
      background: rgba(255, 251, 235, 0.95);
      color: #92400e;
      font-size: 0.86rem;
      font-weight: 800;
      line-height: 1.55;
      white-space: normal;
    }


    .rh-muted {
      margin: 0;
      color: rgba(15, 23, 42, 0.62);
      line-height: 1.6;
    }

    details summary {
      color: #0f172a;
      cursor: pointer;
      font-weight: 900;
    }

    pre {
      overflow: auto;
      max-height: 520px;
      margin: 1rem 0 0;
      padding: 1rem;
      border: 1px solid rgba(15, 23, 42, 0.1);
      border-radius: 1rem;
      background: #0f172a;
      color: #e2e8f0;
      font-size: 0.85rem;
      line-height: 1.5;
    }

    @media (max-width: 900px) {
      .rh-admin-grid,
      .rh-metric-grid {
        grid-template-columns: 1fr;
      }

      .rh-admin-token-card {
        display: grid;
      }

      .rh-admin-token-actions {
        justify-content: stretch;
      }

      .rh-admin-token-actions .rh-button {
        width: 100%;
      }
    }

    @media (max-width: 640px) {
      .rh-admin-page {
        width: min(100% - 1rem, 1180px);
        padding-top: 1rem;
      }

      .rh-admin-hero,
      .rh-admin-card,
      .rh-admin-status-card {
        padding: 1rem;
        border-radius: 1rem;
      }

      .rh-admin-linkbar a {
        width: 100%;
      }
    }
  
  /* 3X-0T-C3-B: Operations Centre licence evidence readability repair */

  .rh-state-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    align-items: center;
  }

  .rh-state-badge {
    display: inline-flex;
    align-items: center;
    border-radius: 999px;
    padding: 0.18rem 0.55rem;
    font-size: 0.72rem;
    font-weight: 700;
    line-height: 1.2;
    white-space: nowrap;
    border: 1px solid rgba(148, 163, 184, 0.35);
    background: #f8fafc;
    color: #334155;
  }

  .rh-state-badge-success {
    background: #ecfdf5;
    border-color: #bbf7d0;
    color: #166534;
  }

  .rh-state-badge-info {
    background: #eff6ff;
    border-color: #bfdbfe;
    color: #1d4ed8;
  }

  .rh-state-badge-warning {
    background: #fffbeb;
    border-color: #fde68a;
    color: #92400e;
  }

  .rh-state-badge-danger {
    background: #fef2f2;
    border-color: #fecaca;
    color: #991b1b;
  }

  .rh-state-badge-muted {
    background: #f8fafc;
    border-color: #e2e8f0;
    color: #64748b;
  }

  .rh-evidence-panel {
    display: grid;
    gap: 0.9rem;
    padding: 1rem;
