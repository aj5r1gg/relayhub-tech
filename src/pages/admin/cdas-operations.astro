  <script is:inline>
    // @ts-nocheck

    const TOKEN_STORAGE_KEY = "relayhub_admin_token";
    const API_URL = "/api/admin/cdas/operations";
    const TABLE_PAGE_SIZE = 8;
    const tablePages = new Map();

    const statusPanel = document.getElementById("statusPanel");
    const refreshBtn = document.getElementById("refreshBtn");
    const rawPayload = document.getElementById("rawPayload");
    const tokenStatus = document.getElementById("token-status");

    function getAdminToken() {
      return sessionStorage.getItem(TOKEN_STORAGE_KEY) || "";
    }

    function escapeHtml(value) {
      return String(value ?? "")
        .replaceAll("&", "&amp;")
        .replaceAll("<", "&lt;")
        .replaceAll(">", "&gt;")
        .replaceAll('"', "&quot;")
        .replaceAll("'", "&#039;");
    }

    function niceLabel(key) {
      return String(key || "")
        .replaceAll("_", " ")
        .replace(/\b\w/g, (c) => c.toUpperCase());
    }

    function updateTokenStatus(message) {
      if (!tokenStatus) return;

      const token = getAdminToken();

      if (message) {
        tokenStatus.textContent = message;
        return;
      }

      tokenStatus.textContent = token
        ? "Admin token is loaded in this browser session. Operations data can be fetched from the protected Worker endpoint."
        : "No admin token is loaded in this browser session. Paste and save the admin token above.";
    }

    function setStatusPanel(status, eyebrow, heading, body) {
      if (!statusPanel) return;

      statusPanel.dataset.status = status || "unknown";
      statusPanel.innerHTML = `
        <p class="rh-eyebrow">${escapeHtml(eyebrow)}</p>
        <h2>${escapeHtml(heading)}</h2>
        <p>${escapeHtml(body)}</p>
      `;
    }

    function metricGrid(targetId, data) {
      const target = document.getElementById(targetId);
      if (!target) return;

      target.innerHTML = Object.entries(data || {})
        .map(([key, value]) => {
          return `
            <div class="rh-metric">
              <strong>${escapeHtml(value ?? 0)}</strong>
              <span>${escapeHtml(niceLabel(key))}</span>
            </div>
          `;
        })
        .join("");
    }

    function emptyMessage(message) {
      return `<p class="rh-muted">${escapeHtml(message)}</p>`;
    }

    function adminUrl(path, params = {}) {
      const query = Object.entries(params)
        .filter(([, value]) => value !== undefined && value !== null && value !== "")
        .map(
          ([key, value]) =>
            `${encodeURIComponent(key)}=${encodeURIComponent(String(value))}`,
        )
        .join("&");

      return query ? `${path}?${query}` : path;
    }

    function adminActionLinks(links) {
      const safeLinks = Array.isArray(links) ? links : [];

      if (!safeLinks.length) {
        return "";
      }

      return `
        <div class="rh-row-actions">
          ${safeLinks
            .filter((link) => link && link.href && link.label)
            .map(
              (link) =>
                `<a class="rh-table-action" href="${escapeHtml(link.href)}">${escapeHtml(
                  link.label,
                )}</a>`,
            )
            .join("")}
        </div>
      `;
    }

    function reviewActionButtons(row) {
      const id = escapeHtml(row.id || "");
      const status = String(row.status || "");

      const requestLink = `<a class="rh-table-action" href="${escapeHtml(
        adminUrl("/admin/cdas-access-requests/", { id: row.id }),
      )}">Open Request</a>`;

      const noteButton = `<button class="rh-mini-button" type="button" data-review-action="note" data-request-id="${id}">Note</button>`;
      const holdButton = `<button class="rh-mini-button" type="button" data-review-action="hold" data-request-id="${id}">Hold</button>`;
      const rejectButton = `<button class="rh-mini-button rh-mini-button-danger" type="button" data-review-action="reject" data-request-id="${id}">Reject</button>`;
      const approveButton = `<button class="rh-mini-button rh-mini-button-primary" type="button" data-review-action="approve_review" data-request-id="${id}">Approve Review</button>`;

      const eligibilityButton = `<button class="rh-mini-button" type="button" data-licence-action="eligibility" data-request-id="${id}">Check Eligibility</button>`;
      const issueLicenceButton = `<button class="rh-mini-button rh-mini-button-success" type="button" data-licence-action="issue" data-request-id="${id}">Issue Licence</button>`;

      const reviewButtons =
        status === "rejected" || status === "review_approved" || status === "licence_issued"
          ? noteButton
          : `${noteButton}${holdButton}${rejectButton}${approveButton}`;

      const licenceButtons =
        status === "review_approved"
          ? `${eligibilityButton}${issueLicenceButton}`
          : eligibilityButton;

      return `
        <div class="rh-request-action-row-inner">
          <span class="rh-request-action-label">Review actions</span>
          ${requestLink}
          ${reviewButtons}
          <span class="rh-request-action-label">Licence handoff</span>
          ${licenceButtons}
        </div>
      `;
    }

    function setReviewActionResult(kind, message) {
      const target = document.getElementById("reviewActionResult");
      if (!target) return;

      target.dataset.kind = kind || "info";
      target.textContent = message || "";
    }

    function setInlineWorkflowActionResult(button, kind, message) {
      const container = button?.closest(".rh-licence-record-actions, .rh-request-action-row-inner");
      const target = container?.querySelector(".rh-inline-workflow-result");

      if (!target) return;

      target.dataset.kind = kind || "info";
      target.textContent = message || "";
    }

    async function submitReviewAction(requestId, action) {
      const token = getAdminToken();

      if (!token) {
        setReviewActionResult("error", "Admin token is required before review actions can be submitted.");
        return;
      }

      const defaultNote =
        action === "note"
          ? "Admin review note."
          : action === "hold"
            ? "Placed on hold from Operations Centre."
            : action === "reject"
              ? "Rejected from Operations Centre."
              : "Approved for the next manual review step.";

      const note = window.prompt(`Enter note/reason for ${niceLabel(action)}:`, defaultNote);

      if (note === null) {
        setReviewActionResult("info", "Review action cancelled.");
        return;
      }

      setReviewActionResult("loading", `Submitting ${niceLabel(action)} for ${requestId}…`);

      try {
        const response = await fetch(
          `/api/admin/cdas/access-requests/${encodeURIComponent(requestId)}/review`,
          {
            method: "POST",
            headers: {
              accept: "application/json",
              authorization: `Bearer ${token}`,
              "content-type": "application/json",
            },
            body: JSON.stringify({
              action,
              actor: "operations-centre",
              reason: note,
              note,
            }),
          },
        );

        const data = await response.json();

        if (!response.ok || !data.ok) {
          throw new Error(data.message || data.error || `Review action failed with ${response.status}`);
        }

        setReviewActionResult(
          "success",
          `${niceLabel(action)} recorded for ${requestId}. Status: ${data.previous_status} → ${data.new_status}.`,
        );

        await loadOperations();
      } catch (error) {
        setReviewActionResult("error", error?.message || "Review action failed.");
      }
    }



    async function checkLicenceEligibility(requestId) {
      const token = getAdminToken();

      if (!token) {
        setReviewActionResult("error", "Admin token is required before licence eligibility can be checked.");
        return;
      }

      setReviewActionResult("loading", `Checking licence eligibility for ${requestId}…`);

      try {
        const response = await fetch(
          `/api/admin/cdas/access-requests/${encodeURIComponent(requestId)}/licence-eligibility`,
          {
            method: "GET",
            headers: {
              accept: "application/json",
              authorization: `Bearer ${token}`,
            },
          },
        );

        const data = await response.json();

        if (!response.ok || !data.ok) {
          throw new Error(data.message || data.error || `Eligibility check failed with ${response.status}`);
        }

        if (data.eligible) {
          setReviewActionResult(
            "success",
            `${requestId} is eligible for licence issue. Existing licences: ${data.counts?.existing_licences_for_request ?? 0}.`,
          );
        } else {
          setReviewActionResult(
            "info",
            `${requestId} is not eligible. Blockers: ${(data.blockers || []).join(", ") || "none reported"}.`,
          );
        }
      } catch (error) {
        setReviewActionResult("error", error?.message || "Licence eligibility check failed.");
      }
    }

    async function issueReviewedLicence(requestId) {
      const token = getAdminToken();

      if (!token) {
        setReviewActionResult("error", "Admin token is required before a licence can be issued.");
        return;
      }

      const note = window.prompt(
        "Enter licence issue note:",
        "Issue licence only. Do not generate PDF, create download link, or send email.",
      );

      if (note === null) {
        setReviewActionResult("info", "Licence issue cancelled.");
        return;
      }

      setReviewActionResult("loading", `Issuing licence for ${requestId}…`);

      try {
        const response = await fetch(
          `/api/admin/cdas/access-requests/${encodeURIComponent(requestId)}/issue-licence`,
          {
            method: "POST",
            headers: {
              accept: "application/json",
              authorization: `Bearer ${token}`,
              "content-type": "application/json",
            },
            body: JSON.stringify({
              actor: "operations-centre",
              note,
            }),
          },
        );

        const data = await response.json();

        if (!response.ok || !data.ok) {
          const blockers = Array.isArray(data.blockers) && data.blockers.length
            ? ` Blockers: ${data.blockers.join(", ")}.`
            : "";

          throw new Error(
            `${data.message || data.error || `Licence issue failed with ${response.status}`}.${blockers}`,
          );
        }

        setReviewActionResult(
          "success",
          `Licence issued for ${requestId}: ${data.licence_number}. No PDF, download link, or email was created.`,
        );

        await loadOperations();
      } catch (error) {
        setReviewActionResult("error", error?.message || "Licence issue failed.");
      }
    }



    function badge(label, kind = "muted", title = "") {
      const safeKind = ["success", "info", "warning", "danger", "muted"].includes(kind)
        ? kind
        : "muted";

      return `<span class="rh-state-badge rh-state-badge-${safeKind}" title="${escapeHtml(title || label)}">${escapeHtml(label)}</span>`;
    }

    function lifecycleBadges(row) {
      const badges = [];

      badges.push(
        row.status === "issued" || row.status === "active"
          ? badge("Licence issued", "success", row.issued_at || "")
          : row.status === "revoked"
            ? badge("Licence revoked", "danger", row.revoked_at || "")
            : badge(`Licence ${niceLabel(row.status || "unknown")}`, "warning"),
      );

      if (row.revoked_at) badges.push(badge("Licence revoked", "danger", row.revoked_at));
      if (row.superseded_by) badges.push(badge("Licence superseded", "danger", row.superseded_by));
      if (row.suspected_leak_at) badges.push(badge("Suspected leak", "warning", row.suspected_leak_at));
      if (row.confirmed_leak_at) badges.push(badge("Confirmed leak", "danger", row.confirmed_leak_at));

      badges.push(
        row.generated_pdf_status === "generated"
          ? badge("PDF generated", "success", row.generated_pdf_created_at || "")
          : row.generated_pdf_error
            ? badge("PDF failed", "danger", row.generated_pdf_error)
            : badge(`PDF ${niceLabel(row.generated_pdf_status || "not_generated")}`, "warning"),
      );

      if (row.generated_pdf_sha256) {
        badges.push(badge("PDF SHA-256", "info", row.generated_pdf_sha256));
      }

      if (row.latest_download_link_id) {
        badges.push(badge("Link created", "success", row.latest_download_link_created_at || row.link_created_event_at || ""));

        const linkStatus = String(row.latest_download_link_status || "");

        if (linkStatus === "pending_activation") {
          badges.push(badge("Pending activation", "warning", row.latest_download_reference || ""));
        } else if (linkStatus === "active") {
          badges.push(badge("Link active", "success", row.latest_download_link_activated_at || row.link_activated_event_at || ""));
        } else if (linkStatus === "used") {
          badges.push(badge("Downloaded", "success", row.latest_download_link_used_at || row.downloaded_event_at || ""));
        } else if (linkStatus === "revoked" || row.latest_download_link_revoked_at) {
          badges.push(badge("Link revoked", "danger", row.latest_download_link_revoked_at || ""));
        } else if (linkStatus === "superseded" || row.latest_download_link_superseded_at) {
          badges.push(badge("Link superseded", "danger", row.latest_download_link_superseded_at || ""));
        } else {
          badges.push(badge(`Link ${niceLabel(linkStatus || "unknown")}`, "info"));
        }
      } else {
        badges.push(badge("No link", "muted"));
      }

      if (row.email_sent_event_at) badges.push(badge("Email sent", "success", row.email_sent_event_at));
      if (row.downloaded_event_at) badges.push(badge("Download event", "success", row.downloaded_event_at));
      if (row.replay_denied_event_at) badges.push(badge("Replay denied", "warning", row.replay_denied_event_at));

      return `<div class="rh-state-badges">${badges.join("")}</div>`;
    }

    function licenceEvidencePanel(row) {
      const linkId = row.latest_download_link_id || "";
      const linkReference = row.latest_download_reference || "No download reference";
      const eventCount = Number(row.download_event_count || 0);

      return `
        <div class="rh-evidence-panel">
          ${lifecycleBadges(row)}
          <p class="rh-evidence-note">
            Latest link: <strong>${escapeHtml(linkReference)}</strong>
            ${linkId ? ` · Link ID: <code>${escapeHtml(linkId)}</code>` : ""}
            · Events recorded for this licence: <strong>${escapeHtml(eventCount)}</strong>
            ${row.generated_pdf_sha256 ? ` · PDF SHA-256: <code>${escapeHtml(row.generated_pdf_sha256)}</code>` : ""}
          </p>
          <div class="rh-token-warning">
            Token handling: raw controlled download URLs are shown only when a link is created.
            They are not stored in D1 and cannot be recovered later from the Operations Centre.
          </div>
          ${downloadLinkRecoveryButtons(row)}
          ${licenceWorkflowButtons(row)}
        </div>
      `;
    }

    function downloadEventBadges(row) {
      const eventType = String(row.event_type || "");
      const success = Number(row.success) === 1;
      const badges = [];

      if (eventType === "document_downloaded") {
        badges.push(badge("Downloaded", "success", row.event_at || ""));
      } else if (eventType === "download_replay_denied") {
        badges.push(badge("Replay denied", "warning", row.failure_reason || ""));
      } else if (eventType === "active_link_delivery_email_sent") {
        badges.push(badge("Email sent", "success", row.failure_reason || ""));
      } else if (eventType === "active_link_delivery_email_blocked") {
        badges.push(badge("Duplicate email blocked", "warning", row.failure_reason || ""));
      } else if (eventType === "download_link_activated") {
        badges.push(badge("Link activated", "success", row.event_at || ""));
      } else if (eventType === "download_link_created_pending_activation") {
        badges.push(badge("Link created", "info", row.event_at || ""));
      } else {
        badges.push(badge(niceLabel(eventType || "event"), success ? "info" : "warning", row.failure_reason || ""));
      }

      badges.push(success ? badge("Success", "success") : badge("Blocked / failed", "warning"));

      if (row.download_link_status) {
        badges.push(
          badge(
            `Link ${niceLabel(row.download_link_status)}`,
            row.download_link_status === "used"
              ? "success"
              : row.download_link_status === "revoked" || row.download_link_status === "superseded"
                ? "danger"
                : "info",
          ),
        );
      }

      return `<div class="rh-state-badges">${badges.join("")}</div>`;
    }

    function downloadEvidencePanel(row) {
      return `
        <div class="rh-evidence-panel">
          ${downloadEventBadges(row)}
          <p class="rh-evidence-note">
            Download reference: <strong>${escapeHtml(row.download_reference || "Not recorded")}</strong>
            · Events for this link: <strong>${escapeHtml(row.events_for_download || 0)}</strong>
            ${row.failure_reason ? ` · Detail: ${escapeHtml(row.failure_reason)}` : ""}
          </p>
          ${adminActionLinks([
            {
              label: "Open download link",
              href: adminUrl("/admin/cdas-download-links/", {
                id: row.download_id,
                licence_number: row.licence_number,
              }),
            },
            {
              label: "Open licence",
              href: adminUrl("/admin/cdas-licences/", {
                licence_number: row.licence_number,
              }),
            },
            {
              label: "Analytics",
              href: adminUrl("/admin/downloads/", {
                event_id: row.id,
                download_id: row.download_id,
              }),
            },
          ])}
        </div>
      `;
    }


    function canRevokeDownloadLink(row) {
      const status = String(row.latest_download_link_status || "").toLowerCase();

      return Boolean(row.latest_download_link_id) &&
        ["created", "pending_generation", "pending_activation", "sent", "active"].includes(status) &&
        !row.latest_download_link_used_at &&
        !row.latest_download_link_revoked_at &&
        !row.latest_download_link_superseded_at;
    }


    function canNotifyRevokedDownloadLink(row) {
      const status = String(row.latest_download_link_status || "").toLowerCase();

      return Boolean(row.latest_download_link_id) &&
        (status === "revoked" || Boolean(row.latest_download_link_revoked_at));
    }

    function revocationNoticeButtons(row) {
      const linkId = escapeHtml(row.latest_download_link_id || "");
      const linkReference = escapeHtml(row.latest_download_reference || row.latest_download_link_id || "");

      if (!linkId) return "";

      return `
        <div class="rh-request-action-row-inner">
          <span class="rh-request-action-label">Notice</span>
          <button
            class="rh-mini-button"
            type="button"
            data-recovery-action="check-revocation-notice"
            data-download-link-id="${linkId}"
            data-download-reference="${linkReference}"
          >Check Notice</button>
          <button
            class="rh-mini-button rh-mini-button-warning"
            type="button"
            data-recovery-action="send-revocation-notice"
            data-download-link-id="${linkId}"
            data-download-reference="${linkReference}"
          >Send Notice</button>
          <span
            class="rh-request-action-label"
            data-notice-result-for="${linkId}"
          ></span>
        </div>
      `;
    }

    function setInlineNoticeResult(downloadLinkId, kind, message) {
      for (const target of document.querySelectorAll("[data-notice-result-for]")) {
        if (target.getAttribute("data-notice-result-for") !== downloadLinkId) continue;

        target.dataset.kind = kind || "info";
        target.textContent = message || "";
        target.title = message || "";
        return;
      }
    }

    function downloadLinkRecoveryButtons(row) {
      const linkId = escapeHtml(row.latest_download_link_id || "");
      const linkReference = escapeHtml(row.latest_download_reference || row.latest_download_link_id || "");
      const status = String(row.latest_download_link_status || "").toLowerCase();

      if (!linkId) {
        return `
          <div class="rh-request-action-row-inner">
            <span class="rh-request-action-label">Recovery</span>
            <span class="rh-request-action-label">No controlled link</span>
          </div>
        `;
      }

      if (!canRevokeDownloadLink(row)) {
        const stateLabel =
          status === "used"
            ? "Used link cannot be revoked"
            : status === "revoked" || row.latest_download_link_revoked_at
              ? "Already revoked"
              : status === "superseded" || row.latest_download_link_superseded_at
                ? "Superseded link"
                : "Revocation unavailable";

        const noticeButtons = canNotifyRevokedDownloadLink(row)
          ? revocationNoticeButtons(row)
          : "";

        return `
          <div class="rh-request-action-row-inner">
            <span class="rh-request-action-label">Recovery</span>
            <span class="rh-request-action-label">${escapeHtml(stateLabel)}</span>
          </div>
          ${noticeButtons}
        `;
      }

      return `
        <div class="rh-request-action-row-inner">
          <span class="rh-request-action-label">Recovery</span>
          <button
            class="rh-mini-button"
            type="button"
            data-recovery-action="check-revocation"
            data-download-link-id="${linkId}"
            data-download-reference="${linkReference}"
          >Check Revoke</button>
          <button
            class="rh-mini-button rh-mini-button-danger"
            type="button"
            data-recovery-action="revoke-link"
            data-download-link-id="${linkId}"
            data-download-reference="${linkReference}"
          >Revoke Link</button>
        </div>
      `;
    }

    async function handleRecoveryAction(action, button) {
      const downloadLinkId = button.getAttribute("data-download-link-id") || "";
      const downloadReference =
        button.getAttribute("data-download-reference") || downloadLinkId;

      try {
        if (action === "check-revocation") {
          setReviewActionResult(
            "loading",
            `Checking revocation eligibility for ${downloadReference}…`,
          );

          const data = await workflowFetch(
            `/api/admin/cdas/download-links/${encodeURIComponent(downloadLinkId)}/revocation-eligibility`,
          );

          setReviewActionResult(
            data.eligible ? "success" : "info",
            data.eligible
              ? `${downloadReference} is eligible for guarded revocation.`
              : `${downloadReference} cannot be revoked. Blockers: ${(data.blockers || []).join(", ") || "none reported"}.`,
          );

          return;
        }

        if (action === "revoke-link") {
          const reason = window.prompt(
            `Reason for revoking ${downloadReference}:`,
            "Operations Centre recovery action. Revoke controlled download link only. Do not reissue, email, serve PDF, delete R2 object, or modify licence.",
          );

          if (reason === null) {
            setReviewActionResult("info", "Revocation cancelled.");
            return;
          }

          const confirmed = window.confirm(
            `Revoke ${downloadReference}? This disables the controlled link but does not delete the PDF, reissue a link, send email, or modify the licence.`,
          );

          if (!confirmed) {
            setReviewActionResult("info", "Revocation cancelled.");
            return;
          }

          setReviewActionResult("loading", `Revoking ${downloadReference}…`);

          const data = await workflowFetch(
            `/api/admin/cdas/download-links/${encodeURIComponent(downloadLinkId)}/revoke`,
            {
              method: "POST",
              body: {
                actor: "operations-centre",
                reason,
              },
            },
          );

          setReviewActionResult(
            "success",
            `${data.download_link?.download_reference || downloadReference} was revoked. Event recorded: ${data.event_recorded ? "yes" : "no"}.`,
          );

          await loadOperations();
          return;
        }

        if (action === "check-revocation-notice") {
          const originalLabel = button.textContent;
          button.disabled = true;
          button.textContent = "Checking…";

          setInlineNoticeResult(downloadLinkId, "loading", "Checking notice eligibility…");
          setReviewActionResult(
            "loading",
            `Checking revocation notice eligibility for ${downloadReference}…`,
          );

          try {
            const data = await workflowFetch(
              `/api/admin/cdas/download-links/${encodeURIComponent(downloadLinkId)}/revocation-notice-eligibility`,
            );

            const blockers = data.blockers || [];
            const alreadySent = Boolean(data.notice?.already_sent);
            const priorSentAt = data.notice?.prior_successful_notice_at || "";
            const recipient = data.notice?.recipient_email || data.licence?.recipient_email || "recipient";

            let inlineMessage;

            if (data.eligible) {
              inlineMessage = `Eligible: notice can be sent to ${recipient}.`;
            } else if (alreadySent || blockers.includes("revocation_notice_already_sent")) {
              inlineMessage = priorSentAt
                ? `Already notified: ${priorSentAt}.`
                : "Already notified.";
            } else {
              inlineMessage = `Blocked: ${blockers.join(", ") || "not eligible"}.`;
            }

            const globalMessage = data.eligible
              ? `${downloadReference} is eligible for a revocation notice to ${recipient}.`
              : `${downloadReference} cannot be notified. ${inlineMessage}`;

            setInlineNoticeResult(
              downloadLinkId,
              data.eligible ? "success" : alreadySent ? "info" : "warning",
              inlineMessage,
            );

            setReviewActionResult(
              data.eligible ? "success" : "warning",
              globalMessage,
            );
          } finally {
            button.disabled = false;
            button.textContent = originalLabel || "Check Notice";
          }

          return;
        }

        if (action === "send-revocation-notice") {
          const note = window.prompt(
            `Notice note for ${downloadReference}:`,
            "Operations Centre: notify recipient that the controlled download link was revoked. Do not state that the licence was revoked. Do not reissue, activate, serve PDF, or modify licence.",
          );

          if (note === null) {
            setReviewActionResult("info", "Revocation notice cancelled.");
            return;
          }

          const confirmed = window.confirm(
            `Send revocation notice for ${downloadReference}? This sends an email only. It does not reissue a link, activate a link, serve the PDF, or modify the licence.`,
          );

          if (!confirmed) {
            setReviewActionResult("info", "Revocation notice cancelled.");
            return;
          }

          setReviewActionResult("loading", `Sending revocation notice for ${downloadReference}…`);

          const data = await workflowFetch(
            `/api/admin/cdas/download-links/${encodeURIComponent(downloadLinkId)}/send-revocation-notice`,
            {
              method: "POST",
              body: {
                actor: "operations-centre",
                note,
              },
            },
          );

          setReviewActionResult(
            "success",
            `Revocation notice sent to ${data.notice?.recipient_email || data.licence?.recipient_email || "recipient"} via ${data.email_result?.provider || "provider"}. Message ID: ${data.email_result?.provider_message_id || "not returned"}.`,
          );

          await loadOperations();
          return;
        }

        setReviewActionResult("error", `Unknown recovery action: ${action}`);
      } catch (error) {
        setReviewActionResult("error", error?.message || "Recovery action failed.");
      }
    }

    function licenceWorkflowButtons(row) {
      const licenceId = escapeHtml(row.id || "");
      const latestLinkId = row.latest_download_link_id || "";
      const latestLinkReference = row.latest_download_reference || latestLinkId;
      const latestLinkStatus = String(row.latest_download_link_status || "").toLowerCase();

      const pdfStatus = String(row.generated_pdf_status || "");
      const openLinkCount = Number(row.open_download_link_count || 0);
      const pendingActivationCount = Number(row.pending_activation_link_count || 0);
      const hasOpenReplacement = openLinkCount > 0 || pendingActivationCount > 0;

      const supersededLinkId = row.latest_superseded_link_id || "";
      const supersededReference = row.latest_superseded_reference || supersededLinkId;
      const supersededStatus = String(row.latest_superseded_link_status || "").toLowerCase();

      const latestIsReissueCandidate = ["revoked", "superseded", "failed"].includes(latestLinkStatus);

      const reissueSourceLinkId = supersededLinkId || (latestIsReissueCandidate ? latestLinkId : "");
      const reissueSourceReference = supersededReference || (latestIsReissueCandidate ? latestLinkReference : "");
      const reissueSourceStatus = supersededStatus || (latestIsReissueCandidate ? latestLinkStatus : "");

      const safeReissueSourceId = escapeHtml(reissueSourceLinkId);
      const safeReissueReference = escapeHtml(reissueSourceReference || reissueSourceLinkId);

      const licenceLink = `<a class="rh-table-action" href="${escapeHtml(
        adminUrl("/admin/cdas-licences/", {
          id: row.id,
          licence_number: row.licence_number,
        }),
      )}">Open Licence</a>`;

      const downloadLinksLink = `<a class="rh-table-action" href="${escapeHtml(
        adminUrl("/admin/cdas-download-links/", {
          id: row.latest_download_link_id || "",
          licence_number: row.licence_number,
        }),
      )}">Open Links</a>`;

      const checkPdf = `<button class="rh-mini-button" type="button" data-cdas-workflow-action="check-pdf" data-licence-id="${licenceId}">Check PDF</button>`;
      const generatePdf = `<button class="rh-mini-button rh-mini-button-success" type="button" data-cdas-workflow-action="generate-pdf" data-licence-id="${licenceId}">Generate PDF</button>`;
      const checkLink = `<button class="rh-mini-button" type="button" data-cdas-workflow-action="check-link" data-licence-id="${licenceId}">Check Link</button>`;
      const createLink = `<button class="rh-mini-button rh-mini-button-success" type="button" data-cdas-workflow-action="create-link" data-licence-id="${licenceId}">Create Link</button>`;

      const linkId = escapeHtml(latestLinkId);

      const checkActivation = latestLinkId
        ? `<button class="rh-mini-button" type="button" data-cdas-workflow-action="check-activation" data-download-link-id="${linkId}">Check Activation</button>`
        : "";

      const activateLink = latestLinkId
        ? `<button class="rh-mini-button rh-mini-button-success" type="button" data-cdas-workflow-action="activate-link" data-download-link-id="${linkId}">Activate Link</button>`
        : "";

      const prepareDelivery = latestLinkId
        ? `<button class="rh-mini-button rh-mini-button-warning" type="button" data-cdas-workflow-action="prepare-delivery" data-download-link-id="${linkId}">Prepare Delivery</button>`
        : "";

      const sendEmail = latestLinkId
        ? `<button class="rh-mini-button rh-mini-button-warning" type="button" data-cdas-workflow-action="send-email" data-download-link-id="${linkId}">Send Email</button>`
        : "";

      const checkReissue = reissueSourceLinkId
        ? `<button
            class="rh-mini-button"
            type="button"
            data-cdas-workflow-action="check-reissue"
            data-download-link-id="${safeReissueSourceId}"
            data-download-reference="${safeReissueReference}"
          >Check Reissue</button>`
        : "";

      const createReissue = reissueSourceLinkId && !hasOpenReplacement
        ? `<button
            class="rh-mini-button rh-mini-button-success"
            type="button"
            data-cdas-workflow-action="reissue-link"
            data-download-link-id="${safeReissueSourceId}"
            data-download-reference="${safeReissueReference}"
          >Create Replacement</button>`
        : "";

      const reissueState = reissueSourceLinkId && hasOpenReplacement
        ? `<span class="rh-request-action-label" title="Open replacement links: ${escapeHtml(openLinkCount)}">Reissue blocked: replacement open</span>`
        : reissueSourceLinkId
          ? `<span class="rh-request-action-label">Source: ${escapeHtml(niceLabel(reissueSourceStatus || "candidate"))}</span>`
          : `<span class="rh-request-action-label">No reissue source</span>`;

      const pdfButtons = pdfStatus === "generated"
        ? `${checkPdf}`
        : `${checkPdf}${generatePdf}`;

      const linkButtons = pdfStatus === "generated" && !latestLinkId
        ? `${checkLink}${createLink}`
        : pdfStatus === "generated"
          ? `${checkLink}`
          : "";

      const activationButtons = latestLinkStatus === "pending_activation"
        ? `${checkActivation}${activateLink}`
        : latestLinkId
          ? checkActivation
          : "";

      const deliveryButtons = latestLinkStatus === "active"
        ? `${prepareDelivery}${sendEmail}`
        : "";

      const consumedNote = latestLinkStatus === "used"
        ? `<span class="rh-request-action-label">Consumed</span>`
        : "";

      return `
        <div class="rh-request-action-row-inner">
          <span class="rh-request-action-label">Workflow</span>
          ${licenceLink}
          ${downloadLinksLink}
          <span class="rh-request-action-label">PDF</span>
          ${pdfButtons}
          <span class="rh-request-action-label">Link</span>
          ${linkButtons}
          ${activationButtons}
          ${deliveryButtons}
          ${consumedNote}
          <span class="rh-request-action-label">Reissue</span>
          ${checkReissue}
          ${createReissue}
          ${reissueState}
