---
import BaseLayout from "../../layouts/BaseLayout.astro";
import AdminTokenPanel from "../../components/AdminTokenPanel.astro";

const pageTitle = "CDAS Access Requests Admin";
const pageDescription =
  "Read-only admin view for RelayHub Controlled Document Access System document access requests.";
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <main class="rh-admin-page">
    <section class="rh-admin-hero">
      <p class="rh-eyebrow">RelayHub Admin</p>
      <h1>CDAS Access Requests</h1>
      <p>
        Read-only view of document access requests recorded through the CDAS intake API.
        This page does not approve requests, verify email addresses, issue licences,
        generate PDFs, or create download links.
      </p>
    </section>

    <AdminTokenPanel />

    <section class="rh-admin-grid rh-admin-summary-grid" aria-label="CDAS access request summary">
      <article class="rh-admin-metric">
        <span>Total requests</span>
        <strong id="metric-total">—</strong>
      </article>

      <article class="rh-admin-metric">
        <span>Email pending</span>
        <strong id="metric-email-pending">—</strong>
      </article>

      <article class="rh-admin-metric">
        <span>Approval pending</span>
        <strong id="metric-approval-pending">—</strong>
      </article>

      <article class="rh-admin-metric">
        <span>Risk flagged</span>
        <strong id="metric-risk">—</strong>
      </article>
    </section>

    <section class="rh-admin-card">
      <div class="rh-admin-section-heading">
        <div>
          <h2>Access request registry</h2>
          <p>
            Search and filter recorded CDAS access requests.
          </p>
        </div>

        <div class="rh-admin-actions">
          <button class="rh-button rh-button-secondary" id="refresh-button" type="button">
            Refresh
          </button>
        </div>
      </div>

      <form class="rh-admin-filters" id="filters-form">
        <label>
          Search
          <input id="filter-q" name="q" type="search" placeholder="Name, email, document, organisation…" />
        </label>

        <label>
          Document
          <input id="filter-document" name="document_id" type="search" placeholder="relayhub-overview" />
        </label>

        <label>
          Status
          <select id="filter-status" name="status">
            <option value="">All statuses</option>
            <option value="email_pending">email_pending</option>
            <option value="approval_pending">approval_pending</option>
            <option value="email_verified">email_verified</option>
            <option value="approved">approved</option>
            <option value="denied">denied</option>
            <option value="expired">expired</option>
            <option value="cancelled">cancelled</option>
          </select>
        </label>

        <label>
          Access class
          <select id="filter-access-class" name="access_class">
            <option value="">All access classes</option>
            <option value="direct_public">direct_public</option>
            <option value="verified_public">verified_public</option>
            <option value="licensed_public">licensed_public</option>
            <option value="controlled_verified">controlled_verified</option>
            <option value="approval_required">approval_required</option>
            <option value="invite_only">invite_only</option>
            <option value="paid_verified">paid_verified</option>
            <option value="disabled">disabled</option>
          </select>
        </label>

        <div class="rh-admin-filter-actions">
          <button class="rh-button rh-button-primary" type="submit">
            Apply filters
          </button>
          <button class="rh-button rh-button-secondary" id="reset-filters" type="button">
            Reset
          </button>
        </div>
      </form>

      <div class="rh-admin-status" id="status-message" role="status" aria-live="polite">
        Ready.
      </div>

      <div class="rh-admin-table-wrap">
        <table class="rh-admin-table">
          <thead>
            <tr>
              <th>Requester</th>
              <th>Document</th>
              <th>Status</th>
              <th>Access class</th>
              <th>Terms</th>
              <th>Risk</th>
              <th>Requested</th>
              <th>Action</th>
            </tr>
          </thead>
          <tbody id="requests-body">
            <tr>
              <td colspan="8" class="rh-admin-empty">
                No records loaded yet.
              </td>
            </tr>
          </tbody>
        </table>
      </div>
    </section>

    <section class="rh-admin-card rh-admin-detail-card" id="detail-card" hidden>
      <div class="rh-admin-section-heading">
        <div>
          <h2>Access request detail</h2>
          <p id="detail-subtitle">
            Selected CDAS access request record.
          </p>
        </div>

        <button class="rh-button rh-button-secondary" id="close-detail" type="button">
          Close
        </button>
      </div>

      <div class="rh-admin-detail-grid" id="detail-grid"></div>
    </section>
  </main>

  <style>
    .rh-admin-page {
      width: min(1180px, calc(100% - 2rem));
      margin: 0 auto;
      padding: 3rem 0 5rem;
    }

    .rh-admin-hero {
      margin-bottom: 1.5rem;
      padding: 2rem;
      border: 1px solid rgba(15, 23, 42, 0.12);
      border-radius: 1.5rem;
      background:
        radial-gradient(circle at top left, rgba(59, 130, 246, 0.12), transparent 36rem),
        linear-gradient(135deg, rgba(255,255,255,0.96), rgba(248,250,252,0.96));
      box-shadow: 0 24px 70px rgba(15, 23, 42, 0.08);
    }

    .rh-admin-hero h1 {
      margin: 0.35rem 0 0.75rem;
      font-size: clamp(2rem, 5vw, 3.5rem);
      line-height: 1;
      letter-spacing: -0.05em;
    }

    .rh-admin-hero p {
      max-width: 800px;
      margin: 0;
      color: rgba(15, 23, 42, 0.74);
      font-size: 1.05rem;
      line-height: 1.7;
    }

    .rh-eyebrow {
      margin: 0;
      color: #2563eb;
      font-size: 0.78rem;
      font-weight: 800;
      letter-spacing: 0.14em;
      text-transform: uppercase;
    }

    .rh-admin-card,
    .rh-admin-metric {
      border: 1px solid rgba(15, 23, 42, 0.12);
      border-radius: 1.25rem;
      background: rgba(255, 255, 255, 0.96);
      box-shadow: 0 18px 50px rgba(15, 23, 42, 0.07);
    }

    .rh-admin-card {
      padding: 1.25rem;
      margin-top: 1rem;
    }

    .rh-admin-section-heading {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 1rem;
    }

    .rh-admin-card h2,
    .rh-admin-section-heading h2 {
      margin: 0;
      font-size: 1.25rem;
      letter-spacing: -0.03em;
    }

    .rh-admin-card p,
    .rh-admin-section-heading p {
      margin: 0.35rem 0 0;
      color: rgba(15, 23, 42, 0.67);
      line-height: 1.6;
    }

    .rh-admin-grid {
      display: grid;
      gap: 1rem;
    }

    .rh-admin-summary-grid {
      grid-template-columns: repeat(4, minmax(0, 1fr));
      margin: 1rem 0;
    }

    .rh-admin-metric {
      padding: 1rem;
    }

    .rh-admin-metric span {
      display: block;
      color: rgba(15, 23, 42, 0.62);
      font-size: 0.82rem;
      font-weight: 800;
      letter-spacing: 0.04em;
      text-transform: uppercase;
    }

    .rh-admin-metric strong {
      display: block;
      margin-top: 0.4rem;
      color: #0f172a;
      font-size: 2rem;
      line-height: 1;
    }

    .rh-admin-actions,
    .rh-admin-filter-actions,
    .rh-admin-row-actions {
      display: flex;
      gap: 0.5rem;
      flex-wrap: wrap;
    }

    .rh-admin-actions,
    .rh-admin-filter-actions {
      justify-content: flex-end;
    }

    .rh-admin-filters {
      display: grid;
      grid-template-columns: 1.4fr 1fr 1fr 1fr;
      gap: 0.85rem;
      align-items: end;
      margin: 1.25rem 0 1rem;
    }

    .rh-admin-filters label {
      display: grid;
      gap: 0.35rem;
      color: rgba(15, 23, 42, 0.8);
      font-size: 0.88rem;
      font-weight: 700;
    }

    .rh-admin-filters input,
    .rh-admin-filters select {
      width: 100%;
      border: 1px solid rgba(15, 23, 42, 0.18);
      border-radius: 0.8rem;
      padding: 0.75rem 0.85rem;
      background: #fff;
      color: #0f172a;
      font: inherit;
    }

    .rh-admin-filter-actions {
      grid-column: 1 / -1;
    }

    .rh-button {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 2.75rem;
      border: 1px solid transparent;
      border-radius: 999px;
      padding: 0.65rem 1rem;
      font: inherit;
      font-weight: 800;
      cursor: pointer;
      transition:
        transform 150ms ease,
        background 150ms ease,
        border-color 150ms ease,
        color 150ms ease;
      white-space: nowrap;
    }

    .rh-button:hover {
      transform: translateY(-1px);
    }

    .rh-button-primary {
      background: #0f172a;
      color: #fff;
      border-color: #0f172a;
    }

    .rh-button-primary:hover {
      background: #1e293b;
      color: #fff;
    }

    .rh-button-secondary {
      background: #fff;
      color: #0f172a;
      border-color: rgba(15, 23, 42, 0.18);
    }

    .rh-button-secondary:hover {
      background: #f8fafc;
      color: #0f172a;
      border-color: rgba(15, 23, 42, 0.34);
    }

    .rh-admin-status {
      margin: 1rem 0;
      padding: 0.85rem 1rem;
      border-radius: 0.9rem;
      background: #f8fafc;
      color: rgba(15, 23, 42, 0.75);
      font-size: 0.95rem;
    }

    .rh-admin-status[data-state="error"] {
      background: #fef2f2;
      color: #991b1b;
    }

    .rh-admin-status[data-state="success"] {
      background: #f0fdf4;
      color: #166534;
    }

    .rh-admin-table-wrap {
      overflow-x: auto;
      border: 1px solid rgba(15, 23, 42, 0.1);
      border-radius: 1rem;
    }

    .rh-admin-table {
      width: 100%;
      min-width: 1040px;
      border-collapse: collapse;
      background: #fff;
      font-size: 0.92rem;
    }

    .rh-admin-table th,
    .rh-admin-table td {
      padding: 0.85rem;
      border-bottom: 1px solid rgba(15, 23, 42, 0.08);
      text-align: left;
      vertical-align: top;
    }

    .rh-admin-table th {
      background: #f8fafc;
      color: rgba(15, 23, 42, 0.74);
      font-size: 0.76rem;
      font-weight: 900;
      letter-spacing: 0.06em;
      text-transform: uppercase;
    }

    .rh-admin-table tr:last-child td {
      border-bottom: 0;
    }

    .rh-admin-empty {
      text-align: center;
      color: rgba(15, 23, 42, 0.58);
    }

    .rh-admin-title-stack,
    .rh-policy-stack {
      display: grid;
      gap: 0.18rem;
    }

    .rh-admin-title-stack strong {
      color: #0f172a;
    }

    .rh-admin-title-stack span,
    .rh-policy-stack span {
      color: rgba(15, 23, 42, 0.64);
      font-size: 0.82rem;
      word-break: break-word;
    }

    .rh-badge {
      display: inline-flex;
      align-items: center;
      width: fit-content;
      border-radius: 999px;
      padding: 0.25rem 0.55rem;
      background: #f1f5f9;
      color: #334155;
      font-size: 0.78rem;
      font-weight: 800;
      white-space: nowrap;
    }

    .rh-badge-email_pending,
    .rh-badge-approval_pending {
      background: #fef3c7;
      color: #92400e;
    }

    .rh-badge-approved,
    .rh-badge-email_verified {
      background: #dcfce7;
      color: #166534;
    }

    .rh-badge-denied,
    .rh-badge-expired,
    .rh-badge-cancelled {
      background: #fee2e2;
      color: #991b1b;
    }

    .rh-admin-detail-card {
      margin-top: 1rem;
    }

    .rh-admin-detail-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 0.85rem;
      margin-top: 1rem;
    }

    .rh-admin-detail-item {
      border: 1px solid rgba(15, 23, 42, 0.1);
      border-radius: 0.9rem;
      padding: 0.85rem;
      background: #f8fafc;
    }

    .rh-admin-detail-item dt {
      color: rgba(15, 23, 42, 0.56);
      font-size: 0.76rem;
      font-weight: 900;
      letter-spacing: 0.06em;
      text-transform: uppercase;
    }

    .rh-admin-detail-item dd {
      margin: 0.3rem 0 0;
      color: #0f172a;
      word-break: break-word;
      line-height: 1.5;
    }

    @media (max-width: 960px) {
      .rh-admin-section-heading {
        display: grid;
      }

      .rh-admin-summary-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }

      .rh-admin-filters {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }

      .rh-admin-detail-grid {
        grid-template-columns: 1fr;
      }
    }

    @media (max-width: 640px) {
      .rh-admin-page {
        width: min(100% - 1rem, 1180px);
        padding-top: 1rem;
      }

      .rh-admin-hero,
      .rh-admin-card {
        padding: 1rem;
        border-radius: 1rem;
      }

      .rh-admin-summary-grid,
      .rh-admin-filters {
        grid-template-columns: 1fr;
      }

      .rh-admin-filter-actions .rh-button,
      .rh-admin-actions .rh-button,
      .rh-admin-row-actions .rh-button {
        width: 100%;
      }
    }
  </style>

  <script is:inline>
    // @ts-nocheck

    const TOKEN_STORAGE_KEY = "relayhub_admin_token";

    const state = {
      requests: [],
      total: 0,
      limit: 100,
      offset: 0,
    };

    const filtersForm = document.getElementById("filters-form");
    const resetFiltersButton = document.getElementById("reset-filters");
    const refreshButton = document.getElementById("refresh-button");
    const statusMessage = document.getElementById("status-message");
    const requestsBody = document.getElementById("requests-body");

    const metricTotal = document.getElementById("metric-total");
    const metricEmailPending = document.getElementById("metric-email-pending");
    const metricApprovalPending = document.getElementById("metric-approval-pending");
    const metricRisk = document.getElementById("metric-risk");

    const detailCard = document.getElementById("detail-card");
    const detailSubtitle = document.getElementById("detail-subtitle");
    const detailGrid = document.getElementById("detail-grid");
    const closeDetailButton = document.getElementById("close-detail");

    function getStoredToken() {
      return sessionStorage.getItem(TOKEN_STORAGE_KEY) || "";
    }

    function setStatus(message, mode = "neutral") {
      statusMessage.textContent = message;
      statusMessage.dataset.state = mode;
    }

    function escapeHtml(value) {
      return String(value ?? "")
        .replaceAll("&", "&amp;")
        .replaceAll("<", "&lt;")
        .replaceAll(">", "&gt;")
        .replaceAll('"', "&quot;")
        .replaceAll("'", "&#039;");
    }

    function formatValue(value) {
      if (value === null || value === undefined || value === "") {
        return "—";
      }

      return String(value);
    }

    function formatDate(value) {
      if (!value) return "—";

      const date = new Date(value);

      if (Number.isNaN(date.getTime())) {
        return value;
      }

      return date.toLocaleString(undefined, {
        year: "numeric",
        month: "short",
        day: "2-digit",
        hour: "2-digit",
        minute: "2-digit",
      });
    }

    function badgeClass(value) {
      const text = String(value || "").toLowerCase();

      if (!text) return "rh-badge";

      return `rh-badge rh-badge-${text}`;
    }

    function getFilters() {
      const formData = new FormData(filtersForm);
      const params = new URLSearchParams();

      for (const [key, value] of formData.entries()) {
        const clean = String(value || "").trim();

        if (clean) {
          params.set(key, clean);
        }
      }

      params.set("limit", String(state.limit));
      params.set("offset", String(state.offset));

      return params;
    }

    async function fetchRequests() {
      const token = getStoredToken();

      if (!token) {
        setStatus("Admin token is missing. Open another admin page and enter it once.", "error");
        renderRequests([]);
        updateMetrics([]);
        return;
      }

      const params = getFilters();
      const endpoint = `/api/admin/cdas/access-requests?${params.toString()}`;

      setStatus("Loading CDAS access requests…");

      let response;
      let data;

      try {
        response = await fetch(endpoint, {
          headers: {
            Authorization: `Bearer ${token}`,
          },
        });

        data = await response.json();
      } catch (error) {
        setStatus(`Could not load CDAS access requests: ${error.message}`, "error");
        return;
      }

      if (!response.ok || !data.ok) {
        setStatus(
          data?.message || data?.error || "CDAS access requests could not be loaded.",
          "error"
        );

        renderRequests([]);
        updateMetrics([]);
        return;
      }

      state.requests = Array.isArray(data.rows) ? data.rows : [];
      state.total = Number(data.total || state.requests.length || 0);

      renderRequests(state.requests);
      updateMetrics(state.requests);

      setStatus(
        `Loaded ${state.requests.length} CDAS access request record(s). Total matching records: ${state.total}.`,
        "success"
      );
    }

    function updateMetrics(requests) {
      const emailPending = requests.filter((row) => row.status === "email_pending").length;
      const approvalPending = requests.filter((row) => row.status === "approval_pending").length;
      const risk = requests.filter((row) => Number(row.risk_score) > 0).length;

      metricTotal.textContent = String(state.total || requests.length || 0);
      metricEmailPending.textContent = String(emailPending);
      metricApprovalPending.textContent = String(approvalPending);
      metricRisk.textContent = String(risk);
    }

    function renderRequests(requests) {
      if (!requests.length) {
        requestsBody.innerHTML = `
          <tr>
            <td colspan="8" class="rh-admin-empty">
              No CDAS access request records found.
            </td>
          </tr>
        `;
        return;
      }

      requestsBody.innerHTML = requests
        .map((row) => {
          const riskFlags = Array.isArray(row.risk_flags) && row.risk_flags.length
            ? row.risk_flags.join(", ")
            : "None";

          return `
            <tr>
              <td>
                <div class="rh-admin-title-stack">
                  <strong>${escapeHtml(row.name)}</strong>
                  <span>${escapeHtml(row.email_normalised)}</span>
                  <span>${escapeHtml(row.organisation_name || "")}</span>
                </div>
              </td>
              <td>
                <div class="rh-policy-stack">
                  <span>${escapeHtml(row.document_id)}</span>
                  <span>Version: ${escapeHtml(formatValue(row.document_version))}</span>
                </div>
              </td>
              <td>
                <span class="${badgeClass(row.status)}">
                  ${escapeHtml(formatValue(row.status))}
                </span>
              </td>
              <td>
                <span class="rh-badge">
                  ${escapeHtml(formatValue(row.access_class))}
                </span>
              </td>
              <td>
                <div class="rh-policy-stack">
                  <span>${escapeHtml(formatValue(row.terms_version))}</span>
                  <span>Accepted: ${escapeHtml(formatDate(row.terms_accepted_at))}</span>
                </div>
              </td>
              <td>
                <div class="rh-policy-stack">
                  <span>Score: ${escapeHtml(formatValue(row.risk_score))}</span>
                  <span>${escapeHtml(riskFlags)}</span>
                </div>
              </td>
              <td>${escapeHtml(formatDate(row.requested_at))}</td>
              <td>
                <div class="rh-admin-row-actions">
                  <button
                    class="rh-button rh-button-secondary"
                    type="button"
                    data-view-request="${escapeHtml(row.id)}"
                  >
                    View
                  </button>
                </div>
              </td>
            </tr>
          `;
        })
        .join("");
    }

    async function renderDetail(requestId) {
      const token = getStoredToken();

      if (!token) {
        setStatus("Admin token is missing. Open another admin page and enter it once.", "error");
        return;
      }

      setStatus("Loading access request detail…");

      let response;
      let data;

      try {
        response = await fetch(
          `/api/admin/cdas/access-requests/${encodeURIComponent(requestId)}`,
          {
            headers: {
              Authorization: `Bearer ${token}`,
            },
          }
        );

        data = await response.json();
      } catch (error) {
        setStatus(`Could not load access request detail: ${error.message}`, "error");
        return;
      }

      if (!response.ok || !data.ok || !data.request) {
        setStatus(
          data?.message || data?.error || "Access request detail could not be loaded.",
          "error"
        );
        return;
      }

      const row = data.request;

      detailSubtitle.textContent = `${row.document_id} — ${row.email_normalised}`;

      const riskFlags = Array.isArray(row.risk_flags) && row.risk_flags.length
        ? row.risk_flags.join(", ")
        : "None";

      const fields = [
        ["ID", row.id],
        ["Document ID", row.document_id],
        ["Document version", row.document_version],
        ["Name", row.name],
        ["Email", row.email],
        ["Email normalised", row.email_normalised],
        ["Licence holder type", row.licence_holder_type],
        ["Organisation name", row.organisation_name],
        ["Contact name", row.contact_name],
        ["Contact email", row.contact_email],
        ["Role title", row.role_title],
        ["Recipient category", row.recipient_category],
        ["Status", row.status],
        ["Access class", row.access_class],
        ["Verification sent at", formatDate(row.verification_sent_at)],
        ["Email verified at", formatDate(row.email_verified_at)],
        ["Email delivery status", row.email_delivery_status],
        ["Requested at", formatDate(row.requested_at)],
        ["Expires at", formatDate(row.expires_at)],
        ["Approved at", formatDate(row.approved_at)],
        ["Approved by", row.approved_by],
        ["Approval role", row.approval_role],
        ["Approval policy version", row.approval_policy_version],
        ["Approval note", row.approval_note],
        ["Denied at", formatDate(row.denied_at)],
        ["Denied by", row.denied_by],
        ["Denial reason", row.denial_reason],
        ["Terms version", row.terms_version],
        ["Terms accepted at", formatDate(row.terms_accepted_at)],
        ["Terms acceptance user agent", row.terms_acceptance_user_agent],
        ["User agent", row.user_agent],
        ["Risk score", row.risk_score],
        ["Risk flags", riskFlags],
      ];

      detailGrid.innerHTML = fields
        .map(([label, value]) => {
          return `
            <dl class="rh-admin-detail-item">
              <dt>${escapeHtml(label)}</dt>
              <dd>${escapeHtml(formatValue(value))}</dd>
            </dl>
          `;
        })
        .join("");

      detailCard.hidden = false;
      detailCard.scrollIntoView({ behavior: "smooth", block: "start" });

      setStatus("Access request detail loaded.", "success");
    }

    filtersForm.addEventListener("submit", (event) => {
      event.preventDefault();
      state.offset = 0;
      fetchRequests();
    });

    resetFiltersButton.addEventListener("click", () => {
      filtersForm.reset();
      state.offset = 0;
      fetchRequests();
    });

    refreshButton.addEventListener("click", () => {
      fetchRequests();
    });

    requestsBody.addEventListener("click", (event) => {
      const target = event.target;

      if (!(target instanceof HTMLElement)) {
        return;
      }

      const viewButton = target.closest("[data-view-request]");

      if (viewButton instanceof HTMLElement) {
        const requestId = viewButton.dataset.viewRequest;

        if (requestId) {
          renderDetail(requestId);
        }
      }
    });

    closeDetailButton.addEventListener("click", () => {
      detailCard.hidden = true;
    });

    const existingToken = getStoredToken();

    if (existingToken) {
      setStatus("Admin token found in this browser session. Loading CDAS access requests…");
      fetchRequests();
    } else {
      setStatus("Admin token is missing. Open another admin page and enter it once.", "error");
    }

    window.relayhubAdminTokenUpdated = () => {
      if (typeof fetchDownloadLinks === "function") {
        fetchDownloadLinks();
      }

      if (typeof fetchLicences === "function") {
        fetchLicences();
      }

      if (typeof fetchDocuments === "function") {
        fetchDocuments();
      }

      if (typeof fetchLicenceTerms === "function") {
        fetchLicenceTerms();
      }

      if (typeof fetchAccessRequests === "function") {
        fetchAccessRequests();
      }

      if (typeof loadDownloads === "function") {
        loadDownloads();
      }

      if (typeof loadContacts === "function") {
        loadContacts();
      }

      if (typeof loadNewsletter === "function") {
        loadNewsletter();
      }
    };

    window.relayhubAdminTokenCleared = () => {
      location.reload();
    };
  </script>
</BaseLayout>