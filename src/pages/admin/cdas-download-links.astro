---
import BaseLayout from "../../layouts/BaseLayout.astro";
import AdminTokenPanel from "../../components/AdminTokenPanel.astro";

const pageTitle = "CDAS Download Links Admin";
const pageDescription =
  "Admin registry and audit view for RelayHub CDAS controlled download links.";
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <main class="rh-admin-page">
    <section class="rh-admin-hero">
      <p class="rh-eyebrow">RelayHub Admin</p>
      <h1>CDAS Download Links</h1>
      <p>
        Registry and audit view for controlled CDAS download links. This page
        never displays raw tokens, token hashes, private R2 URLs, or public
        download URLs. It only shows lifecycle state, evidence metadata, and
        audit history.
      </p>
    </section>

    <AdminTokenPanel />

    <section class="rh-admin-grid rh-admin-summary-grid" aria-label="CDAS download link summary">
      <article class="rh-admin-metric">
        <span>Total links</span>
        <strong id="metric-total">—</strong>
      </article>

      <article class="rh-admin-metric">
        <span>Created</span>
        <strong id="metric-created">—</strong>
      </article>

      <article class="rh-admin-metric">
        <span>Used</span>
        <strong id="metric-used">—</strong>
      </article>

      <article class="rh-admin-metric">
        <span>Failures</span>
        <strong id="metric-failures">—</strong>
      </article>
    </section>

    <section class="rh-admin-card">
      <div class="rh-admin-section-heading">
        <div>
          <h2>Download link registry</h2>
          <p>
            Inspect generated CDAS download links, their lifecycle state, generated
            PDF evidence, and associated download events.
          </p>
        </div>

        <div class="rh-admin-actions">
          <button class="rh-button rh-button-secondary" id="refresh-button" type="button">
            Refresh
          </button>
        </div>
      </div>

      <form class="rh-admin-filters" id="filters-form">
        <label>
          Search
          <input id="filter-q" name="q" type="search" placeholder="Link ID, licence, email, holder, document…" />
        </label>

        <label>
          Status
          <select id="filter-status" name="status">
            <option value="">All statuses</option>
            <option value="created">created</option>
            <option value="active">active</option>
            <option value="used">used</option>
            <option value="expired">expired</option>
            <option value="revoked">revoked</option>
            <option value="failed">failed</option>
          </select>
        </label>

        <label>
          Licence ID
          <input id="filter-licence-id" name="licence_id" type="search" placeholder="lic_…" />
        </label>

        <div class="rh-admin-filter-actions">
          <button class="rh-button rh-button-primary" type="submit">
            Apply filters
          </button>
          <button class="rh-button rh-button-secondary" id="reset-filters" type="button">
            Reset
          </button>
        </div>
      </form>

      <div class="rh-admin-status" id="status-message" role="status" aria-live="polite">
        Ready.
      </div>

      <div class="rh-admin-table-wrap">
        <table class="rh-admin-table">
          <thead>
            <tr>
              <th>Download link</th>
              <th>Licence</th>
              <th>Recipient</th>
              <th>Status</th>
              <th>Lifecycle</th>
              <th>Events</th>
            </tr>
          </thead>
          <tbody id="links-body">
            <tr>
              <td colspan="6" class="rh-admin-empty">
                No records loaded yet.
              </td>
            </tr>
          </tbody>
        </table>
      </div>
    </section>

    <section class="rh-admin-card rh-admin-detail-card" id="detail-card" hidden>
      <div class="rh-admin-section-heading">
        <div>
          <h2>Download link detail</h2>
          <p id="detail-subtitle">
            Selected CDAS download link record.
          </p>
        </div>

        <button class="rh-button rh-button-secondary" id="close-detail" type="button">
          Close
        </button>
      </div>

      <div class="rh-admin-detail-layout">
        <section>
          <h3>Link metadata</h3>
          <div class="rh-detail-grid" id="detail-grid"></div>
        </section>

        <section>
          <h3>Generated PDF evidence</h3>
          <div class="rh-detail-grid" id="pdf-grid"></div>
        </section>

        <section>
          <h3>Safety controls</h3>
          <div class="rh-detail-grid" id="controls-grid"></div>
        </section>

        <section>
          <h3>Download events</h3>
          <div class="rh-event-list" id="event-list"></div>
        </section>
      </div>
    </section>
  </main>

  <style>
    .rh-admin-page {
      width: min(1180px, calc(100% - 2rem));
      margin: 0 auto;
      padding: 3rem 0 5rem;
    }

    .rh-admin-hero {
      margin-bottom: 1.5rem;
      padding: 2rem;
      border: 1px solid rgba(15, 23, 42, 0.12);
      border-radius: 1.5rem;
      background:
        radial-gradient(circle at top left, rgba(59, 130, 246, 0.12), transparent 36rem),
        linear-gradient(135deg, rgba(255,255,255,0.96), rgba(248,250,252,0.96));
      box-shadow: 0 24px 70px rgba(15, 23, 42, 0.08);
    }

    .rh-admin-hero h1 {
      margin: 0.35rem 0 0.75rem;
      font-size: clamp(2rem, 5vw, 3.5rem);
      line-height: 1;
      letter-spacing: -0.05em;
    }

    .rh-admin-hero p {
      max-width: 820px;
      margin: 0;
      color: rgba(15, 23, 42, 0.74);
      font-size: 1.05rem;
      line-height: 1.7;
    }

    .rh-eyebrow {
      margin: 0;
      color: #2563eb;
      font-size: 0.78rem;
      font-weight: 800;
      letter-spacing: 0.14em;
      text-transform: uppercase;
    }

    .rh-admin-card,
    .rh-admin-metric {
      border: 1px solid rgba(15, 23, 42, 0.12);
      border-radius: 1.25rem;
      background: rgba(255, 255, 255, 0.96);
      box-shadow: 0 18px 50px rgba(15, 23, 42, 0.07);
    }

    .rh-admin-card {
      padding: 1.25rem;
      margin-top: 1rem;
    }

    .rh-admin-section-heading {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 1rem;
    }

    .rh-admin-card h2,
    .rh-admin-section-heading h2 {
      margin: 0;
      font-size: 1.25rem;
      letter-spacing: -0.03em;
    }

    .rh-admin-card h3 {
      margin: 1.25rem 0 0.75rem;
      font-size: 1rem;
      letter-spacing: -0.02em;
    }

    .rh-admin-card p,
    .rh-admin-section-heading p {
      margin: 0.35rem 0 0;
      color: rgba(15, 23, 42, 0.67);
      line-height: 1.6;
    }

    .rh-admin-grid {
      display: grid;
      gap: 1rem;
    }

    .rh-admin-summary-grid {
      grid-template-columns: repeat(4, minmax(0, 1fr));
      margin: 1rem 0;
    }

    .rh-admin-metric {
      padding: 1rem;
    }

    .rh-admin-metric span {
      display: block;
      color: rgba(15, 23, 42, 0.62);
      font-size: 0.82rem;
      font-weight: 800;
      letter-spacing: 0.04em;
      text-transform: uppercase;
    }

    .rh-admin-metric strong {
      display: block;
      margin-top: 0.4rem;
      color: #0f172a;
      font-size: 2rem;
      line-height: 1;
    }

    .rh-admin-actions,
    .rh-admin-filter-actions,
    .rh-admin-row-actions {
      display: flex;
      gap: 0.5rem;
      flex-wrap: wrap;
    }

    .rh-admin-actions,
    .rh-admin-filter-actions {
      justify-content: flex-end;
    }

    .rh-admin-action-row td {
      padding-top: 0.75rem;
      padding-bottom: 0.9rem;
      background: #f8fafc;
      border-bottom: 1px solid rgba(15, 23, 42, 0.1);
    }

    .rh-admin-action-row .rh-admin-row-actions {
      justify-content: flex-start;
    }

    .rh-admin-action-row-label {
      color: rgba(15, 23, 42, 0.56);
      font-size: 0.76rem;
      font-weight: 900;
      letter-spacing: 0.06em;
      text-transform: uppercase;
    }

    .rh-admin-action-row-inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
      flex-wrap: wrap;
    }

    .rh-admin-filters {
      display: grid;
      grid-template-columns: 1.4fr 1fr 1fr;
      gap: 0.85rem;
      align-items: end;
      margin: 1.25rem 0 1rem;
    }

    .rh-admin-filters label {
      display: grid;
      gap: 0.35rem;
      color: rgba(15, 23, 42, 0.8);
      font-size: 0.88rem;
      font-weight: 700;
    }

    .rh-admin-filters input,
    .rh-admin-filters select {
      width: 100%;
      border: 1px solid rgba(15, 23, 42, 0.18);
      border-radius: 0.8rem;
      padding: 0.75rem 0.85rem;
      background: #fff;
      color: #0f172a;
      font: inherit;
    }

    .rh-admin-filter-actions {
      grid-column: 1 / -1;
    }

    .rh-button {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 2.75rem;
      border: 1px solid transparent;
      border-radius: 999px;
      padding: 0.65rem 1rem;
      font: inherit;
      font-weight: 800;
      cursor: pointer;
      transition:
        transform 150ms ease,
        background 150ms ease,
        border-color 150ms ease,
        color 150ms ease;
      white-space: nowrap;
      text-decoration: none;
    }

    .rh-button:hover {
      transform: translateY(-1px);
    }

    .rh-button-primary {
      background: #0f172a;
      color: #fff;
      border-color: #0f172a;
    }

    .rh-button-primary:hover {
      background: #1e293b;
      color: #fff;
    }

    .rh-button-secondary {
      background: #fff;
      color: #0f172a;
      border-color: rgba(15, 23, 42, 0.18);
    }

    .rh-button-secondary:hover {
      background: #f8fafc;
      color: #0f172a;
      border-color: rgba(15, 23, 42, 0.34);
    }

    .rh-button-danger {
      background: #991b1b;
      color: #fff;
      border-color: #991b1b;
    }

    .rh-button-danger:hover {
      background: #7f1d1d;
      color: #fff;
    }

    .rh-button[disabled] {
      cursor: not-allowed;
      opacity: 0.55;
      transform: none;
    }

    .rh-admin-status {
      margin: 1rem 0;
      padding: 0.85rem 1rem;
      border-radius: 0.9rem;
      background: #f8fafc;
      color: rgba(15, 23, 42, 0.75);
      font-size: 0.95rem;
      line-height: 1.6;
      overflow-wrap: anywhere;
    }

    .rh-admin-status[data-state="error"] {
      background: #fef2f2;
      color: #991b1b;
    }

    .rh-admin-status[data-state="success"] {
      background: #f0fdf4;
      color: #166534;
    }

    .rh-admin-table-wrap {
      overflow-x: auto;
      border: 1px solid rgba(15, 23, 42, 0.1);
      border-radius: 1rem;
    }

    .rh-admin-table {
      width: 100%;
      min-width: 1180px;
      border-collapse: collapse;
      background: #fff;
      font-size: 0.92rem;
    }

    .rh-admin-table th,
    .rh-admin-table td {
      padding: 0.85rem;
      border-bottom: 1px solid rgba(15, 23, 42, 0.08);
      text-align: left;
      vertical-align: top;
    }

    .rh-admin-table th {
      background: #f8fafc;
      color: rgba(15, 23, 42, 0.74);
      font-size: 0.76rem;
      font-weight: 900;
      letter-spacing: 0.06em;
      text-transform: uppercase;
    }

    .rh-admin-table tr:last-child td {
      border-bottom: 0;
    }

    .rh-admin-empty {
      text-align: center;
      color: rgba(15, 23, 42, 0.58);
    }

    .rh-stack {
      display: grid;
      gap: 0.2rem;
    }

    .rh-stack strong {
      color: #0f172a;
    }

    .rh-stack span {
      color: rgba(15, 23, 42, 0.66);
      font-size: 0.82rem;
      line-height: 1.45;
      word-break: break-word;
    }

    .rh-code {
      font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", monospace;
      font-size: 0.86rem;
      word-break: break-all;
    }

    .rh-badge {
      display: inline-flex;
      align-items: center;
      width: fit-content;
      border-radius: 999px;
      padding: 0.25rem 0.55rem;
      background: #f1f5f9;
      color: #334155;
      font-size: 0.78rem;
      font-weight: 800;
      white-space: nowrap;
    }

    .rh-badge-created {
      background: #e0f2fe;
      color: #075985;
    }

    .rh-badge-active {
      background: #dcfce7;
      color: #166534;
    }

    .rh-badge-used {
      background: #f1f5f9;
      color: #334155;
    }

    .rh-badge-expired,
    .rh-badge-revoked,
    .rh-badge-failed {
      background: #fee2e2;
      color: #991b1b;
    }

    .rh-admin-detail-card {
      margin-top: 1rem;
    }

    .rh-admin-detail-layout {
      display: grid;
      gap: 1rem;
      margin-top: 1rem;
    }

    .rh-detail-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 0.85rem;
    }

    .rh-detail-row {
      border: 1px solid rgba(15, 23, 42, 0.1);
      border-radius: 0.9rem;
      padding: 0.85rem;
      background: #f8fafc;
    }

    .rh-detail-row dt {
      color: rgba(15, 23, 42, 0.56);
      font-size: 0.76rem;
      font-weight: 900;
      letter-spacing: 0.06em;
      text-transform: uppercase;
    }

    .rh-detail-row dd {
      margin: 0.3rem 0 0;
      color: #0f172a;
      word-break: break-word;
      line-height: 1.5;
    }

    .rh-event-list {
      display: grid;
      gap: 0.75rem;
    }

    .rh-event-card {
      border: 1px solid rgba(15, 23, 42, 0.1);
      border-radius: 1rem;
      padding: 1rem;
      background: #f8fafc;
    }

    .rh-event-card h4 {
      margin: 0 0 0.5rem;
      font-size: 0.95rem;
    }

    .rh-event-card dl {
      display: grid;
      grid-template-columns: 150px 1fr;
      gap: 0.35rem 0.75rem;
      margin: 0;
      font-size: 0.88rem;
    }

    .rh-event-card dt {
      color: rgba(15, 23, 42, 0.56);
      font-weight: 800;
    }

    .rh-event-card dd {
      margin: 0;
      color: #0f172a;
      word-break: break-word;
    }

    @media (max-width: 960px) {
      .rh-admin-section-heading {
        display: grid;
      }

      .rh-admin-summary-grid,
      .rh-admin-filters,
      .rh-detail-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }

    @media (max-width: 640px) {
      .rh-admin-page {
        width: min(100% - 1rem, 1180px);
        padding-top: 1rem;
      }

      .rh-admin-hero,
      .rh-admin-card {
        padding: 1rem;
        border-radius: 1rem;
      }

      .rh-admin-summary-grid,
      .rh-admin-filters,
      .rh-detail-grid {
        grid-template-columns: 1fr;
      }

      .rh-admin-filter-actions .rh-button,
      .rh-admin-actions .rh-button,
      .rh-admin-row-actions .rh-button {
        width: 100%;
      }

      .rh-event-card dl {
        grid-template-columns: 1fr;
      }
    }
  </style>

  <script is:inline>
    // @ts-nocheck

    const TOKEN_STORAGE_KEY = "relayhub_admin_token";

    const state = {
      links: [],
      total: 0,
      limit: 100,
      offset: 0,
    };

    const filtersForm = document.getElementById("filters-form");
    const resetFiltersButton = document.getElementById("reset-filters");
    const refreshButton = document.getElementById("refresh-button");
    const statusMessage = document.getElementById("status-message");
    const linksBody = document.getElementById("links-body");

    const metricTotal = document.getElementById("metric-total");
    const metricCreated = document.getElementById("metric-created");
    const metricUsed = document.getElementById("metric-used");
    const metricFailures = document.getElementById("metric-failures");

    const detailCard = document.getElementById("detail-card");
    const detailSubtitle = document.getElementById("detail-subtitle");
    const closeDetailButton = document.getElementById("close-detail");
    const detailGrid = document.getElementById("detail-grid");
    const pdfGrid = document.getElementById("pdf-grid");
    const eventList = document.getElementById("event-list");
    const controlsGrid = document.getElementById("controls-grid");

    function getStoredToken() {
      return sessionStorage.getItem(TOKEN_STORAGE_KEY) || "";
    }

    function setStatus(message, mode = "neutral") {
      statusMessage.textContent = message;
      statusMessage.dataset.state = mode;
    }

    function normaliseResponseSnippet(value) {
      return String(value || "")
        .replace(/\s+/g, " ")
        .trim()
        .slice(0, 300);
    }

    async function readJsonResponse(response, endpoint = "admin API endpoint") {
      const contentType = response.headers.get("content-type") || "";
      const rawText = await response.text();
      const trimmed = rawText.trim();

      if (!trimmed) {
        return {};
      }

      const looksLikeJson = trimmed.startsWith("{") || trimmed.startsWith("[");

      if (!contentType.toLowerCase().includes("application/json") && !looksLikeJson) {
        const snippet = normaliseResponseSnippet(trimmed);

        throw new Error(
          `Expected JSON from ${endpoint}, but received HTTP ${response.status} ${response.statusText || ""} ` +
          `with content-type "${contentType || "unknown"}". Response starts: ${snippet || "empty response"}`
        );
      }

      try {
        return JSON.parse(trimmed);
      } catch (error) {
        const snippet = normaliseResponseSnippet(trimmed);

        throw new Error(
          `Invalid JSON from ${endpoint}. HTTP ${response.status} ${response.statusText || ""}. ` +
          `Response starts: ${snippet || "empty response"}`
        );
      }
    }

    function escapeHtml(value) {
      return String(value ?? "")
        .replaceAll("&", "&amp;")
        .replaceAll("<", "&lt;")
        .replaceAll(">", "&gt;")
        .replaceAll('"', "&quot;")
        .replaceAll("'", "&#039;");
    }

    function formatValue(value) {
      if (value === null || value === undefined || value === "") {
        return "—";
      }

      return String(value);
    }

    function formatDate(value) {
      if (!value) return "—";

      const date = new Date(value);

      if (Number.isNaN(date.getTime())) {
        return value;
      }

      return date.toLocaleString(undefined, {
        year: "numeric",
        month: "short",
        day: "2-digit",
        hour: "2-digit",
        minute: "2-digit",
      });
    }

    function booleanText(value) {
      return Number(value) === 1 || value === true ? "yes" : "no";
    }

    function badgeClass(value) {
      const text = String(value || "").toLowerCase();

      if (!text) return "rh-badge";

      return `rh-badge rh-badge-${text}`;
    }

    function canRevokeLink(row) {
      return row && row.status === "created" && !row.used_at;
    }

    async function fetchAdminJson(endpoint, token, options = {}) {
      const response = await fetch(endpoint, {
        method: options.method || "GET",
        headers: {
          Authorization: `Bearer ${token}`,
          Accept: "application/json",
          ...(options.headers || {}),
        },
        body: options.body,
        cache: "no-store",
      });

      const data = await readJsonResponse(response, response.url || "admin API endpoint");

      return { response, data };
    }

    function getFilters() {
      const formData = new FormData(filtersForm);
      const params = new URLSearchParams();

      for (const [key, value] of formData.entries()) {
        const clean = String(value || "").trim();

        if (clean) {
          params.set(key, clean);
        }
      }

      params.set("limit", String(state.limit));
      params.set("offset", String(state.offset));

      return params;
    }

    async function fetchLinks() {
      const token = getStoredToken();

      if (!token) {
        setStatus("Admin token is missing. Open another admin page and enter it once.", "error");
        renderLinks([]);
        updateMetrics([]);
        return;
      }

      const params = getFilters();
      const endpoint = `/api/admin/cdas/download-links?${params.toString()}`;

      setStatus("Loading CDAS download links…");

      let response;
      let data;

      try {
        const result = await fetchAdminJson(endpoint, token);
        response = result.response;
        data = result.data;
      } catch (error) {
        setStatus(`Could not load CDAS download links: ${error.message}`, "error");
        renderLinks([]);
        updateMetrics([]);
        return;
      }

      if (!response.ok || !data.ok) {
        setStatus(
          data?.message || data?.error || `CDAS download links could not be loaded. HTTP ${response.status}.`,
          "error"
        );

        renderLinks([]);
        updateMetrics([]);
        return;
      }

      state.links = Array.isArray(data.rows) ? data.rows : [];
      state.total = Number(data.total || state.links.length || 0);

      renderLinks(state.links);
      updateMetrics(state.links);

      setStatus(
        `Loaded ${state.links.length} CDAS download link record(s). Total matching records: ${state.total}.`,
        "success"
      );
    }

    function updateMetrics(rows) {
      const created = rows.filter((row) => row.status === "created").length;
      const used = rows.filter((row) => row.status === "used").length;
      const failures = rows.reduce(
        (count, row) => count + Number(row.events?.failure_count || 0),
        0
      );

      metricTotal.textContent = String(state.total || rows.length || 0);
      metricCreated.textContent = String(created);
      metricUsed.textContent = String(used);
      metricFailures.textContent = String(failures);
    }

    function renderLinks(rows) {
      if (!rows.length) {
        linksBody.innerHTML = `
          <tr>
            <td colspan="6" class="rh-admin-empty">
              No CDAS download links found.
            </td>
          </tr>
        `;
        return;
      }

      linksBody.innerHTML = rows
        .map((row) => {
          const revokeButton = canRevokeLink(row)
            ? `
              <button
                class="rh-button rh-button-danger"
                type="button"
                data-revoke-download-link="${escapeHtml(row.id)}"
              >
                Revoke
              </button>
            `
            : `
              <button
                class="rh-button rh-button-secondary"
                type="button"
                disabled
                aria-disabled="true"
                title="Only unused created links can be revoked."
              >
                Revoke
              </button>
            `;

          return `
            <tr>
              <td>
                <div class="rh-stack">
                  <strong class="rh-code">${escapeHtml(row.id)}</strong>
                  <span>Token hash present: ${escapeHtml(booleanText(row.token_hash_present))}</span>
                  <span>Hash length: ${escapeHtml(formatValue(row.token_hash_length))}</span>
                </div>
              </td>

              <td>
                <div class="rh-stack">
                  <strong>${escapeHtml(formatValue(row.licence_number))}</strong>
                  <span class="rh-code">${escapeHtml(formatValue(row.licence_id))}</span>
                  <span>${escapeHtml(formatValue(row.document_id))} v${escapeHtml(formatValue(row.document_version))}</span>
                </div>
              </td>

              <td>
                <div class="rh-stack">
                  <strong>${escapeHtml(formatValue(row.licence_holder_name))}</strong>
                  <span>${escapeHtml(formatValue(row.recipient_email))}</span>
                  <span>${escapeHtml(formatValue(row.organisation_name))}</span>
                </div>
              </td>

              <td>
                <span class="${badgeClass(row.status)}">
                  ${escapeHtml(formatValue(row.status))}
                </span>
              </td>

              <td>
                <div class="rh-stack">
                  <span>Created: ${escapeHtml(formatDate(row.created_at))}</span>
                  <span>Expires: ${escapeHtml(formatDate(row.expires_at))}</span>
                  <span>Used: ${escapeHtml(formatDate(row.used_at))}</span>
                  <span>Failure: ${escapeHtml(formatValue(row.failure_reason))}</span>
                </div>
              </td>

              <td>
                <div class="rh-stack">
                  <strong>${escapeHtml(formatValue(row.events?.event_count))} event(s)</strong>
                  <span>Success: ${escapeHtml(formatValue(row.events?.success_count))}</span>
                  <span>Failure: ${escapeHtml(formatValue(row.events?.failure_count))}</span>
                  <span>Last: ${escapeHtml(formatDate(row.events?.last_event_at))}</span>
                </div>
              </td>
            </tr>

            <tr class="rh-admin-action-row">
              <td colspan="6">
                <div class="rh-admin-action-row-inner">
                  <span class="rh-admin-action-row-label">
                    Actions for ${escapeHtml(row.id)}
                  </span>

                  <div class="rh-admin-row-actions">
                    <button
                      class="rh-button rh-button-secondary"
                      type="button"
                      data-view-download-link="${escapeHtml(row.id)}"
                    >
                      View
                    </button>

                    ${revokeButton}
                  </div>
                </div>
              </td>
            </tr>
          `;
        })
        .join("");
    }

    function detailRow(label, value, options = {}) {
      const codeClass = options.code ? "rh-code" : "";

      return `
        <dl class="rh-detail-row">
          <dt>${escapeHtml(label)}</dt>
          <dd class="${codeClass}">
            ${escapeHtml(formatValue(value))}
          </dd>
        </dl>
      `;
    }

    async function renderDetail(linkId) {
      const token = getStoredToken();

      if (!token) {
        setStatus("Admin token is missing. Open another admin page and enter it once.", "error");
        return;
      }

      const endpoint = `/api/admin/cdas/download-links/${encodeURIComponent(linkId)}`;

      setStatus("Loading download link detail…");

      let response;
      let data;

      try {
        const result = await fetchAdminJson(endpoint, token);
        response = result.response;
        data = result.data;
      } catch (error) {
        setStatus(`Could not load download link detail: ${error.message}`, "error");
        return;
      }

      if (!response.ok || !data.ok || !data.link) {
        setStatus(
          data?.message || data?.error || `Download link detail could not be loaded. HTTP ${response.status}.`,
          "error"
        );
        return;
      }

      const link = data.link;
      const pdf = data.generated_pdf || {};
      const events = Array.isArray(data.events) ? data.events : [];
      const controls = data.controls || {};

      detailSubtitle.textContent = `${link.id} — ${link.status}`;

      detailGrid.innerHTML = [
        detailRow("Download link ID", link.id, { code: true }),
        detailRow("Status", link.status),
        detailRow("Token hash present", booleanText(link.token_hash_present)),
        detailRow("Token hash length", link.token_hash_length),
        detailRow("Licence ID", link.licence_id, { code: true }),
        detailRow("Licence number", link.licence_number),
        detailRow("Document ID", link.document_id),
        detailRow("Document version", link.document_version),
        detailRow("Licence holder", link.licence_holder_name),
        detailRow("Recipient email", link.recipient_email),
        detailRow("Organisation", link.organisation_name),
        detailRow("Created at", formatDate(link.created_at)),
        detailRow("Expires at", formatDate(link.expires_at)),
        detailRow("Used at", formatDate(link.used_at)),
        detailRow("Failure reason", link.failure_reason),
      ].join("");

      pdfGrid.innerHTML = [
        detailRow("Generated object", pdf.generated_object, { code: true }),
        detailRow("Generated SHA-256", pdf.generated_sha256, { code: true }),
        detailRow("Generated size", pdf.generated_size),
        detailRow("Generated at", formatDate(pdf.generated_at)),
        detailRow("Generated by", pdf.generated_by),
        detailRow("R2 object present", booleanText(pdf.generated_object_present)),
        detailRow("SHA present", booleanText(pdf.generated_sha256_present)),
      ].join("");

      controlsGrid.innerHTML = [
        detailRow("Can download", booleanText(controls.can_download)),
        detailRow("Can revoke", booleanText(controls.can_revoke)),
        detailRow("Can reissue", booleanText(controls.can_reissue)),
        detailRow("Can prepare delivery", booleanText(controls.can_prepare_delivery)),
        detailRow("Can send delivery email", booleanText(controls.can_send_delivery_email)),
        detailRow("Requires raw landing URL", booleanText(controls.requires_raw_landing_url)),
      ].join("");

      if (!events.length) {
        eventList.innerHTML = `
          <div class="rh-admin-empty">
            No download events recorded for this link.
          </div>
        `;
      } else {
        eventList.innerHTML = events
          .map((event) => {
            return `
              <article class="rh-event-card">
                <h4>${escapeHtml(formatValue(event.event_type))}</h4>
                <dl>
                  <dt>Event ID</dt>
                  <dd class="rh-code">${escapeHtml(formatValue(event.id))}</dd>

                  <dt>Occurred at</dt>
                  <dd>${escapeHtml(formatDate(event.created_at))}</dd>

                  <dt>Success</dt>
                  <dd>${escapeHtml(booleanText(event.success))}</dd>

                  <dt>Failure reason</dt>
                  <dd>${escapeHtml(formatValue(event.failure_reason))}</dd>

                  <dt>IP hash</dt>
                  <dd class="rh-code">${escapeHtml(formatValue(event.ip_hash))}</dd>

                  <dt>User agent</dt>
                  <dd>${escapeHtml(formatValue(event.user_agent))}</dd>
                </dl>
              </article>
            `;
          })
          .join("");
      }

      detailCard.hidden = false;
      detailCard.scrollIntoView({ behavior: "smooth", block: "start" });

      setStatus("Download link detail loaded.", "success");
    }

    async function revokeDownloadLink(linkId) {
      const token = getStoredToken();

      if (!token) {
        setStatus("Admin token is missing. Open another admin page and enter it once.", "error");
        return;
      }

      const row = state.links.find((item) => item.id === linkId);

      if (!canRevokeLink(row)) {
        setStatus("Only unused created download links can be revoked from this page.", "error");
        return;
      }

      const reason = window.prompt(
        `Enter a revocation reason for download link ${linkId}:`,
        "Admin revoked unused download link before delivery."
      );

      if (reason === null) {
        return;
      }

      const cleanReason = reason.trim();

      if (!cleanReason) {
        setStatus("Revocation reason is required.", "error");
        return;
      }

      const endpoint = `/api/admin/cdas/download-links/${encodeURIComponent(linkId)}/revoke`;

      setStatus("Revoking download link…");

      let response;
      let data;

      try {
        const result = await fetchAdminJson(endpoint, token, {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
          },
          body: JSON.stringify({
            reason: cleanReason,
          }),
        });

        response = result.response;
        data = result.data;
      } catch (error) {
        setStatus(`Could not revoke download link: ${error.message}`, "error");
        return;
      }

      if (!response.ok || !data.ok) {
        setStatus(
          data?.message || data?.error || `Download link could not be revoked. HTTP ${response.status}.`,
          "error"
        );
        return;
      }

      setStatus(data.message || "Download link revoked successfully.", "success");
      await fetchLinks();

      if (!detailCard.hidden) {
        detailCard.hidden = true;
      }
    }

    filtersForm.addEventListener("submit", (event) => {
      event.preventDefault();
      state.offset = 0;
      fetchLinks();
    });

    resetFiltersButton.addEventListener("click", () => {
      filtersForm.reset();
      state.offset = 0;
      fetchLinks();
    });

    refreshButton.addEventListener("click", () => {
      fetchLinks();
    });

    linksBody.addEventListener("click", (event) => {
      const target = event.target;

      if (!(target instanceof HTMLElement)) {
        return;
      }

      const viewButton = target.closest("[data-view-download-link]");

      if (viewButton instanceof HTMLElement) {
        const linkId = viewButton.dataset.viewDownloadLink;

        if (linkId) {
          renderDetail(linkId);
        }

        return;
      }

      const revokeButton = target.closest("[data-revoke-download-link]");

      if (revokeButton instanceof HTMLElement) {
        const linkId = revokeButton.dataset.revokeDownloadLink;

        if (linkId) {
          revokeDownloadLink(linkId);
        }
      }
    });

    closeDetailButton.addEventListener("click", () => {
      detailCard.hidden = true;
    });

    const existingToken = getStoredToken();

    if (existingToken) {
      setStatus("Admin token found in this browser session. Loading CDAS download links…");
      fetchLinks();
    } else {
      setStatus("Admin token is missing. Open another admin page and enter it once.", "error");
    }

    window.relayhubAdminTokenUpdated = () => {
      fetchLinks();
    };

    window.relayhubAdminTokenCleared = () => {
      location.reload();
    };
  </script>
</BaseLayout>