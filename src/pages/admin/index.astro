---
import BaseLayout from "../../layouts/BaseLayout.astro";

const adminCards = [
  {
    href: "/admin/downloads",
    title: "Download Analytics",
    eyebrow: "Downloads",
    description:
      "View legacy download analytics, personalised download registry records, generated PDF cache status, and operational download evidence.",
  },
  {
    href: "/admin/newsletter",
    title: "Newsletter Signups",
    eyebrow: "Newsletter",
    description:
      "Review RelayHub newsletter signups and export signup records.",
  },
  {
    href: "/admin/contact",
    title: "Contact Messages",
    eyebrow: "Contact",
    description:
      "Review submitted contact messages and operational enquiries.",
  },
  {
    href: "/admin/cdas-documents",
    title: "CDAS Documents",
    eyebrow: "Controlled Document Access",
    description:
      "View imported CDAS document records, access classes, classifications, licence template assignments, and rendered licence previews.",
  },
  {
    href: "/admin/cdas-licence-terms",
    title: "CDAS Licence Terms",
    eyebrow: "Controlled Document Access",
    description:
      "View versioned CDAS licence templates, including public distribution, personal use, commercial use, and enterprise redistribution templates.",
  },
];
---

<BaseLayout
  title="Admin | RelayHub"
  description="RelayHub private admin hub."
  noindex={true}
>
  <main class="rh-admin-page">
    <section class="rh-admin-hero">
      <p class="rh-eyebrow">RelayHub Admin</p>
      <h1>Admin Hub</h1>
      <p>
        Private operational entry point for RelayHub administrative tools.
        This page links to existing admin screens only; it does not expose new
        public functionality, issue licences, approve downloads, or alter records.
      </p>
    </section>

    <section class="rh-admin-card rh-admin-token-card">
      <div>
        <h2>Admin token status</h2>
        <p id="token-status">
          Checking browser session…
        </p>
      </div>

      <div class="rh-admin-token-actions">
        <button class="rh-button rh-button-secondary" id="clear-token" type="button">
          Clear session token
        </button>
      </div>
    </section>

    <section class="rh-admin-grid" aria-label="Admin tools">
      {adminCards.map((card) => (
        <a class="rh-admin-tool-card" href={card.href}>
          <span>{card.eyebrow}</span>
          <strong>{card.title}</strong>
          <p>{card.description}</p>
        </a>
      ))}
    </section>
  </main>

  <style>
    .rh-admin-page {
      width: min(1180px, calc(100% - 2rem));
      margin: 0 auto;
      padding: 3rem 0 5rem;
    }

    .rh-admin-hero {
      margin-bottom: 1.5rem;
      padding: 2rem;
      border: 1px solid rgba(15, 23, 42, 0.12);
      border-radius: 1.5rem;
      background:
        radial-gradient(circle at top left, rgba(59, 130, 246, 0.12), transparent 36rem),
        linear-gradient(135deg, rgba(255,255,255,0.96), rgba(248,250,252,0.96));
      box-shadow: 0 24px 70px rgba(15, 23, 42, 0.08);
    }

    .rh-admin-hero h1 {
      margin: 0.35rem 0 0.75rem;
      font-size: clamp(2rem, 5vw, 3.5rem);
      line-height: 1;
      letter-spacing: -0.05em;
    }

    .rh-admin-hero p {
      max-width: 760px;
      margin: 0;
      color: rgba(15, 23, 42, 0.74);
      font-size: 1.05rem;
      line-height: 1.7;
    }

    .rh-eyebrow {
      margin: 0;
      color: #2563eb;
      font-size: 0.78rem;
      font-weight: 800;
      letter-spacing: 0.14em;
      text-transform: uppercase;
    }

    .rh-admin-card,
    .rh-admin-tool-card {
      border: 1px solid rgba(15, 23, 42, 0.12);
      border-radius: 1.25rem;
      background: rgba(255, 255, 255, 0.96);
      box-shadow: 0 18px 50px rgba(15, 23, 42, 0.07);
    }

    .rh-admin-card {
      padding: 1.25rem;
      margin-bottom: 1rem;
    }

    .rh-admin-token-card {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 1rem;
    }

    .rh-admin-card h2 {
      margin: 0;
      font-size: 1.25rem;
      letter-spacing: -0.03em;
    }

    .rh-admin-card p {
      margin: 0.35rem 0 0;
      color: rgba(15, 23, 42, 0.67);
      line-height: 1.6;
    }

    .rh-admin-token-actions {
      display: flex;
      gap: 0.5rem;
      flex-wrap: wrap;
      justify-content: flex-end;
    }

    .rh-button {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 2.75rem;
      border: 1px solid transparent;
      border-radius: 999px;
      padding: 0.65rem 1rem;
      font: inherit;
      font-weight: 800;
      cursor: pointer;
      transition:
        transform 150ms ease,
        background 150ms ease,
        border-color 150ms ease,
        color 150ms ease;
      white-space: nowrap;
    }

    .rh-button:hover {
      transform: translateY(-1px);
    }

    .rh-button-secondary {
      background: #fff;
      color: #0f172a;
      border-color: rgba(15, 23, 42, 0.18);
    }

    .rh-button-secondary:hover {
      background: #f8fafc;
      color: #0f172a;
      border-color: rgba(15, 23, 42, 0.34);
    }

    .rh-admin-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 1rem;
    }

    .rh-admin-tool-card {
      display: grid;
      gap: 0.45rem;
      padding: 1.25rem;
      color: inherit;
      text-decoration: none;
      transition:
        transform 150ms ease,
        border-color 150ms ease,
        box-shadow 150ms ease;
    }

    .rh-admin-tool-card:hover {
      transform: translateY(-2px);
      border-color: rgba(37, 99, 235, 0.35);
      box-shadow: 0 24px 70px rgba(15, 23, 42, 0.11);
    }

    .rh-admin-tool-card span {
      color: #2563eb;
      font-size: 0.76rem;
      font-weight: 900;
      letter-spacing: 0.09em;
      text-transform: uppercase;
    }

    .rh-admin-tool-card strong {
      color: #0f172a;
      font-size: 1.25rem;
      letter-spacing: -0.03em;
    }

    .rh-admin-tool-card p {
      margin: 0;
      color: rgba(15, 23, 42, 0.68);
      line-height: 1.6;
    }

    @media (max-width: 760px) {
      .rh-admin-token-card {
        display: grid;
      }

      .rh-admin-token-actions {
        justify-content: stretch;
      }

      .rh-admin-token-actions .rh-button {
        width: 100%;
      }

      .rh-admin-grid {
        grid-template-columns: 1fr;
      }
    }

    @media (max-width: 640px) {
      .rh-admin-page {
        width: min(100% - 1rem, 1180px);
        padding-top: 1rem;
      }

      .rh-admin-hero,
      .rh-admin-card,
      .rh-admin-tool-card {
        padding: 1rem;
        border-radius: 1rem;
      }
    }
  </style>

  <script is:inline>
    // @ts-nocheck

    const TOKEN_STORAGE_KEY = "relayhub_admin_token";

    const tokenStatus = document.getElementById("token-status");
    const clearTokenButton = document.getElementById("clear-token");

    function updateTokenStatus() {
      const token = sessionStorage.getItem(TOKEN_STORAGE_KEY);

      if (token) {
        tokenStatus.textContent =
          "Admin token is loaded in this browser session. CDAS admin pages will use it automatically.";
      } else {
        tokenStatus.textContent =
          "No admin token is loaded in this browser session. Open an existing admin page that accepts the token, or set sessionStorage['relayhub_admin_token'].";
      }
    }

    clearTokenButton.addEventListener("click", () => {
      sessionStorage.removeItem(TOKEN_STORAGE_KEY);
      updateTokenStatus();
    });

    updateTokenStatus();
  </script>
</BaseLayout>