---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Contact Admin | RelayHub"
  description="Private RelayHub contact message management page."
  noindex={true}
>
  <section class="rh-section">
    <div class="rh-container">
      <p class="rh-kicker">Admin</p>

      <h1 class="rh-section-title">Contact messages</h1>

      <p class="rh-section-lead">
        Private admin page for checking contact form messages, searching records,
        and exporting CSV data.
      </p>

      <div class="rh-card" style="margin-top: var(--space-8);">
        <label class="rh-label" for="admin-token">Admin token</label>
        <input
          class="rh-input"
          id="admin-token"
          type="password"
          placeholder="Paste admin token"
        />

        <div style="height: var(--space-5);"></div>

        <label class="rh-label" for="search">Search</label>
        <input
          class="rh-input"
          id="search"
          type="search"
          placeholder="Search name, email, topic, or message"
        />

        <div class="rh-actions">
          <button class="rh-button rh-button-primary" type="button" id="load-messages">
            Load messages
          </button>

          <button class="rh-button rh-button-secondary" type="button" id="export-csv">
            Export CSV
          </button>
        </div>
      </div>

      <div class="rh-card" style="margin-top: var(--space-8);">
        <h2 class="rh-card-title">Summary</h2>
        <p class="rh-card-text" id="summary">No data loaded yet.</p>
      </div>

      <div class="rh-card" style="margin-top: var(--space-8); overflow-x: auto;">
        <h2 class="rh-card-title">Latest messages</h2>

        <table class="rh-admin-table">
          <thead>
            <tr>
              <th>ID</th>
              <th>Created</th>
              <th>Name</th>
              <th>Email</th>
              <th>Topic</th>
              <th>Message</th>
            </tr>
          </thead>
          <tbody id="message-table">
            <tr>
              <td colspan="6">No records loaded.</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <script>
    const tokenInput =
      document.querySelector<HTMLInputElement>("#admin-token");

    const searchInput =
      document.querySelector<HTMLInputElement>("#search");

    const loadButton =
      document.querySelector<HTMLButtonElement>("#load-messages");

    const exportButton =
      document.querySelector<HTMLButtonElement>("#export-csv");

    const summary =
      document.querySelector<HTMLElement>("#summary");

    const table =
      document.querySelector<HTMLElement>("#message-table");

    async function loadMessages() {
      if (!tokenInput || !searchInput || !summary || !table) {
        return;
      }

      const token = tokenInput.value.trim();
      const q = searchInput.value.trim();

      if (!token) {
        summary.textContent = "Admin token is required.";
        return;
      }

      const params = new URLSearchParams();

      if (q) {
        params.set("q", q);
      }

      const response = await fetch(`/api/admin/contact?${params.toString()}`, {
        headers: {
          Authorization: `Bearer ${token}`,
        },
      });

      if (!response.ok) {
        summary.textContent = `Request failed: ${response.status}`;
        return;
      }

      const data = await response.json();

      summary.textContent =
        `${data.total} total contact message(s). Showing ${data.messages.length}.`;

      table.innerHTML = "";

      if (!data.messages.length) {
        table.innerHTML = `<tr><td colspan="6">No records found.</td></tr>`;
        return;
      }

      for (const message of data.messages) {
        const row = document.createElement("tr");

        row.innerHTML = `
          <td>${escapeHtml(String(message.id ?? ""))}</td>
          <td>${escapeHtml(message.created_at ?? "")}</td>
          <td>${escapeHtml(message.name ?? "")}</td>
          <td>${escapeHtml(message.email ?? "")}</td>
          <td>${escapeHtml(message.topic ?? "")}</td>
          <td>${escapeHtml(message.message ?? "")}</td>
        `;

        table.appendChild(row);
      }
    }

    function exportCsv() {
      if (!tokenInput || !searchInput || !summary) {
        return;
      }

      const token = tokenInput.value.trim();
      const q = searchInput.value.trim();

      if (!token) {
        summary.textContent = "Admin token is required.";
        return;
      }

      const params = new URLSearchParams();

      if (q) {
        params.set("q", q);
      }

      params.set("token", token);

      window.location.href = `/api/admin/contact.csv?${params.toString()}`;
    }

    function escapeHtml(value: string): string {
      const replacements: Record<string, string> = {
        "&": "&amp;",
        "<": "&lt;",
        ">": "&gt;",
        '"': "&quot;",
        "'": "&#039;",
      };

      return value.replace(
        /[&<>"']/g,
        (char: string) => replacements[char] ?? char
      );
    }

    loadButton?.addEventListener("click", loadMessages);
    exportButton?.addEventListener("click", exportCsv);
  </script>
</BaseLayout>