---
import BaseLayout from "../../layouts/BaseLayout.astro";

const pageTitle = "CDAS Documents Admin";
const pageDescription =
  "Read-only admin view for RelayHub Controlled Document Access System document records.";
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <main class="rh-admin-page">
    <section class="rh-admin-hero">
      <p class="rh-eyebrow">RelayHub Admin</p>
      <h1>CDAS Documents</h1>
      <p>
        Read-only view of the Controlled Document Access System document registry.
        This page does not issue licences, change document policy, revoke access, or
        alter the legacy download system.
      </p>
    </section>

    <section class="rh-admin-grid rh-admin-summary-grid" aria-label="CDAS document summary">
      <article class="rh-admin-metric">
        <span>Total records</span>
        <strong id="metric-total">—</strong>
      </article>

      <article class="rh-admin-metric">
        <span>Active</span>
        <strong id="metric-active">—</strong>
      </article>

      <article class="rh-admin-metric">
        <span>Listed</span>
        <strong id="metric-listed">—</strong>
      </article>

      <article class="rh-admin-metric">
        <span>Requires approval</span>
        <strong id="metric-approval">—</strong>
      </article>
    </section>

    <section class="rh-admin-card">
      <div class="rh-admin-section-heading">
        <div>
          <h2>Document registry</h2>
          <p>
            Search and filter the CDAS document records imported from the R2 catalogue.
          </p>
        </div>

        <div class="rh-admin-actions">
          <button class="rh-button rh-button-secondary" id="refresh-button" type="button">
            Refresh
          </button>
        </div>
      </div>

      <form class="rh-admin-filters" id="filters-form">
        <label>
          Search
          <input id="filter-q" name="q" type="search" placeholder="Title, slug, source object…" />
        </label>

        <label>
          Status
          <select id="filter-status" name="status">
            <option value="">All statuses</option>
            <option value="active">active</option>
            <option value="draft">draft</option>
            <option value="review">review</option>
            <option value="superseded">superseded</option>
            <option value="withdrawn">withdrawn</option>
            <option value="retired">retired</option>
            <option value="archived">archived</option>
            <option value="restricted">restricted</option>
            <option value="disabled">disabled</option>
          </select>
        </label>

        <label>
          Classification
          <select id="filter-classification" name="classification">
            <option value="">All classifications</option>
            <option value="public_open">public_open</option>
            <option value="public_licensed">public_licensed</option>
            <option value="controlled">controlled</option>
            <option value="restricted">restricted</option>
            <option value="confidential">confidential</option>
            <option value="retired_public">retired_public</option>
            <option value="withdrawn">withdrawn</option>
            <option value="internal_only">internal_only</option>
          </select>
        </label>

        <label>
          Access class
          <select id="filter-access-class" name="access_class">
            <option value="">All access classes</option>
            <option value="direct_public">direct_public</option>
            <option value="verified_public">verified_public</option>
            <option value="licensed_public">licensed_public</option>
            <option value="controlled_verified">controlled_verified</option>
            <option value="approval_required">approval_required</option>
            <option value="invite_only">invite_only</option>
            <option value="paid_verified">paid_verified</option>
            <option value="disabled">disabled</option>
          </select>
        </label>

        <label>
          Listed
          <select id="filter-listed" name="listed">
            <option value="">Listed and unlisted</option>
            <option value="1">Listed only</option>
            <option value="0">Unlisted only</option>
          </select>
        </label>

        <div class="rh-admin-filter-actions">
          <button class="rh-button rh-button-primary" type="submit">
            Apply filters
          </button>
          <button class="rh-button rh-button-secondary" id="reset-filters" type="button">
            Reset
          </button>
        </div>
      </form>

      <div class="rh-admin-status" id="status-message" role="status" aria-live="polite">
        Ready.
      </div>

      <div class="rh-admin-table-wrap">
        <table class="rh-admin-table">
          <thead>
            <tr>
              <th>Document</th>
              <th>Version</th>
              <th>Status</th>
              <th>Classification</th>
              <th>Access class</th>
              <th>Terms</th>
              <th>Policy</th>
              <th>Updated</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody id="documents-body">
            <tr>
              <td colspan="9" class="rh-admin-empty">
                No records loaded yet.
              </td>
            </tr>
          </tbody>
        </table>
      </div>
    </section>

    <section class="rh-admin-card rh-admin-detail-card" id="detail-card" hidden>
      <div class="rh-admin-section-heading">
        <div>
          <h2>Document detail</h2>
          <p id="detail-subtitle">
            Selected CDAS document record.
          </p>
        </div>

        <button class="rh-button rh-button-secondary" id="close-detail" type="button">
          Close
        </button>
      </div>

      <div class="rh-admin-detail-grid" id="detail-grid"></div>
    </section>

    <section class="rh-admin-card rh-admin-detail-card" id="licence-preview-card" hidden>
      <div class="rh-admin-section-heading">
        <div>
          <h2>Rendered licence preview</h2>
          <p id="licence-preview-subtitle">
            Document-specific licence preview.
          </p>
        </div>

        <button class="rh-button rh-button-secondary" id="close-licence-preview" type="button">
          Close
        </button>
      </div>

      <div class="rh-admin-detail-grid">
        <dl class="rh-admin-detail-item">
          <dt>Terms version</dt>
          <dd id="licence-preview-version">—</dd>
        </dl>

        <dl class="rh-admin-detail-item">
          <dt>Rendered SHA-256</dt>
          <dd id="licence-preview-sha">—</dd>
        </dl>

        <dl class="rh-admin-detail-item">
          <dt>Unresolved placeholders</dt>
          <dd id="licence-preview-unresolved">—</dd>
        </dl>

        <dl class="rh-admin-detail-item">
          <dt>Template placeholders</dt>
          <dd id="licence-preview-placeholders">—</dd>
        </dl>
      </div>

      <article class="rh-admin-body-panel">
        <h3>Rendered licence body</h3>
        <pre id="licence-preview-body"></pre>
      </article>
    </section>
  </main>

  <style>
    .rh-admin-page {
      width: min(1180px, calc(100% - 2rem));
      margin: 0 auto;
      padding: 3rem 0 5rem;
    }

    .rh-admin-hero {
      margin-bottom: 1.5rem;
      padding: 2rem;
      border: 1px solid rgba(15, 23, 42, 0.12);
      border-radius: 1.5rem;
      background:
        radial-gradient(circle at top left, rgba(59, 130, 246, 0.12), transparent 36rem),
        linear-gradient(135deg, rgba(255,255,255,0.96), rgba(248,250,252,0.96));
      box-shadow: 0 24px 70px rgba(15, 23, 42, 0.08);
    }

    .rh-admin-hero h1 {
      margin: 0.35rem 0 0.75rem;
      font-size: clamp(2rem, 5vw, 3.5rem);
      line-height: 1;
      letter-spacing: -0.05em;
    }

    .rh-admin-hero p {
      max-width: 760px;
      margin: 0;
      color: rgba(15, 23, 42, 0.74);
      font-size: 1.05rem;
      line-height: 1.7;
    }

    .rh-eyebrow {
      margin: 0;
      color: #2563eb;
      font-size: 0.78rem;
      font-weight: 800;
      letter-spacing: 0.14em;
      text-transform: uppercase;
    }

    .rh-admin-card,
    .rh-admin-metric {
      border: 1px solid rgba(15, 23, 42, 0.12);
      border-radius: 1.25rem;
      background: rgba(255, 255, 255, 0.96);
      box-shadow: 0 18px 50px rgba(15, 23, 42, 0.07);
    }

    .rh-admin-card {
      padding: 1.25rem;
      margin-top: 1rem;
    }

    .rh-admin-section-heading {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 1rem;
    }

    .rh-admin-card h2,
    .rh-admin-section-heading h2 {
      margin: 0;
      font-size: 1.25rem;
      letter-spacing: -0.03em;
    }

    .rh-admin-card p,
    .rh-admin-section-heading p {
      margin: 0.35rem 0 0;
      color: rgba(15, 23, 42, 0.67);
      line-height: 1.6;
    }

    .rh-admin-filters label {
      display: grid;
      gap: 0.35rem;
      color: rgba(15, 23, 42, 0.8);
      font-size: 0.88rem;
      font-weight: 700;
    }

    .rh-admin-filters input,
    .rh-admin-filters select {
      width: 100%;
      border: 1px solid rgba(15, 23, 42, 0.18);
      border-radius: 0.8rem;
      padding: 0.75rem 0.85rem;
      background: #fff;
      color: #0f172a;
      font: inherit;
    }

    .rh-button {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 2.75rem;
      border: 1px solid transparent;
      border-radius: 999px;
      padding: 0.65rem 1rem;
      font: inherit;
      font-weight: 800;
      cursor: pointer;
      transition:
        transform 150ms ease,
        background 150ms ease,
        border-color 150ms ease,
        color 150ms ease;
      white-space: nowrap;
    }

    .rh-button:hover {
      transform: translateY(-1px);
    }

    .rh-button-primary {
      background: #0f172a;
      color: #fff;
      border-color: #0f172a;
    }

    .rh-button-primary:hover {
      background: #1e293b;
      color: #fff;
    }

    .rh-button-secondary {
      background: #fff;
      color: #0f172a;
      border-color: rgba(15, 23, 42, 0.18);
    }

    .rh-button-secondary:hover {
      background: #f8fafc;
      color: #0f172a;
      border-color: rgba(15, 23, 42, 0.34);
    }

    .rh-admin-grid {
      display: grid;
      gap: 1rem;
    }

    .rh-admin-summary-grid {
      grid-template-columns: repeat(4, minmax(0, 1fr));
      margin: 1rem 0;
    }

    .rh-admin-metric {
      padding: 1rem;
    }

    .rh-admin-metric span {
      display: block;
      color: rgba(15, 23, 42, 0.62);
      font-size: 0.82rem;
      font-weight: 800;
      letter-spacing: 0.04em;
      text-transform: uppercase;
    }

    .rh-admin-metric strong {
      display: block;
      margin-top: 0.4rem;
      color: #0f172a;
      font-size: 2rem;
      line-height: 1;
    }

    .rh-admin-actions {
      display: flex;
      gap: 0.5rem;
      flex-wrap: wrap;
      justify-content: flex-end;
    }

    .rh-admin-filters {
      display: grid;
      grid-template-columns: 1.4fr repeat(4, minmax(150px, 1fr));
      gap: 0.85rem;
      align-items: end;
      margin: 1.25rem 0 1rem;
    }

    .rh-admin-filter-actions {
      display: flex;
      gap: 0.5rem;
      grid-column: 1 / -1;
      justify-content: flex-end;
      flex-wrap: wrap;
    }

    .rh-admin-status {
      margin: 1rem 0;
      padding: 0.85rem 1rem;
      border-radius: 0.9rem;
      background: #f8fafc;
      color: rgba(15, 23, 42, 0.75);
      font-size: 0.95rem;
    }

    .rh-admin-status[data-state="error"] {
      background: #fef2f2;
      color: #991b1b;
    }

    .rh-admin-status[data-state="success"] {
      background: #f0fdf4;
      color: #166534;
    }

    .rh-admin-table-wrap {
      overflow-x: auto;
      border: 1px solid rgba(15, 23, 42, 0.1);
      border-radius: 1rem;
    }

    .rh-admin-table {
      width: 100%;
      min-width: 1000px;
      border-collapse: collapse;
      background: #fff;
      font-size: 0.92rem;
    }

    .rh-admin-table th,
    .rh-admin-table td {
      padding: 0.85rem;
      border-bottom: 1px solid rgba(15, 23, 42, 0.08);
      text-align: left;
      vertical-align: top;
    }

    .rh-admin-table th {
      background: #f8fafc;
      color: rgba(15, 23, 42, 0.74);
      font-size: 0.76rem;
      font-weight: 900;
      letter-spacing: 0.06em;
      text-transform: uppercase;
    }

    .rh-admin-table tr:last-child td {
      border-bottom: 0;
    }

    .rh-admin-empty {
      text-align: center;
      color: rgba(15, 23, 42, 0.58);
    }

    .rh-admin-document-title {
      display: grid;
      gap: 0.15rem;
    }

    .rh-admin-document-title strong {
      color: #0f172a;
    }

    .rh-admin-document-title span {
      color: rgba(15, 23, 42, 0.58);
      font-size: 0.82rem;
      word-break: break-word;
    }

    .rh-badge {
      display: inline-flex;
      align-items: center;
      width: fit-content;
      border-radius: 999px;
      padding: 0.25rem 0.55rem;
      background: #f1f5f9;
      color: #334155;
      font-size: 0.78rem;
      font-weight: 800;
      white-space: nowrap;
    }

    .rh-badge-active {
      background: #dcfce7;
      color: #166534;
    }

    .rh-badge-disabled,
    .rh-badge-withdrawn {
      background: #fee2e2;
      color: #991b1b;
    }

    .rh-badge-review,
    .rh-badge-restricted,
    .rh-badge-approval {
      background: #fef3c7;
      color: #92400e;
    }

    .rh-policy-stack {
      display: grid;
      gap: 0.3rem;
      color: rgba(15, 23, 42, 0.72);
      font-size: 0.84rem;
    }

    .rh-policy-stack span {
      display: block;
    }

    .rh-admin-row-actions {
      display: flex;
      gap: 0.5rem;
      flex-wrap: wrap;
    }

    .rh-admin-detail-card {
      margin-top: 1rem;
    }

    .rh-admin-detail-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 0.85rem;
      margin-top: 1rem;
    }

    .rh-admin-detail-item {
      border: 1px solid rgba(15, 23, 42, 0.1);
      border-radius: 0.9rem;
      padding: 0.85rem;
      background: #f8fafc;
    }

    .rh-admin-detail-item dt {
      color: rgba(15, 23, 42, 0.56);
      font-size: 0.76rem;
      font-weight: 900;
      letter-spacing: 0.06em;
      text-transform: uppercase;
    }

    .rh-admin-detail-item dd {
      margin: 0.3rem 0 0;
      color: #0f172a;
      word-break: break-word;
      line-height: 1.5;
    }

    .rh-admin-body-panel {
      margin-top: 1rem;
      border: 1px solid rgba(15, 23, 42, 0.1);
      border-radius: 1rem;
      background: #f8fafc;
      padding: 1rem;
    }

    .rh-admin-body-panel h3 {
      margin: 0 0 0.75rem;
      font-size: 1rem;
    }

    .rh-admin-body-panel pre {
      margin: 0;
      padding: 1rem;
      overflow-x: auto;
      white-space: pre-wrap;
      border-radius: 0.85rem;
      background: #0f172a;
      color: #e2e8f0;
      line-height: 1.6;
      font-size: 0.9rem;
    }

    @media (max-width: 960px) {
      .rh-admin-section-heading {
        display: grid;
      }

      .rh-admin-summary-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }

      .rh-admin-filters {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }

      .rh-admin-detail-grid {
        grid-template-columns: 1fr;
      }
    }

    @media (max-width: 640px) {
      .rh-admin-page {
        width: min(100% - 1rem, 1180px);
        padding-top: 1rem;
      }

      .rh-admin-hero,
      .rh-admin-card {
        padding: 1rem;
        border-radius: 1rem;
      }

      .rh-admin-summary-grid,
      .rh-admin-filters {
        grid-template-columns: 1fr;
      }

      .rh-admin-filter-actions {
        justify-content: stretch;
      }

      .rh-admin-filter-actions .rh-button,
      .rh-admin-actions .rh-button,
      .rh-admin-row-actions .rh-button {
        width: 100%;
      }
    }
  </style>

  <script is:inline>
    // @ts-nocheck

    const TOKEN_STORAGE_KEY = "relayhub_admin_token";

    const state = {
      documents: [],
      total: 0,
      limit: 100,
      offset: 0,
    };

    const filtersForm = document.getElementById("filters-form");
    const resetFiltersButton = document.getElementById("reset-filters");
    const refreshButton = document.getElementById("refresh-button");
    const statusMessage = document.getElementById("status-message");
    const documentsBody = document.getElementById("documents-body");

    const metricTotal = document.getElementById("metric-total");
    const metricActive = document.getElementById("metric-active");
    const metricListed = document.getElementById("metric-listed");
    const metricApproval = document.getElementById("metric-approval");

    const detailCard = document.getElementById("detail-card");
    const detailSubtitle = document.getElementById("detail-subtitle");
    const detailGrid = document.getElementById("detail-grid");
    const closeDetailButton = document.getElementById("close-detail");

    const licencePreviewCard = document.getElementById("licence-preview-card");
    const licencePreviewSubtitle = document.getElementById("licence-preview-subtitle");
    const licencePreviewVersion = document.getElementById("licence-preview-version");
    const licencePreviewSha = document.getElementById("licence-preview-sha");
    const licencePreviewUnresolved = document.getElementById("licence-preview-unresolved");
    const licencePreviewPlaceholders = document.getElementById("licence-preview-placeholders");
    const licencePreviewBody = document.getElementById("licence-preview-body");
    const closeLicencePreviewButton = document.getElementById("close-licence-preview");

    function getStoredToken() {
      return sessionStorage.getItem(TOKEN_STORAGE_KEY) || "";
    }

    function setStatus(message, mode = "neutral") {
      statusMessage.textContent = message;
      statusMessage.dataset.state = mode;
    }

    function escapeHtml(value) {
      return String(value ?? "")
        .replaceAll("&", "&amp;")
        .replaceAll("<", "&lt;")
        .replaceAll(">", "&gt;")
        .replaceAll('"', "&quot;")
        .replaceAll("'", "&#039;");
    }

    function formatValue(value) {
      if (value === null || value === undefined || value === "") {
        return "—";
      }

      return String(value);
    }

    function formatDate(value) {
      if (!value) {
        return "—";
      }

      const date = new Date(value);

      if (Number.isNaN(date.getTime())) {
        return value;
      }

      return date.toLocaleString(undefined, {
        year: "numeric",
        month: "short",
        day: "2-digit",
        hour: "2-digit",
        minute: "2-digit",
      });
    }

    function badgeClass(value) {
      const text = String(value || "").toLowerCase();

      if (text === "active") return "rh-badge rh-badge-active";
      if (text === "disabled") return "rh-badge rh-badge-disabled";
      if (text === "withdrawn") return "rh-badge rh-badge-withdrawn";
      if (text === "review") return "rh-badge rh-badge-review";
      if (text === "restricted") return "rh-badge rh-badge-restricted";
      if (text === "approval_required") return "rh-badge rh-badge-approval";

      return "rh-badge";
    }

    function getFilters() {
      const formData = new FormData(filtersForm);
      const params = new URLSearchParams();

      for (const [key, value] of formData.entries()) {
        const clean = String(value || "").trim();

        if (clean) {
          params.set(key, clean);
        }
      }

      params.set("limit", String(state.limit));
      params.set("offset", String(state.offset));

      return params;
    }

    async function fetchDocuments() {
      const token = getStoredToken();

      if (!token) {
        setStatus("Admin token is missing. Open another admin page and enter it once.", "error");
        renderDocuments([]);
        updateMetrics([]);
        return;
      }

      const params = getFilters();
      const endpoint = `/api/admin/cdas/documents?${params.toString()}`;

      setStatus("Loading CDAS document records…");

      let response;
      let data;

      try {
        response = await fetch(endpoint, {
          headers: {
            Authorization: `Bearer ${token}`,
          },
        });

        data = await response.json();
      } catch (error) {
        setStatus(`Could not load CDAS documents: ${error.message}`, "error");
        return;
      }

      if (!response.ok || !data.ok) {
        setStatus(
          data?.message || data?.error || "CDAS documents could not be loaded.",
          "error"
        );

        renderDocuments([]);
        updateMetrics([]);
        return;
      }

      state.documents = Array.isArray(data.rows) ? data.rows : [];
      state.total = Number(data.total || state.documents.length || 0);

      renderDocuments(state.documents);
      updateMetrics(state.documents);

      setStatus(
        `Loaded ${state.documents.length} CDAS document record(s). Total matching records: ${state.total}.`,
        "success"
      );
    }

    function updateMetrics(documents) {
      const active = documents.filter((doc) => doc.status === "active").length;
      const listed = documents.filter((doc) => Number(doc.is_listed) === 1).length;
      const approval = documents.filter((doc) => Number(doc.requires_approval) === 1).length;

      metricTotal.textContent = String(state.total || documents.length || 0);
      metricActive.textContent = String(active);
      metricListed.textContent = String(listed);
      metricApproval.textContent = String(approval);
    }

    function renderDocuments(documents) {
      if (!documents.length) {
        documentsBody.innerHTML = `
          <tr>
            <td colspan="9" class="rh-admin-empty">
              No CDAS document records found.
            </td>
          </tr>
        `;
        return;
      }

      documentsBody.innerHTML = documents
        .map((doc) => {
          const policy = `
            <div class="rh-policy-stack">
              <span>Listed: ${Number(doc.is_listed) === 1 ? "yes" : "no"}</span>
              <span>Re-download: ${Number(doc.allow_redownload) === 1 ? "yes" : "no"}</span>
              <span>Approval: ${Number(doc.requires_approval) === 1 ? "yes" : "no"}</span>
            </div>
          `;

          return `
            <tr>
              <td>
                <div class="rh-admin-document-title">
                  <strong>${escapeHtml(doc.title)}</strong>
                  <span>${escapeHtml(doc.slug)}</span>
                  <span>${escapeHtml(doc.source_object)}</span>
                </div>
              </td>
              <td>${escapeHtml(formatValue(doc.version))}</td>
              <td>
                <span class="${badgeClass(doc.status)}">
                  ${escapeHtml(formatValue(doc.status))}
                </span>
              </td>
              <td>
                <span class="${badgeClass(doc.classification)}">
                  ${escapeHtml(formatValue(doc.classification))}
                </span>
              </td>
              <td>
                <span class="${badgeClass(doc.access_class)}">
                  ${escapeHtml(formatValue(doc.access_class))}
                </span>
              </td>
              <td>${escapeHtml(formatValue(doc.licence_terms_version))}</td>
              <td>${policy}</td>
              <td>${escapeHtml(formatDate(doc.updated_at))}</td>
              <td>
                <div class="rh-admin-row-actions">
                  <button
                    class="rh-button rh-button-secondary"
                    type="button"
                    data-view-document="${escapeHtml(doc.id)}"
                  >
                    View
                  </button>

                  <button
                    class="rh-button rh-button-secondary"
                    type="button"
                    data-preview-licence="${escapeHtml(doc.id)}"
                  >
                    Licence
                  </button>
                </div>
              </td>
            </tr>
          `;
        })
        .join("");
    }

    function renderDetail(documentId) {
      const doc = state.documents.find((item) => item.id === documentId);

      if (!doc) {
        setStatus("Selected document was not found in the current result set.", "error");
        return;
      }

      detailSubtitle.textContent = `${doc.title} — ${doc.version}`;

      const fields = [
        ["ID", doc.id],
        ["Slug", doc.slug],
        ["Title", doc.title],
        ["Version", doc.version],
        ["Status", doc.status],
        ["Classification", doc.classification],
        ["Access class", doc.access_class],
        ["Source object", doc.source_object],
        ["Source SHA-256", doc.source_sha256],
        ["Generated prefix", doc.generated_prefix],
        ["Licence terms version", doc.licence_terms_version],
        ["Listed", Number(doc.is_listed) === 1 ? "yes" : "no"],
        ["Allow re-download", Number(doc.allow_redownload) === 1 ? "yes" : "no"],
        ["Max re-downloads", doc.max_redownloads],
        ["Requires approval", Number(doc.requires_approval) === 1 ? "yes" : "no"],
        ["Current version of", doc.current_version_of],
        ["Supersedes document ID", doc.supersedes_document_id],
        ["Superseded by document ID", doc.superseded_by_document_id],
        ["Created at", formatDate(doc.created_at)],
        ["Updated at", formatDate(doc.updated_at)],
      ];

      detailGrid.innerHTML = fields
        .map(([label, value]) => {
          return `
            <dl class="rh-admin-detail-item">
              <dt>${escapeHtml(label)}</dt>
              <dd>${escapeHtml(formatValue(value))}</dd>
            </dl>
          `;
        })
        .join("");

      detailCard.hidden = false;
      detailCard.scrollIntoView({ behavior: "smooth", block: "start" });
    }

    async function renderLicencePreview(documentId) {
      const token = getStoredToken();

      if (!token) {
        setStatus("Admin token is missing. Open another admin page and enter it once.", "error");
        return;
      }

      const doc = state.documents.find((item) => item.id === documentId);

      setStatus("Loading rendered licence preview…");

      let response;
      let data;

      try {
        response = await fetch(
          `/api/admin/cdas/documents/${encodeURIComponent(documentId)}/rendered-licence`,
          {
            headers: {
              Authorization: `Bearer ${token}`,
            },
          }
        );

        data = await response.json();
      } catch (error) {
        setStatus(`Could not load rendered licence preview: ${error.message}`, "error");
        return;
      }

      if (!response.ok || !data.ok) {
        setStatus(
          data?.message || data?.error || "Rendered licence preview could not be loaded.",
          "error"
        );
        return;
      }

      licencePreviewSubtitle.textContent = doc
        ? `${doc.title} — ${doc.version}`
        : data.document?.title || documentId;

      licencePreviewVersion.textContent = data.terms?.version || "—";
      licencePreviewSha.textContent = data.rendered_sha256 || "—";

      licencePreviewUnresolved.textContent =
        Array.isArray(data.unresolved_placeholders) && data.unresolved_placeholders.length
          ? data.unresolved_placeholders.join(", ")
          : "None";

      licencePreviewPlaceholders.textContent =
        Array.isArray(data.template_placeholders) && data.template_placeholders.length
          ? data.template_placeholders.join(", ")
          : "None";

      licencePreviewBody.textContent =
        data.rendered_body || "No rendered licence body returned.";

      licencePreviewCard.hidden = false;
      licencePreviewCard.scrollIntoView({ behavior: "smooth", block: "start" });

      if (data.unresolved_placeholders?.length) {
        setStatus(
          `Rendered licence loaded, but ${data.unresolved_placeholders.length} placeholder(s) remain unresolved.`,
          "error"
        );
      } else {
        setStatus("Rendered licence preview loaded successfully.", "success");
      }
    }

    filtersForm.addEventListener("submit", (event) => {
      event.preventDefault();
      state.offset = 0;
      fetchDocuments();
    });

    resetFiltersButton.addEventListener("click", () => {
      filtersForm.reset();
      state.offset = 0;
      fetchDocuments();
    });

    refreshButton.addEventListener("click", () => {
      fetchDocuments();
    });

    documentsBody.addEventListener("click", (event) => {
      const target = event.target;

      if (!(target instanceof HTMLElement)) {
        return;
      }

      const viewButton = target.closest("[data-view-document]");

      if (viewButton instanceof HTMLElement) {
        const documentId = viewButton.dataset.viewDocument;

        if (documentId) {
          renderDetail(documentId);
        }

        return;
      }

      const licenceButton = target.closest("[data-preview-licence]");

      if (licenceButton instanceof HTMLElement) {
        const documentId = licenceButton.dataset.previewLicence;

        if (documentId) {
          renderLicencePreview(documentId);
        }

        return;
      }
    });

    closeDetailButton.addEventListener("click", () => {
      detailCard.hidden = true;
    });

    closeLicencePreviewButton.addEventListener("click", () => {
      licencePreviewCard.hidden = true;
    });

    const existingToken = getStoredToken();

    if (existingToken) {
      setStatus("Admin token found in this browser session. Loading CDAS documents…");
      fetchDocuments();
    } else {
      setStatus("Admin token is missing. Open another admin page and enter it once.", "error");
    }
  </script>
</BaseLayout>