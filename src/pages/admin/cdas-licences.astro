---
import BaseLayout from "../../layouts/BaseLayout.astro";
import AdminTokenPanel from "../../components/AdminTokenPanel.astro";

const pageTitle = "CDAS Licences Admin";
const pageDescription =
  "Read-only admin view for RelayHub Controlled Document Access System licence records.";
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <main class="rh-admin-page">
    <section class="rh-admin-hero">
      <p class="rh-eyebrow">RelayHub Admin</p>
      <h1>CDAS Licences</h1>
      <p>
        Read-only view of issued CDAS licence records and their rendered licence
        evidence. This page does not revoke or alter licence records. It can issue controlled
        one-time download links through the CDAS admin workflow.
      </p>
    </section>

    <AdminTokenPanel />

    <section class="rh-admin-grid rh-admin-summary-grid" aria-label="CDAS licence summary">
      <article class="rh-admin-metric">
        <span>Total licences</span>
        <strong id="metric-total">—</strong>
      </article>

      <article class="rh-admin-metric">
        <span>Active</span>
        <strong id="metric-active">—</strong>
      </article>

      <article class="rh-admin-metric">
        <span>Evidence captured</span>
        <strong id="metric-rendered">—</strong>
      </article>

      <article class="rh-admin-metric">
        <span>Leak flags</span>
        <strong id="metric-leaks">—</strong>
      </article>
    </section>

    <section class="rh-admin-card">
      <div class="rh-admin-section-heading">
        <div>
          <h2>Licence registry</h2>
          <p>
            Search and filter issued CDAS licence records.
          </p>
        </div>

        <div class="rh-admin-actions">
          <button class="rh-button rh-button-secondary" id="refresh-button" type="button">
            Refresh
          </button>
        </div>
      </div>

      <form class="rh-admin-filters" id="filters-form">
        <label>
          Search
          <input id="filter-q" name="q" type="search" placeholder="Licence, email, document, holder…" />
        </label>

        <label>
          Document
          <input id="filter-document" name="document_id" type="search" placeholder="relayhub-overview" />
        </label>

        <label>
          Status
          <select id="filter-status" name="status">
            <option value="">All statuses</option>
            <option value="active">active</option>
            <option value="revoked">revoked</option>
            <option value="superseded">superseded</option>
            <option value="corrected">corrected</option>
            <option value="expired">expired</option>
          </select>
        </label>

        <div class="rh-admin-filter-actions">
          <button class="rh-button rh-button-primary" type="submit">
            Apply filters
          </button>
          <button class="rh-button rh-button-secondary" id="reset-filters" type="button">
            Reset
          </button>
        </div>
      </form>

      <div class="rh-admin-status" id="status-message" role="status" aria-live="polite">
        Ready.
      </div>

      <div class="rh-admin-table-wrap">
        <table class="rh-admin-table">
          <thead>
            <tr>
              <th>Licence</th>
              <th>Holder</th>
              <th>Document</th>
              <th>Status</th>
              <th>Evidence</th>
              <th>Issued</th>
            </tr>
          </thead>
          <tbody id="licences-body">
            <tr>
              <td colspan="6" class="rh-admin-empty">
                No records loaded yet.
              </td>
            </tr>
          </tbody>
        </table>
      </div>
    </section>

    <section class="rh-admin-card rh-admin-detail-card" id="detail-card" hidden>
      <div class="rh-admin-section-heading">
        <div>
          <h2>Licence detail</h2>
          <p id="detail-subtitle">
            Selected CDAS licence record.
          </p>
        </div>

        <button class="rh-button rh-button-secondary" id="close-detail" type="button">
          Close
        </button>
      </div>

      <div class="rh-detail-sections" id="detail-sections"></div>

      <section class="rh-rendered-evidence" id="rendered-evidence-card" hidden>
        <div class="rh-rendered-heading">
          <div>
            <p class="rh-eyebrow">Captured evidence</p>
            <h3>Rendered issued licence</h3>
            <p>
              Exact licence text captured at licence issue time. This is stored
              evidence, not a live template preview.
            </p>
          </div>
        </div>

        <div class="rh-evidence-grid" id="rendered-meta"></div>

        <div class="rh-rendered-body-wrap">
          <div class="rh-rendered-body-heading">
            <h4>Exact rendered licence body</h4>
          </div>
          <pre class="rh-rendered-body" id="rendered-body"></pre>
        </div>
      </section>

      <section class="rh-generation-preview" id="generation-preview-card" hidden>
        <div class="rh-generation-heading">
          <div>
            <p class="rh-eyebrow">Generation gate</p>
            <h3>PDF generation readiness</h3>
            <p>
              Preview-only generation readiness check. This does not generate a PDF,
              write to R2, create a download link, or serve a document.
            </p>
          </div>
        </div>

        <div class="rh-generation-status" id="generation-status"></div>

        <div class="rh-generation-grid" id="generation-grid"></div>

        <div class="rh-generation-controls" id="generation-controls"></div>
      </section>

      <section class="rh-pdf-inspection" id="pdf-inspection-card" hidden>
        <div class="rh-pdf-inspection-heading">
          <div>
            <p class="rh-eyebrow">Generated PDF inspection</p>
            <h3>Generated PDF evidence check</h3>
            <p>
              Admin-only inspection of the private generated PDF object. This does not
              create a download link, serve the PDF, mutate the database, or expose
              public access.
            </p>
          </div>
        </div>

        <div class="rh-pdf-inspection-status" id="pdf-inspection-status"></div>

        <div class="rh-pdf-inspection-grid" id="pdf-inspection-grid"></div>

        <div class="rh-pdf-inspection-controls" id="pdf-inspection-controls"></div>
      </section>

      <section class="rh-download-link-issue" id="download-link-card" hidden>
        <div class="rh-download-link-heading">
          <div>
            <p class="rh-eyebrow">Controlled download workflow</p>
            <h3>Prepare and email download</h3>
            <p>
              Admin-only operator workflow for preparing a requester-specific PDF,
              activating a one-time controlled download link, and emailing the
              recipient landing page. This panel must never expose private R2 URLs.
            </p>
          </div>
        </div>

        <div class="rh-download-link-status" id="download-link-status"></div>

        <div class="rh-download-link-url-card" id="download-link-url-card" hidden>
          <label for="download-link-url">Recipient landing URL</label>
          <div class="rh-download-link-copy-row">
            <input id="download-link-url" type="text" readonly />
            <button class="rh-button rh-button-primary" id="copy-download-link" type="button">
              Copy link
            </button>
          </div>
          <p>
            This URL is returned once by the Worker and is emailed to the recipient.
            Only the token hash is stored. Do not use this link unless intentionally
            consuming the single-use download.
          </p>
        </div>

        <div class="rh-download-link-grid" id="download-link-grid"></div>

        <div class="rh-download-link-controls" id="download-link-controls"></div>
      </section>

      <section class="rh-download-history" id="download-history-card" hidden>
        <div class="rh-download-history-heading">
          <div>
            <p class="rh-eyebrow">Licence evidence trail</p>
            <h3>Download history</h3>
            <p>
              Read-only operator view of controlled download links, email events,
              download events, dangerous states, and timeline evidence for this licence.
              This panel does not generate PDFs, send email, expose raw tokens, or mutate data.
            </p>
          </div>
        </div>

        <div class="rh-download-history-status" id="download-history-status"></div>

        <div class="rh-download-history-grid" id="download-history-summary"></div>

        <div class="rh-download-history-subsection">
          <h4>Dangerous states</h4>
          <div class="rh-download-history-grid" id="download-history-dangerous-states"></div>
        </div>

        <div class="rh-download-history-subsection">
          <h4>Download links</h4>
          <div class="rh-download-history-grid" id="download-history-links"></div>
        </div>

        <div class="rh-download-history-subsection">
          <h4>Email events</h4>
          <div class="rh-download-history-grid" id="download-history-email-events"></div>
        </div>

        <div class="rh-download-history-subsection">
          <h4>Timeline</h4>
          <div class="rh-download-history-timeline" id="download-history-timeline"></div>
        </div>

        <div class="rh-download-history-controls" id="download-history-controls"></div>
      </section>
    </section>
  </main>

  <style>
    .rh-admin-page {
      width: min(1220px, calc(100% - 2rem));
      margin: 0 auto;
      padding: 7rem 0 5rem;
    }

    .rh-admin-hero {
      margin-bottom: 1.5rem;
      padding: 2rem;
      border: 1px solid rgba(15, 23, 42, 0.12);
      border-radius: 1.5rem;
      background:
        radial-gradient(circle at top left, rgba(59, 130, 246, 0.12), transparent 36rem),
        linear-gradient(135deg, rgba(255,255,255,0.96), rgba(248,250,252,0.96));
      box-shadow: 0 24px 70px rgba(15, 23, 42, 0.08);
    }

    .rh-admin-hero h1 {
      margin: 0.35rem 0 0.75rem;
      font-size: clamp(2rem, 5vw, 3.5rem);
      line-height: 1;
      letter-spacing: -0.05em;
    }

    .rh-admin-hero p {
      max-width: 860px;
      margin: 0;
      color: rgba(15, 23, 42, 0.74);
      font-size: 1.05rem;
      line-height: 1.7;
    }

    .rh-eyebrow {
      margin: 0;
      color: #2563eb;
      font-size: 0.76rem;
      font-weight: 900;
      letter-spacing: 0.14em;
      text-transform: uppercase;
    }

    .rh-admin-card,
    .rh-admin-metric {
      border: 1px solid rgba(15, 23, 42, 0.12);
      border-radius: 1.25rem;
      background: rgba(255, 255, 255, 0.96);
      box-shadow: 0 18px 50px rgba(15, 23, 42, 0.07);
    }

    .rh-admin-card {
      padding: 1.25rem;
      margin-top: 1rem;
    }

        .rh-admin-section-heading {
      display: flex;
      justify-content: space-between;
      gap: 1rem;
      align-items: flex-start;
      margin-bottom: 1rem;
    }

    .rh-admin-section-heading h2 {
      margin: 0;
      color: #0f172a;
      font-size: 1.35rem;
      letter-spacing: -0.03em;
    }

    .rh-admin-section-heading p {
      margin: 0.35rem 0 0;
      color: rgba(15, 23, 42, 0.68);
      line-height: 1.55;
    }

    .rh-admin-grid {
      display: grid;
      gap: 1rem;
    }

    .rh-admin-summary-grid {
      grid-template-columns: repeat(4, minmax(0, 1fr));
      margin: 1rem 0;
    }

    .rh-admin-metric {
      padding: 1rem;
    }

    .rh-admin-metric span {
      display: block;
      color: rgba(15, 23, 42, 0.62);
      font-size: 0.84rem;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 0.08em;
    }

    .rh-admin-metric strong {
      display: block;
      margin-top: 0.35rem;
      color: #0f172a;
      font-size: 2rem;
      line-height: 1;
    }

    .rh-admin-actions,
    .rh-admin-filter-actions {
      display: flex;
      gap: 0.65rem;
      align-items: center;
      flex-wrap: wrap;
    }

    .rh-button {
      display: inline-flex;
      justify-content: center;
      align-items: center;
      gap: 0.45rem;
      min-height: 2.45rem;
      padding: 0.62rem 0.95rem;
      border: 1px solid transparent;
      border-radius: 999px;
      font: inherit;
      font-size: 0.88rem;
      font-weight: 900;
      line-height: 1;
      cursor: pointer;
      text-decoration: none;
      transition:
        transform 0.16s ease,
        box-shadow 0.16s ease,
        background 0.16s ease,
        border-color 0.16s ease;
    }

    .rh-button:hover {
      transform: translateY(-1px);
    }

    .rh-button-primary {
      color: #fff;
      background: linear-gradient(135deg, #2563eb, #1d4ed8);
      box-shadow: 0 12px 26px rgba(37, 99, 235, 0.22);
    }

    .rh-button-secondary {
      color: #0f172a;
      background: rgba(248, 250, 252, 0.98);
      border-color: rgba(15, 23, 42, 0.13);
    }

    .rh-button-warning {
      color: #7c2d12;
      background: linear-gradient(135deg, rgba(255, 247, 237, 0.98), rgba(254, 215, 170, 0.92));
      border-color: rgba(234, 88, 12, 0.35);
      box-shadow: 0 12px 26px rgba(234, 88, 12, 0.12);
    }

    .rh-admin-filters {
      display: grid;
      grid-template-columns: 1.35fr 1fr 0.85fr auto;
      gap: 0.9rem;
      align-items: end;
      padding: 1rem;
      border: 1px solid rgba(15, 23, 42, 0.1);
      border-radius: 1rem;
      background: rgba(248, 250, 252, 0.72);
    }

    .rh-admin-filters label {
      display: grid;
      gap: 0.35rem;
      color: rgba(15, 23, 42, 0.72);
      font-size: 0.82rem;
      font-weight: 900;
      text-transform: uppercase;
      letter-spacing: 0.06em;
    }

    .rh-admin-filters input,
    .rh-admin-filters select,
    .rh-download-link-url-card input {
      width: 100%;
      min-height: 2.65rem;
      padding: 0.7rem 0.8rem;
      border: 1px solid rgba(15, 23, 42, 0.14);
      border-radius: 0.75rem;
      background: #fff;
      color: #0f172a;
      font: inherit;
      font-size: 0.95rem;
    }

    .rh-admin-status {
      margin: 1rem 0;
      padding: 0.85rem 1rem;
      border-radius: 0.9rem;
      background: rgba(239, 246, 255, 0.9);
      color: #1e3a8a;
      font-weight: 800;
      line-height: 1.45;
    }

    .rh-admin-status[data-state="success"] {
      background: rgba(236, 253, 245, 0.95);
      color: #065f46;
    }

    .rh-admin-status[data-state="error"] {
      background: rgba(254, 242, 242, 0.95);
      color: #991b1b;
    }

    .rh-admin-table-wrap {
      overflow-x: auto;
      border: 1px solid rgba(15, 23, 42, 0.1);
      border-radius: 1rem;
    }

    .rh-admin-table {
      width: 100%;
      min-width: 980px;
      border-collapse: collapse;
      background: #fff;
    }

    .rh-admin-table th,
    .rh-admin-table td {
      padding: 0.9rem;
      border-bottom: 1px solid rgba(15, 23, 42, 0.08);
      text-align: left;
      vertical-align: top;
    }

    .rh-admin-table th {
      background: rgba(248, 250, 252, 0.98);
      color: rgba(15, 23, 42, 0.68);
      font-size: 0.76rem;
      font-weight: 900;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .rh-licence-main-row td {
      border-bottom: 0;
    }

    .rh-licence-actions-row td {
      padding-top: 0;
      background: linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(248, 250, 252, 0.82));
      border-bottom: 1px solid rgba(15, 23, 42, 0.12);
    }

    .rh-admin-row-actions {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      justify-content: flex-start;
      gap: 0.55rem;
      padding: 0.2rem 0 0.75rem;
    }

    .rh-admin-row-actions .rh-button {
      min-height: 2.2rem;
      padding: 0.5rem 0.82rem;
      font-size: 0.8rem;
    }

    .rh-admin-row-actions-note {
      flex-basis: 100%;
      margin: 0.1rem 0 0;
      color: rgba(15, 23, 42, 0.58);
      font-size: 0.8rem;
      line-height: 1.45;
    }

    .rh-admin-empty {
      padding: 2rem !important;
      color: rgba(15, 23, 42, 0.58);
      text-align: center !important;
      font-weight: 800;
    }

    .rh-admin-title-stack,
    .rh-policy-stack {
      display: grid;
      gap: 0.24rem;
    }

    .rh-admin-title-stack strong {
      color: #0f172a;
      font-weight: 900;
    }

    .rh-admin-title-stack span,
    .rh-policy-stack span {
      color: rgba(15, 23, 42, 0.62);
      font-size: 0.84rem;
      line-height: 1.35;
    }

    .rh-badge {
      display: inline-flex;
      align-items: center;
      padding: 0.3rem 0.62rem;
      border-radius: 999px;
      background: rgba(226, 232, 240, 0.82);
      color: #334155;
      font-size: 0.74rem;
      font-weight: 900;
      text-transform: uppercase;
      letter-spacing: 0.06em;
    }

    .rh-badge-active {
      background: rgba(220, 252, 231, 0.95);
      color: #166534;
    }

    .rh-badge-revoked,
    .rh-badge-failed {
      background: rgba(254, 226, 226, 0.95);
      color: #991b1b;
    }

    .rh-badge-superseded,
    .rh-badge-corrected,
    .rh-badge-expired,
    .rh-badge-used {
      background: rgba(254, 249, 195, 0.95);
      color: #854d0e;
    }

    .rh-evidence-pill {
      display: inline-flex;
      width: fit-content;
      padding: 0.22rem 0.55rem;
      border-radius: 999px;
      background: rgba(220, 252, 231, 0.95);
      color: #166534 !important;
      font-size: 0.72rem !important;
      font-weight: 900;
      text-transform: uppercase;
      letter-spacing: 0.06em;
    }

    .rh-evidence-pill-missing {
      background: rgba(254, 226, 226, 0.95);
      color: #991b1b !important;
    }

    .rh-hash,
    .rh-generation-code,
    .rh-pdf-code,
    .rh-download-link-code,
    .rh-download-history-code {
      overflow-wrap: anywhere;
      word-break: break-word;
      font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", monospace;
      font-size: 0.78rem !important;
    }

    .rh-admin-detail-card {
      scroll-margin-top: 5rem;
    }

    .rh-detail-sections {
      display: grid;
      gap: 1rem;
    }

    .rh-detail-section,
    .rh-rendered-evidence,
    .rh-generation-preview,
    .rh-pdf-inspection,
    .rh-download-link-issue,
    .rh-download-history {
      padding: 1rem;
      border: 1px solid rgba(15, 23, 42, 0.1);
      border-radius: 1rem;
      background: rgba(248, 250, 252, 0.62);
    }

    .rh-detail-section-header h3,
    .rh-rendered-heading h3,
    .rh-generation-heading h3,
    .rh-pdf-inspection-heading h3,
    .rh-download-link-heading h3,
    .rh-download-history-heading h3 {
      margin: 0.2rem 0 0.4rem;
      color: #0f172a;
      font-size: 1.1rem;
      letter-spacing: -0.02em;
    }

    .rh-rendered-heading p,
    .rh-generation-heading p,
    .rh-pdf-inspection-heading p,
    .rh-download-link-heading p,
    .rh-download-history-heading p {
      margin: 0.25rem 0 0;
      color: rgba(15, 23, 42, 0.66);
      line-height: 1.55;
    }

    .rh-detail-grid,
    .rh-evidence-grid,
    .rh-generation-grid,
    .rh-generation-controls,
    .rh-pdf-inspection-grid,
    .rh-pdf-inspection-controls,
    .rh-download-link-grid,
    .rh-download-link-controls,
    .rh-download-history-grid,
    .rh-download-history-controls {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 0.75rem;
      margin-top: 1rem;
    }

    .rh-detail-item,
    .rh-evidence-row,
    .rh-generation-row,
    .rh-pdf-row,
    .rh-download-link-row,
    .rh-download-history-row {
      min-width: 0;
      margin: 0;
      padding: 0.75rem;
      border: 1px solid rgba(15, 23, 42, 0.08);
      border-radius: 0.85rem;
      background: rgba(255, 255, 255, 0.9);
    }

    .rh-detail-item-wide {
      grid-column: 1 / -1;
    }

    .rh-detail-item dt,
    .rh-evidence-row dt,
    .rh-generation-row dt,
    .rh-pdf-row dt,
    .rh-download-link-row dt,
    .rh-download-history-row dt {
      margin-bottom: 0.32rem;
      color: rgba(15, 23, 42, 0.58);
      font-size: 0.72rem;
      font-weight: 900;
      letter-spacing: 0.07em;
      text-transform: uppercase;
    }

    .rh-detail-item dd,
    .rh-evidence-row dd,
    .rh-generation-row dd,
    .rh-pdf-row dd,
    .rh-download-link-row dd,
    .rh-download-history-row dd {
      margin: 0;
      color: #0f172a;
      line-height: 1.45;
      overflow-wrap: anywhere;
    }

    .rh-evidence-hash {
      font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", monospace;
      font-size: 0.78rem;
    }

    .rh-rendered-body-wrap {
      margin-top: 1rem;
      border: 1px solid rgba(15, 23, 42, 0.1);
      border-radius: 1rem;
      overflow: hidden;
      background: #0f172a;
    }

    .rh-rendered-body-heading {
      padding: 0.75rem 1rem;
      background: rgba(15, 23, 42, 0.96);
      border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    }

    .rh-rendered-body-heading h4 {
      margin: 0;
      color: #fff;
      font-size: 0.95rem;
    }

    .rh-rendered-body {
      max-height: 34rem;
      margin: 0;
      padding: 1rem;
      overflow: auto;
      color: #e2e8f0;
      white-space: pre-wrap;
      font-size: 0.82rem;
      line-height: 1.55;
    }

        .rh-generation-status,
    .rh-pdf-inspection-status,
    .rh-download-link-status,
    .rh-download-history-status {
      margin-top: 1rem;
      padding: 0.85rem 1rem;
      border-radius: 0.9rem;
      background: rgba(239, 246, 255, 0.95);
      color: #1e3a8a;
      font-weight: 850;
      line-height: 1.45;
    }

    .rh-generation-status[data-state="ready"],
    .rh-pdf-inspection-status[data-state="passed"],
    .rh-download-link-status[data-state="success"],
    .rh-download-history-status[data-state="safe"] {
      background: rgba(236, 253, 245, 0.95);
      color: #065f46;
    }

    .rh-generation-status[data-state="warning"],
    .rh-pdf-inspection-status[data-state="warning"],
    .rh-download-link-status[data-state="warning"],
    .rh-download-history-status[data-state="warning"] {
      background: rgba(254, 249, 195, 0.95);
      color: #854d0e;
    }

    .rh-generation-status[data-state="blocked"],
    .rh-pdf-inspection-status[data-state="failed"],
    .rh-download-link-status[data-state="error"],
    .rh-download-history-status[data-state="danger"] {
      background: rgba(254, 242, 242, 0.95);
      color: #991b1b;
    }

    .rh-generation-list,
    .rh-pdf-list,
    .rh-download-link-list,
    .rh-download-history-list {
      margin: 0;
      padding-left: 1.1rem;
    }

    .rh-generation-list li,
    .rh-pdf-list li,
    .rh-download-link-list li,
    .rh-download-history-list li {
      margin: 0.18rem 0;
      line-height: 1.45;
    }

    .rh-download-link-url-card {
      margin-top: 1rem;
      padding: 1rem;
      border: 1px solid rgba(37, 99, 235, 0.18);
      border-radius: 1rem;
      background: rgba(239, 246, 255, 0.72);
    }

    .rh-download-link-url-card label {
      display: block;
      margin-bottom: 0.45rem;
      color: rgba(15, 23, 42, 0.7);
      font-size: 0.76rem;
      font-weight: 900;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .rh-download-link-url-card p {
      margin: 0.55rem 0 0;
      color: rgba(15, 23, 42, 0.66);
      font-size: 0.88rem;
      line-height: 1.55;
    }

    .rh-download-link-copy-row {
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto;
      gap: 0.65rem;
      align-items: center;
    }

    .rh-download-history {
      margin-top: 1rem;
    }

    .rh-download-history-subsection {
      margin-top: 1rem;
      padding-top: 1rem;
      border-top: 1px solid rgba(15, 23, 42, 0.1);
    }

    .rh-download-history-subsection h4 {
      margin: 0 0 0.75rem;
      color: #0f172a;
      font-size: 1rem;
      letter-spacing: -0.02em;
    }

    .rh-download-history-timeline {
      display: grid;
      gap: 0.65rem;
      margin-top: 0.75rem;
    }

    .rh-timeline-item {
      display: grid;
      gap: 0.25rem;
      padding: 0.75rem;
      border: 1px solid rgba(15, 23, 42, 0.08);
      border-left: 4px solid rgba(37, 99, 235, 0.55);
      border-radius: 0.85rem;
      background: rgba(255, 255, 255, 0.92);
    }

    .rh-timeline-item[data-state="failed"] {
      border-left-color: rgba(220, 38, 38, 0.72);
      background: rgba(254, 242, 242, 0.72);
    }

    .rh-timeline-item[data-state="warning"] {
      border-left-color: rgba(202, 138, 4, 0.72);
      background: rgba(254, 249, 195, 0.58);
    }

    .rh-timeline-title {
      display: flex;
      justify-content: space-between;
      gap: 0.75rem;
      align-items: flex-start;
      color: #0f172a;
      font-weight: 900;
      line-height: 1.35;
    }

    .rh-timeline-title span {
      color: rgba(15, 23, 42, 0.58);
      font-size: 0.78rem;
      font-weight: 800;
      white-space: nowrap;
    }

    .rh-timeline-meta {
      color: rgba(15, 23, 42, 0.66);
      font-size: 0.84rem;
      line-height: 1.45;
      overflow-wrap: anywhere;
    }

    .rh-download-history-mini-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 0.55rem;
      margin-top: 0.6rem;
    }

    .rh-download-history-mini {
      padding: 0.6rem;
      border: 1px solid rgba(15, 23, 42, 0.08);
      border-radius: 0.75rem;
      background: rgba(248, 250, 252, 0.9);
    }

    .rh-download-history-mini span {
      display: block;
      color: rgba(15, 23, 42, 0.56);
      font-size: 0.68rem;
      font-weight: 900;
      letter-spacing: 0.07em;
      text-transform: uppercase;
    }

    .rh-download-history-mini strong {
      display: block;
      margin-top: 0.2rem;
      color: #0f172a;
      font-size: 1rem;
      overflow-wrap: anywhere;
    }

    @media (max-width: 980px) {
      .rh-admin-summary-grid,
      .rh-admin-filters,
      .rh-detail-grid,
      .rh-evidence-grid,
      .rh-generation-grid,
      .rh-generation-controls,
      .rh-pdf-inspection-grid,
      .rh-pdf-inspection-controls,
      .rh-download-link-grid,
      .rh-download-link-controls,
      .rh-download-history-grid,
      .rh-download-history-controls {
        grid-template-columns: 1fr;
      }

      .rh-admin-section-heading {
        flex-direction: column;
      }

      .rh-download-link-copy-row {
        grid-template-columns: 1fr;
      }

      .rh-download-history-mini-grid {
        grid-template-columns: 1fr;
      }
    }

    @media (max-width: 680px) {
      .rh-admin-page {
        width: min(100% - 1rem, 1220px);
        padding-top: 5.5rem;
      }

      .rh-admin-hero,
      .rh-admin-card {
        padding: 1rem;
        border-radius: 1rem;
      }

      .rh-admin-summary-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>

  <script>
       // @ts-nocheck
    const licencesBody = document.getElementById("licences-body");
    const statusMessage = document.getElementById("status-message");
    const filtersForm = document.getElementById("filters-form");
    const resetFiltersButton = document.getElementById("reset-filters");
    const refreshButton = document.getElementById("refresh-button");

    const metricTotal = document.getElementById("metric-total");
    const metricActive = document.getElementById("metric-active");
    const metricRendered = document.getElementById("metric-rendered");
    const metricLeaks = document.getElementById("metric-leaks");

    const detailCard = document.getElementById("detail-card");
    const detailSubtitle = document.getElementById("detail-subtitle");
    const detailSections = document.getElementById("detail-sections");
    const closeDetailButton = document.getElementById("close-detail");

    const renderedEvidenceCard = document.getElementById("rendered-evidence-card");
    const renderedMeta = document.getElementById("rendered-meta");
    const renderedBody = document.getElementById("rendered-body");

    const generationPreviewCard = document.getElementById("generation-preview-card");
    const generationStatus = document.getElementById("generation-status");
    const generationGrid = document.getElementById("generation-grid");
    const generationControls = document.getElementById("generation-controls");

    const pdfInspectionCard = document.getElementById("pdf-inspection-card");
    const pdfInspectionStatus = document.getElementById("pdf-inspection-status");
    const pdfInspectionGrid = document.getElementById("pdf-inspection-grid");
    const pdfInspectionControls = document.getElementById("pdf-inspection-controls");

    const downloadLinkCard = document.getElementById("download-link-card");
    const downloadLinkStatus = document.getElementById("download-link-status");
    const downloadLinkUrlCard = document.getElementById("download-link-url-card");
    const downloadLinkUrlInput = document.getElementById("download-link-url");
    const copyDownloadLinkButton = document.getElementById("copy-download-link");
    const downloadLinkGrid = document.getElementById("download-link-grid");
    const downloadLinkControls = document.getElementById("download-link-controls");

    const downloadHistoryCard = document.getElementById("download-history-card");
    const downloadHistoryStatus = document.getElementById("download-history-status");
    const downloadHistorySummary = document.getElementById("download-history-summary");
    const downloadHistoryDangerousStates = document.getElementById("download-history-dangerous-states");
    const downloadHistoryLinks = document.getElementById("download-history-links");
    const downloadHistoryEmailEvents = document.getElementById("download-history-email-events");
    const downloadHistoryTimeline = document.getElementById("download-history-timeline");
    const downloadHistoryControls = document.getElementById("download-history-controls");

    const state = {
      licences: [],
      total: 0,
      limit: 100,
      offset: 0,
    };

    function getStoredToken() {
      return (
        window.localStorage.getItem("relayhub_admin_token") ||
        window.sessionStorage.getItem("relayhub_admin_token") ||
        ""
      );
    }

    function escapeHtml(value) {
      return String(value ?? "")
        .replaceAll("&", "&amp;")
        .replaceAll("<", "&lt;")
        .replaceAll(">", "&gt;")
        .replaceAll('"', "&quot;")
        .replaceAll("'", "&#039;");
    }

    function formatValue(value) {
      if (value === null || value === undefined || value === "") {
        return "—";
      }

      return String(value);
    }

    function booleanText(value) {
      return value ? "Yes" : "No";
    }

    function setStatus(message, stateName = "neutral") {
      statusMessage.textContent = message;
      statusMessage.dataset.state = stateName;
    }

    function formatDate(value) {
      if (!value) return "—";

      const date = new Date(value);

      if (Number.isNaN(date.getTime())) {
        return value;
      }

      return date.toLocaleString(undefined, {
        year: "numeric",
        month: "short",
        day: "2-digit",
        hour: "2-digit",
        minute: "2-digit",
        second: "2-digit",
      });
    }

        function badgeClass(value) {
      const text = String(value || "").toLowerCase();

      if (!text) return "rh-badge";

      return `rh-badge rh-badge-${text}`;
    }

    function parseJsonArray(value) {
      if (!value) return [];

      if (Array.isArray(value)) return value;

      try {
        const parsed = JSON.parse(value);
        return Array.isArray(parsed) ? parsed : [];
      } catch {
        return [];
      }
    }

    function isEmptyValue(value) {
      return value === null || value === undefined || value === "";
    }

    function getFilters() {
      const formData = new FormData(filtersForm);
      const params = new URLSearchParams();

      for (const [key, value] of formData.entries()) {
        const clean = String(value || "").trim();

        if (clean) {
          params.set(key, clean);
        }
      }

      params.set("limit", String(state.limit));
      params.set("offset", String(state.offset));

      return params;
    }

    async function fetchLicences() {
      const token = getStoredToken();

      if (!token) {
        setStatus("Admin token is missing. Open another admin page and enter it once.", "error");
        renderLicences([]);
        updateMetrics([]);
        return;
      }

      const params = getFilters();
      const endpoint = `/api/admin/cdas/licences?${params.toString()}`;

      setStatus("Loading CDAS licence records…");

      let response;
      let data;

      try {
        response = await fetch(endpoint, {
          headers: {
            Authorization: `Bearer ${token}`,
          },
        });

        data = await response.json();
      } catch (error) {
        setStatus(`Could not load CDAS licences: ${error.message}`, "error");
        return;
      }

      if (!response.ok || !data.ok) {
        setStatus(
          data?.message || data?.error || "CDAS licences could not be loaded.",
          "error"
        );

        renderLicences([]);
        updateMetrics([]);
        return;
      }

      state.licences = Array.isArray(data.rows) ? data.rows : [];
      state.total = Number(data.total || state.licences.length || 0);

      renderLicences(state.licences);
      updateMetrics(state.licences);

      setStatus(
        `Loaded ${state.licences.length} CDAS licence record(s). Total matching records: ${state.total}.`,
        "success"
      );
    }

    function updateMetrics(licences) {
      const active = licences.filter((row) => row.status === "active").length;
      const rendered = licences.filter((row) => row.rendered_licence_sha256).length;
      const leaks = licences.filter(
        (row) => row.suspected_leak_at || row.confirmed_leak_at
      ).length;

      metricTotal.textContent = String(state.total || licences.length || 0);
      metricActive.textContent = String(active);
      metricRendered.textContent = String(rendered);
      metricLeaks.textContent = String(leaks);
    }

    function renderLicences(licences) {
      if (!licences.length) {
        licencesBody.innerHTML = `
          <tr>
            <td colspan="6" class="rh-admin-empty">
              No CDAS licence records found.
            </td>
          </tr>
        `;
        return;
      }

      licencesBody.innerHTML = licences
        .map((row) => {
          const hasEvidence = Boolean(row.rendered_licence_sha256);
          const licenceId = escapeHtml(row.id);

          return `
            <tr class="rh-licence-main-row">
              <td>
                <div class="rh-admin-title-stack">
                  <strong>${escapeHtml(row.licence_number)}</strong>
                  <span>${escapeHtml(row.id)}</span>
                </div>
              </td>
              <td>
                <div class="rh-admin-title-stack">
                  <strong>${escapeHtml(formatValue(row.licence_holder_name))}</strong>
                  <span>${escapeHtml(formatValue(row.licence_holder_email_normalised))}</span>
                  <span>${escapeHtml(formatValue(row.organisation_name))}</span>
                </div>
              </td>
              <td>
                <div class="rh-admin-title-stack">
                  <strong>${escapeHtml(formatValue(row.document_id))}</strong>
                  <span>v${escapeHtml(formatValue(row.document_version))}</span>
                  <span>Terms: ${escapeHtml(formatValue(row.licence_terms_version))}</span>
                </div>
              </td>
              <td>
                <span class="${badgeClass(row.status)}">
                  ${escapeHtml(formatValue(row.status))}
                </span>
              </td>
              <td>
                <div class="rh-policy-stack">
                  <span class="${hasEvidence ? "rh-evidence-pill" : "rh-evidence-pill rh-evidence-pill-missing"}">
                    ${hasEvidence ? "Captured" : "Missing"}
                  </span>
                  <span class="rh-hash">${escapeHtml(formatValue(row.rendered_licence_sha256))}</span>
                </div>
              </td>
              <td>${escapeHtml(formatDate(row.issued_at))}</td>
            </tr>

            <tr class="rh-licence-actions-row">
              <td colspan="6">
                <div class="rh-admin-row-actions" aria-label="Licence actions for ${escapeHtml(row.licence_number)}">
                  <button
                    class="rh-button rh-button-secondary"
                    type="button"
                    data-view-licence="${licenceId}"
                  >
                    View
                  </button>

                  <button
                    class="rh-button rh-button-secondary"
                    type="button"
                    data-generation-preview="${licenceId}"
                  >
                    Generation
                  </button>

                  <button
                    class="rh-button rh-button-secondary"
                    type="button"
                    data-inspect-pdf="${licenceId}"
                  >
                    Inspect PDF
                  </button>

                  <button
                    class="rh-button rh-button-secondary"
                    type="button"
                    data-download-history="${licenceId}"
                  >
                    Download History
                  </button>

                  <button
                    class="rh-button rh-button-primary"
                    type="button"
                    data-prepare-email-download="${licenceId}"
                  >
                    Prepare &amp; Email
                  </button>

                  <button
                    class="rh-button rh-button-warning"
                    type="button"
                    data-reissue-download="${licenceId}"
                  >
                    Reissue Download
                  </button>

                  <p class="rh-admin-row-actions-note">
                    Download History is read-only. Reissue Download creates a new licensed copy with a new Download ID.
                  </p>
                </div>
              </td>
            </tr>
          `;
        })
        .join("");
    }

    function detailItem(label, value, options = {}) {
      if (options.hideEmpty && isEmptyValue(value)) {
        return "";
      }

      const classes = ["rh-detail-item"];

      if (options.wide) {
        classes.push("rh-detail-item-wide");
      }

      return `
        <dl class="${classes.join(" ")}">
          <dt>${escapeHtml(label)}</dt>
          <dd>${escapeHtml(formatValue(value))}</dd>
        </dl>
      `;
    }

    function renderDetailSection(title, items) {
      const body = items.filter(Boolean).join("");

      if (!body) {
        return "";
      }

      return `
        <section class="rh-detail-section">
          <div class="rh-detail-section-header">
            <h3>${escapeHtml(title)}</h3>
          </div>
          <div class="rh-detail-grid">
            ${body}
          </div>
        </section>
      `;
    }

    function renderRenderedEvidence(row) {
      const placeholders = parseJsonArray(row.rendered_licence_placeholders);
      const unresolved = parseJsonArray(row.rendered_licence_unresolved_placeholders);

      const metaFields = [
        ["Rendered licence SHA-256", row.rendered_licence_sha256, true],
        ["Rendered terms body SHA-256", row.rendered_terms_body_sha256, true],
        ["Rendered at", formatDate(row.rendered_licence_at), false],
        ["Template placeholders", placeholders.length ? placeholders.join(", ") : "None", false],
        ["Unresolved placeholders", unresolved.length ? unresolved.join(", ") : "None", false],
      ];

      renderedMeta.innerHTML = metaFields
        .map(([label, value, isHash]) => {
          return `
            <dl class="rh-evidence-row">
              <dt>${escapeHtml(label)}</dt>
              <dd class="${isHash ? "rh-evidence-hash" : ""}">
                ${escapeHtml(formatValue(value))}
              </dd>
            </dl>
          `;
        })
        .join("");

      renderedBody.textContent =
        row.rendered_licence_body || "No rendered licence body stored on this licence record.";

      renderedEvidenceCard.hidden = false;
    }

    function renderList(items) {
      const values = Array.isArray(items) ? items : [];

      if (!values.length) {
        return "None";
      }

      return `
        <ul class="rh-generation-list">
          ${values.map((item) => `<li>${escapeHtml(item)}</li>`).join("")}
        </ul>
      `;
    }

    function generationRow(label, value, options = {}) {
      const className = options.code ? "rh-generation-code" : "";

      return `
        <dl class="rh-generation-row">
          <dt>${escapeHtml(label)}</dt>
          <dd class="${className}">
            ${options.html ? value : escapeHtml(formatValue(value))}
          </dd>
        </dl>
      `;
    }

        function renderGenerationPreviewData(data) {
      const ready = Boolean(data.ready_for_generation);
      const blockers = Array.isArray(data.blockers) ? data.blockers : [];
      const warnings = Array.isArray(data.warnings) ? data.warnings : [];

      if (ready && warnings.length) {
        generationStatus.dataset.state = "warning";
        generationStatus.textContent =
          "Ready for future PDF generation, with warnings that should be reviewed.";
      } else if (ready) {
        generationStatus.dataset.state = "ready";
        generationStatus.textContent =
          "Ready for future PDF generation. No blockers were reported.";
      } else {
        generationStatus.dataset.state = "blocked";
        generationStatus.textContent =
          "Not ready for future PDF generation. Resolve blockers first.";
      }

      generationGrid.innerHTML = [
        generationRow("Ready for generation", ready ? "Yes" : "No"),
        generationRow("Blockers", renderList(blockers), { html: true }),
        generationRow("Warnings", renderList(warnings), { html: true }),
        generationRow("Licence number", data.licence?.licence_number),
        generationRow("Licence status", data.licence?.status),
        generationRow("Document", data.document?.title),
        generationRow("Document ID", data.document?.id),
        generationRow("Document version", data.document?.version),
        generationRow("Source object", data.document?.source_object, { code: true }),
        generationRow("Source SHA-256", data.document?.source_sha256 || "Missing", { code: true }),
        generationRow("Rendered licence SHA-256", data.licence?.rendered_licence_sha256, { code: true }),
        generationRow("Rendered terms SHA-256", data.licence?.rendered_terms_body_sha256, { code: true }),
        generationRow("Planned object key", data.planned_output?.generated_object_key, { code: true }),
        generationRow("Planned filename", data.planned_output?.generated_filename, { code: true }),
      ].join("");

      const controls = data.controls || {};

      generationControls.innerHTML = [
        generationRow("Writes to R2", controls.writes_to_r2 ? "Yes" : "No"),
        generationRow("Generates PDF", controls.generates_pdf ? "Yes" : "No"),
        generationRow("Creates download link", controls.creates_download_link ? "Yes" : "No"),
        generationRow("Serves download", controls.serves_download ? "Yes" : "No"),
        generationRow("Preview only", controls.preview_only ? "Yes" : "No"),
        generationRow("Message", data.message),
      ].join("");

      generationPreviewCard.hidden = false;
    }

    async function renderGenerationPreview(licenceId) {
      const token = getStoredToken();

      if (!token) {
        setStatus("Admin token is missing. Open another admin page and enter it once.", "error");
        return;
      }

      detailCard.hidden = false;
      generationPreviewCard.hidden = false;
      generationStatus.dataset.state = "neutral";
      generationStatus.textContent = "Loading generation readiness preview…";
      generationGrid.innerHTML = "";
      generationControls.innerHTML = "";

      let response;
      let data;

      try {
        response = await fetch(
          `/api/admin/cdas/licences/${encodeURIComponent(licenceId)}/generation-preview`,
          {
            headers: {
              Authorization: `Bearer ${token}`,
            },
          }
        );

        data = await response.json();
      } catch (error) {
        generationStatus.dataset.state = "blocked";
        generationStatus.textContent = `Could not load generation preview: ${error.message}`;
        return;
      }

      if (!response.ok || !data.ok) {
        generationStatus.dataset.state = "blocked";
        generationStatus.textContent =
          data?.message || data?.error || "Generation readiness preview could not be loaded.";
        return;
      }

      renderGenerationPreviewData(data);

      generationPreviewCard.scrollIntoView({ behavior: "smooth", block: "start" });

      setStatus("Generation readiness preview loaded.", "success");
    }

    function renderPdfList(items) {
      const values = Array.isArray(items) ? items : [];

      if (!values.length) {
        return "None";
      }

      return `
        <ul class="rh-pdf-list">
          ${values.map((item) => `<li>${escapeHtml(item)}</li>`).join("")}
        </ul>
      `;
    }

    function pdfRow(label, value, options = {}) {
      const className = options.code ? "rh-pdf-code" : "";

      return `
        <dl class="rh-pdf-row">
          <dt>${escapeHtml(label)}</dt>
          <dd class="${className}">
            ${options.html ? value : escapeHtml(formatValue(value))}
          </dd>
        </dl>
      `;
    }

    function renderPdfInspectionData(data) {
      const blockers = Array.isArray(data.blockers) ? data.blockers : [];
      const warnings = Array.isArray(data.warnings) ? data.warnings : [];

      if (data.evidence_matches && !blockers.length && !warnings.length) {
        pdfInspectionStatus.dataset.state = "passed";
        pdfInspectionStatus.textContent =
          "Generated PDF inspection passed. R2 object and D1 evidence match.";
      } else if (data.evidence_matches && warnings.length) {
        pdfInspectionStatus.dataset.state = "warning";
        pdfInspectionStatus.textContent =
          "Generated PDF evidence matches, but warnings should be reviewed.";
      } else {
        pdfInspectionStatus.dataset.state = "failed";
        pdfInspectionStatus.textContent =
          "Generated PDF inspection found blockers or evidence mismatch.";
      }

      const licence = data.licence || {};
      const r2 = data.r2_object || {};
      const comparisons = data.comparisons || {};

      pdfInspectionGrid.innerHTML = [
        pdfRow("Object exists", booleanText(data.object_exists)),
        pdfRow("Evidence matches", booleanText(data.evidence_matches)),
        pdfRow("Blockers", renderPdfList(blockers), { html: true }),
        pdfRow("Warnings", renderPdfList(warnings), { html: true }),

        pdfRow("Licence number", licence.licence_number),
        pdfRow("Document ID", licence.document_id),
        pdfRow("Document version", licence.document_version),
        pdfRow("Generated status", licence.generated_pdf_status),

        pdfRow("D1 object key", licence.generated_pdf_object_key, { code: true }),
        pdfRow("R2 object key", r2.key, { code: true }),

        pdfRow("D1 filename", licence.generated_pdf_filename, { code: true }),
        pdfRow("D1 content type", licence.generated_pdf_content_type),
        pdfRow("R2 content type", r2.http_metadata?.contentType),

        pdfRow("D1 size", licence.generated_pdf_size_bytes),
        pdfRow("R2 size", r2.size),
        pdfRow("Size matches", booleanText(comparisons.size_matches)),

        pdfRow("D1 SHA-256", licence.generated_pdf_sha256, { code: true }),
        pdfRow("Calculated R2 SHA-256", r2.calculated_sha256, { code: true }),
        pdfRow("SHA-256 matches", booleanText(comparisons.sha256_matches)),

        pdfRow("D1 created at", licence.generated_pdf_created_at),
        pdfRow("R2 uploaded", r2.uploaded),
        pdfRow("R2 HTTP ETag", r2.http_etag, { code: true }),
        pdfRow("D1 error clear", booleanText(comparisons.database_error_is_clear)),
      ].join("");

      const controls = data.controls || {};

      pdfInspectionControls.innerHTML = [
        pdfRow("Reads generated PDF from R2", booleanText(controls.reads_generated_pdf_from_r2)),
        pdfRow("Calculates generated PDF SHA-256", booleanText(controls.calculates_generated_pdf_sha256)),
        pdfRow("Writes to R2", booleanText(controls.writes_to_r2)),
        pdfRow("Mutates database", booleanText(controls.mutates_database)),
        pdfRow("Creates download link", booleanText(controls.creates_download_link)),
