        downloadHistoryRow(
          "Dangerous states",
          `Total: ${dangerousSummary.total || 0} | Critical: ${dangerousSummary.critical || 0} | Warning: ${dangerousSummary.warning || 0}`
        ),
        downloadHistoryRow("Timeline events", timelineSummary.total || 0),
      ].join("");

      evidenceBundleIntegrity.innerHTML = [
        downloadHistoryRow("Licence evidence captured", booleanText(integrity.licence_evidence_captured)),
        downloadHistoryRow("Generated PDF evidence present", booleanText(integrity.generated_pdf_evidence_present)),
        downloadHistoryRow("Document record present", booleanText(integrity.document_record_present)),
        downloadHistoryRow(
          "Download links with PDF evidence",
          `${integrity.download_links_with_generated_pdf_evidence || 0} of ${integrity.download_links_total || 0}`
        ),
        downloadHistoryRow("Email events match download links", booleanText(integrity.email_events_match_download_links)),
        downloadHistoryRow("Dangerous states present", booleanText(integrity.dangerous_states_present)),

        downloadHistoryRow("Raw token exposed", booleanText(integrity.raw_token_exposed)),
        downloadHistoryRow("Token hash exposed", booleanText(integrity.token_hash_exposed)),
        downloadHistoryRow("Private R2 URL exposed", booleanText(integrity.private_r2_url_exposed)),

        downloadHistoryRow("Bundle read only", booleanText(bundleControls.read_only)),
        downloadHistoryRow("Bundle mutates database", booleanText(bundleControls.mutates_database)),
        downloadHistoryRow("Bundle writes to R2", booleanText(bundleControls.writes_to_r2)),
        downloadHistoryRow("Bundle creates download link", booleanText(bundleControls.creates_download_link)),
        downloadHistoryRow("Bundle sends email", booleanText(bundleControls.sends_email)),
        downloadHistoryRow("Bundle serves download", booleanText(bundleControls.serves_download)),
        downloadHistoryRow("Bundle exposes raw token", booleanText(bundleControls.exposes_raw_token)),
        downloadHistoryRow("Bundle exposes token hash", booleanText(bundleControls.exposes_token_hash)),
        downloadHistoryRow("Bundle includes private R2 URL", booleanText(bundleControls.includes_private_r2_url)),

        downloadHistoryRow(isArchive ? "Archive records audit event" : "Export records audit event", booleanText(actionControls.records_admin_audit_event)),
        downloadHistoryRow(isArchive ? "Archive mutates database" : "Export mutates database", booleanText(actionControls.mutates_database)),
        downloadHistoryRow(isArchive ? "Archive writes to R2" : "Export writes to R2", booleanText(actionControls.writes_to_r2)),
        downloadHistoryRow(isArchive ? "Archive creates download link" : "Export creates download link", booleanText(actionControls.creates_download_link)),
        downloadHistoryRow(isArchive ? "Archive generates PDF" : "Export generates PDF", booleanText(actionControls.generates_pdf)),
        downloadHistoryRow(isArchive ? "Archive sends email" : "Export sends email", booleanText(actionControls.sends_email)),
        downloadHistoryRow(isArchive ? "Archive serves download" : "Export serves download", booleanText(actionControls.serves_download)),
        downloadHistoryRow(isArchive ? "Archive exposes raw token" : "Export exposes raw token", booleanText(actionControls.exposes_raw_token)),
        downloadHistoryRow(isArchive ? "Archive exposes token hash" : "Export exposes token hash", booleanText(actionControls.exposes_token_hash)),
        downloadHistoryRow(isArchive ? "Archive includes private R2 URL" : "Export includes private R2 URL", booleanText(actionControls.includes_private_r2_url)),

        ...(isArchive
          ? [
              downloadHistoryRow("Archives evidence bundle JSON", booleanText(actionControls.archives_evidence_bundle_json)),
            ]
          : []),
      ].join("");

      evidenceBundlePreview.textContent = JSON.stringify(
        {
          ok: data.ok,
          mode: isArchive ? "archive" : "export",
          archive_record_type: data.archive_record_type,
          export_record_type: data.export_record_type,
          archive_evidence: data.archive_evidence,
          export_evidence: data.export_evidence,
          r2_archive: data.r2_archive,
          audit_record: data.audit_record,
          bundle: {
            ok: bundle.ok,
            bundle_type: bundle.bundle_type,
            bundle_version: bundle.bundle_version,
            generated_at: bundle.generated_at,
            licence: {
              id: bundle.licence?.id,
              licence_number: bundle.licence?.licence_number,
              status: bundle.licence?.status,
            },
            summary: bundle.summary,
            operator_interpretation: bundle.operator_interpretation,
            integrity_summary: bundle.integrity_summary,
            controls: bundle.controls,
          },
          action_controls: data.controls,
        },
        null,
        2
      );

      evidenceBundleControls.innerHTML = `
        <button class="rh-button rh-button-primary" type="button" data-download-evidence-bundle-json>
          Download JSON Evidence Bundle
        </button>
        <p>
          ${
            isArchive
              ? "The evidence bundle has been archived server-side to R2 before this download button is shown."
              : "The export has been recorded server-side before this download button is shown."
          }
          The downloaded JSON file is generated locally by your browser from the returned
          evidence bundle. It does not create a recipient CDAS download link or expose a
          recipient download token.
        </p>
      `;

      evidenceBundleCard.hidden = false;
    }

    async function renderEvidenceBundle(licenceId) {
      const token = getStoredToken();

      if (!token) {
        setStatus("Admin token is missing. Open another admin page and enter it once.", "error");
        return;
      }

      const confirmed = window.confirm(
        "Export and record this CDAS licence evidence bundle?\n\n" +
          "This will generate the evidence bundle server-side, calculate its SHA-256, " +
          "record an admin audit event, and then allow you to download the JSON bundle.\n\n" +
          "It will not create a download link, generate a PDF, send email, write R2, " +
          "serve a document, expose raw tokens, expose token hashes, or expose private R2 URLs."
      );

      if (!confirmed) {
        return;
      }

      detailCard.hidden = false;
      evidenceBundleCard.hidden = false;
      resetEvidenceBundlePanel();
      evidenceBundleStatus.dataset.state = "neutral";
      evidenceBundleStatus.textContent = "Recording CDAS licence evidence bundle export…";

      let response;
      let data;

      try {
        response = await fetch(
          `/api/admin/cdas/licences/${encodeURIComponent(licenceId)}/evidence-bundle/export-record`,
          {
            method: "POST",
            headers: {
              Authorization: `Bearer ${token}`,
              "Content-Type": "application/json",
            },
            body: JSON.stringify({
              action: "export_evidence_bundle",
              confirm_export_record: true,
            }),
          }
        );

        data = await readJsonResponse(response, response.url || "admin API endpoint");
      } catch (error) {
        evidenceBundleStatus.dataset.state = "error";
        evidenceBundleStatus.textContent = `Could not record evidence bundle export: ${error.message}`;
        return;
      }

      if (!response.ok || !data.ok) {
        evidenceBundleStatus.dataset.state = "error";
        evidenceBundleStatus.textContent =
          data?.message || data?.error || "Evidence bundle export could not be recorded.";

        evidenceBundleSummary.innerHTML = [
          downloadHistoryRow("Error", data?.error),
          downloadHistoryRow("Message", data?.message),
        ].join("");

        return;
      }

      renderEvidenceBundleData(data);

      evidenceBundleCard.scrollIntoView({ behavior: "smooth", block: "start" });

      if (data.audit_record?.recorded) {
        setStatus("CDAS licence evidence bundle export recorded.", "success");
      } else {
        setStatus(
          "Evidence bundle loaded, but the export audit record was not persisted. Review the panel.",
          "error"
        );
      }
    }

    async function archiveEvidenceBundle(licenceId) {
      const token = getStoredToken();

      if (!token) {
        setStatus("Admin token is missing. Open another admin page and enter it once.", "error");
        return;
      }

      const confirmed = window.confirm(
        "Archive this CDAS licence evidence bundle to R2?\n\n" +
          "This will generate the evidence bundle server-side, calculate its SHA-256, " +
          "store the JSON bundle in R2, and record an admin audit event.\n\n" +
          "It will not create a download link, generate a PDF, send email, serve a document, " +
          "expose raw tokens, expose token hashes, or expose private R2 URLs."
      );

      if (!confirmed) {
        return;
      }

      detailCard.hidden = false;
      evidenceBundleCard.hidden = false;
      resetEvidenceBundlePanel();
      evidenceBundleStatus.dataset.state = "neutral";
      evidenceBundleStatus.textContent = "Archiving CDAS licence evidence bundle to R2…";

      let response;
      let data;

      try {
        response = await fetch(
          `/api/admin/cdas/licences/${encodeURIComponent(licenceId)}/evidence-bundle/archive`,
          {
            method: "POST",
            headers: {
              Authorization: `Bearer ${token}`,
              "Content-Type": "application/json",
            },
            body: JSON.stringify({
              action: "archive_evidence_bundle",
              confirm_archive: true,
            }),
          }
        );

        data = await readJsonResponse(response, response.url || "admin API endpoint");
      } catch (error) {
        evidenceBundleStatus.dataset.state = "error";
        evidenceBundleStatus.textContent = `Could not archive evidence bundle: ${error.message}`;
        return;
      }

      if (!response.ok || !data.ok) {
        evidenceBundleStatus.dataset.state = "error";
        evidenceBundleStatus.textContent =
          data?.message || data?.error || "Evidence bundle could not be archived.";

        evidenceBundleSummary.innerHTML = [
          downloadHistoryRow("Error", data?.error),
          downloadHistoryRow("Message", data?.message),
        ].join("");

        return;
      }

      renderEvidenceBundleData(data, "archive");

      evidenceBundleCard.scrollIntoView({ behavior: "smooth", block: "start" });

      if (data.r2_archive?.archived && data.audit_record?.recorded) {
        setStatus("CDAS licence evidence bundle archived to R2 and audit event recorded.", "success");
      } else if (data.r2_archive?.archived) {
        setStatus(
          "Evidence bundle archived to R2, but the audit record was not persisted. Review the panel.",
          "error"
        );
      } else {
        setStatus("Evidence bundle archive did not complete. Review the panel.", "error");
      }
    }

    async function prepareAndEmailDownload(licenceId) {
      const token = getStoredToken();

      if (!token) {
        setStatus("Admin token is missing. Open another admin page and enter it once.", "error");
        return;
      }

      const confirmed = window.confirm(
        "Prepare and email a requester-specific controlled download for this licence?\n\n" +
          "This will reserve a Download ID, generate the PDF if needed, activate the link, and email the recipient landing page. The admin page will not open or test the URL automatically."
      );

      if (!confirmed) {
        return;
      }

      detailCard.hidden = false;
      downloadLinkCard.hidden = false;
      resetDownloadLinkPanel();
      downloadLinkStatus.dataset.state = "neutral";
      downloadLinkStatus.textContent = "Preparing requester-specific PDF and emailing controlled download…";

      let response;
      let data;

      try {
        response = await fetch(
          `/api/admin/cdas/licences/${encodeURIComponent(licenceId)}/email-download-link`,
          {
            method: "POST",
            headers: {
              Authorization: `Bearer ${token}`,
              "Content-Type": "application/json",
            },
            body: JSON.stringify({}),
          }
        );

        data = await readJsonResponse(response, response.url || "admin API endpoint");
      } catch (error) {
        downloadLinkStatus.dataset.state = "error";
        downloadLinkStatus.textContent = `Could not prepare and email controlled download: ${error.message}`;
        return;
      }

      if (!response.ok || !data.ok) {
        downloadLinkStatus.dataset.state = "error";
        downloadLinkStatus.textContent =
          data?.message || data?.error || "Controlled download workflow could not be completed.";

        const blockers = Array.isArray(data?.blockers) ? data.blockers : [];
        const warnings = Array.isArray(data?.warnings) ? data.warnings : [];

        downloadLinkGrid.innerHTML = [
          downloadLinkRow("Error", data?.error),
          downloadLinkRow("Message", data?.message),
          downloadLinkRow("Blockers", renderDownloadLinkList(blockers), { html: true }),
          downloadLinkRow("Warnings", renderDownloadLinkList(warnings), { html: true }),
        ].join("");

        if (data?.issue_result || data?.generation_result) {
          downloadLinkControls.innerHTML = [
            downloadLinkRow("Reservation result", data.issue_result ? "Present" : "None"),
            downloadLinkRow("Generation result", data.generation_result ? "Present" : "None"),
          ].join("");
        }

        return;
      }

      renderDownloadWorkflowData(data, "prepare");

      downloadLinkCard.scrollIntoView({ behavior: "smooth", block: "start" });

      if (data.emailed) {
        setStatus("CDAS download prepared, activated, and emailed.", "success");
      } else {
        setStatus("CDAS download prepared and activated, but email was not sent. Review the result panel.", "error");
      }
    }

    async function reissueDownload(licenceId) {
      const token = getStoredToken();

      if (!token) {
        setStatus("Admin token is missing. Open another admin page and enter it once.", "error");
        return;
      }

      const confirmed = window.confirm(
        "Reissue this controlled download?\n\n" +
          "This creates a new licensed copy with a new Download ID.\n\n" +
          "Use this only when the previous link was used, expired, failed, revoked, superseded, or otherwise unavailable. The new recipient landing URL will be emailed to the licence holder."
      );

      if (!confirmed) {
        return;
      }
      detailCard.hidden = false;
      downloadLinkCard.hidden = false;
      resetDownloadLinkPanel();
      downloadLinkStatus.dataset.state = "neutral";
      downloadLinkStatus.textContent = "Reissuing controlled download with a new Download ID…";

      let response;
      let data;

      try {
        response = await fetch(
          `/api/admin/cdas/licences/${encodeURIComponent(licenceId)}/reissue-download-link`,
          {
            method: "POST",
            headers: {
              Authorization: `Bearer ${token}`,
              "Content-Type": "application/json",
            },
            body: JSON.stringify({
              confirm_reissue: true,
              action: "reissue_download",
            }),
          }
        );

        data = await readJsonResponse(response, response.url || "admin API endpoint");
      } catch (error) {
        downloadLinkStatus.dataset.state = "error";
        downloadLinkStatus.textContent = `Could not reissue controlled download: ${error.message}`;
        return;
      }

      if (!response.ok || !data.ok) {
        downloadLinkStatus.dataset.state = "error";
        downloadLinkStatus.textContent =
          data?.message || data?.error || "Controlled download reissue could not be completed.";

        const blockers = Array.isArray(data?.blockers) ? data.blockers : [];
        const warnings = Array.isArray(data?.warnings) ? data.warnings : [];

        downloadLinkGrid.innerHTML = [
          downloadLinkRow("Error", data?.error),
          downloadLinkRow("Message", data?.message),
          downloadLinkRow("Blockers", renderDownloadLinkList(blockers), { html: true }),
          downloadLinkRow("Warnings", renderDownloadLinkList(warnings), { html: true }),
        ].join("");

        return;
      }

      renderDownloadWorkflowData(data, "reissue");

      downloadLinkCard.scrollIntoView({ behavior: "smooth", block: "start" });

      if (data.emailed) {
        setStatus("CDAS download reissued, activated, and emailed.", "success");
      } else {
        setStatus("CDAS download reissued and activated, but email was not sent. Review the result panel.", "error");
      }
    }

    function resetDetailPanels() {
      renderedEvidenceCard.hidden = true;
      generationPreviewCard.hidden = true;
      pdfInspectionCard.hidden = true;
      downloadLinkCard.hidden = true;
      downloadHistoryCard.hidden = true;
      evidenceBundleCard.hidden = true;

      renderedMeta.innerHTML = "";
      renderedBody.textContent = "";

      generationStatus.textContent = "";
      generationStatus.dataset.state = "neutral";
      generationGrid.innerHTML = "";
      generationControls.innerHTML = "";

      pdfInspectionStatus.textContent = "";
      pdfInspectionStatus.dataset.state = "neutral";
      pdfInspectionGrid.innerHTML = "";
      pdfInspectionControls.innerHTML = "";

      resetDownloadLinkPanel();
      resetDownloadHistoryPanel();
      resetEvidenceBundlePanel();
    }

    async function loadLicenceDetail(licenceId) {
      const token = getStoredToken();

      if (!token) {
        setStatus("Admin token is missing. Open another admin page and enter it once.", "error");
        return;
      }

      setStatus("Loading licence detail…");
      resetDetailPanels();

      let response;
      let data;

      try {
        response = await fetch(`/api/admin/cdas/licences/${encodeURIComponent(licenceId)}`, {
          headers: {
            Authorization: `Bearer ${token}`,
          },
        });

        data = await readJsonResponse(response, response.url || "admin API endpoint");
      } catch (error) {
        setStatus(`Could not load licence detail: ${error.message}`, "error");
        return;
      }

      if (!response.ok || !data.ok || !data.row) {
        setStatus(data?.message || data?.error || "Licence detail could not be loaded.", "error");
        return;
      }

      const row = data.row;

      detailSubtitle.textContent = `${row.licence_number} — ${row.licence_holder_name || row.licence_holder_email_normalised || "Unknown holder"}`;

      detailSections.innerHTML = [
        renderDetailSection("Licence", [
          detailItem("Licence ID", row.id),
          detailItem("Licence number", row.licence_number),
          detailItem("Status", row.status),
          detailItem("Issued at", formatDate(row.issued_at)),
          detailItem("Expires at", formatDate(row.expires_at)),
          detailItem("Revoked at", formatDate(row.revoked_at)),
          detailItem("Revoked by", row.revoked_by),
          detailItem("Revocation reason", row.revocation_reason, { wide: true }),
          detailItem("Superseded by", row.superseded_by),
          detailItem("Corrected from", row.corrected_from),
          detailItem("Suspected leak at", formatDate(row.suspected_leak_at)),
          detailItem("Confirmed leak at", formatDate(row.confirmed_leak_at)),
          detailItem("Notes", row.notes, { wide: true }),
        ]),

        renderDetailSection("Holder", [
          detailItem("Holder type", row.licence_holder_type),
          detailItem("Holder name", row.licence_holder_name),
          detailItem("Organisation", row.organisation_name),
          detailItem("Contact name", row.contact_name),
          detailItem("Contact email", row.contact_email),
          detailItem("Holder email", row.licence_holder_email),
          detailItem("Normalised email", row.licence_holder_email_normalised),
          detailItem("Recipient category", row.recipient_category),
        ]),

        renderDetailSection("Document", [
          detailItem("Document ID", row.document_id),
          detailItem("Document version", row.document_version),
          detailItem("Request ID", row.request_id),
          detailItem("Licence terms version", row.licence_terms_version),
          detailItem("Source object", row.source_object, { wide: true }),
          detailItem("Source SHA-256", row.source_sha256, { wide: true }),
        ]),

        renderDetailSection("Generated PDF evidence", [
          detailItem("Generated PDF status", row.generated_pdf_status),
          detailItem("Generated PDF created at", formatDate(row.generated_pdf_created_at)),
          detailItem("Generated PDF filename", row.generated_pdf_filename, { wide: true }),
          detailItem("Generated PDF object key", row.generated_pdf_object_key, { wide: true }),
          detailItem("Generated PDF SHA-256", row.generated_pdf_sha256, { wide: true }),
          detailItem("Generated PDF size", row.generated_pdf_size_bytes),
          detailItem("Generated PDF content type", row.generated_pdf_content_type),
          detailItem("Generated PDF error", row.generated_pdf_error, { wide: true }),
        ]),

        renderDetailSection("Rendered licence evidence", [
          detailItem("Rendered licence SHA-256", row.rendered_licence_sha256, { wide: true }),
          detailItem("Rendered terms body SHA-256", row.rendered_terms_body_sha256, { wide: true }),
          detailItem("Rendered at", formatDate(row.rendered_licence_at)),
          detailItem("Placeholders", row.rendered_licence_placeholders, { wide: true }),
          detailItem("Unresolved placeholders", row.rendered_licence_unresolved_placeholders, { wide: true }),
        ]),
      ].join("");

      renderRenderedEvidence(row);

      detailCard.hidden = false;
      detailCard.scrollIntoView({ behavior: "smooth", block: "start" });

      setStatus("Licence detail loaded.", "success");
    }

    licencesBody.addEventListener("click", (event) => {
      const viewButton = event.target.closest("[data-view-licence]");
      const generationButton = event.target.closest("[data-generation-preview]");
      const inspectPdfButton = event.target.closest("[data-inspect-pdf]");
      const downloadHistoryButton = event.target.closest("[data-download-history]");
      const evidenceBundleButton = event.target.closest("[data-evidence-bundle]");
      const archiveEvidenceBundleButton = event.target.closest("[data-archive-evidence-bundle]");
      const prepareEmailDownloadButton = event.target.closest("[data-prepare-email-download]");
      const reissueDownloadButton = event.target.closest("[data-reissue-download]");

      if (viewButton) {
        loadLicenceDetail(viewButton.dataset.viewLicence);
        return;
      }

      if (generationButton) {
        renderGenerationPreview(generationButton.dataset.generationPreview);
        return;
      }

      if (inspectPdfButton) {
        renderPdfInspection(inspectPdfButton.dataset.inspectPdf);
        return;
      }

      if (downloadHistoryButton) {
        renderDownloadHistory(downloadHistoryButton.dataset.downloadHistory);
        return;
      }

      if (evidenceBundleButton) {
        renderEvidenceBundle(evidenceBundleButton.dataset.evidenceBundle);
        return;
      }

      if (archiveEvidenceBundleButton) {
        archiveEvidenceBundle(archiveEvidenceBundleButton.dataset.archiveEvidenceBundle);
        return;
      }

      if (prepareEmailDownloadButton) {
        prepareAndEmailDownload(prepareEmailDownloadButton.dataset.prepareEmailDownload);
        return;
      }

      if (reissueDownloadButton) {
        reissueDownload(reissueDownloadButton.dataset.reissueDownload);
      }
    });

    evidenceBundleControls.addEventListener("click", (event) => {
      const downloadButton = event.target.closest("[data-download-evidence-bundle-json]");

      if (!downloadButton || !latestEvidenceBundle) {
        return;
      }

      downloadJsonFile(evidenceBundleFileName(latestEvidenceBundle), latestEvidenceBundle);
    });

    copyDownloadLinkButton.addEventListener("click", async () => {
      const value = downloadLinkUrlInput.value;

      if (!value) {
        return;
      }

      try {
        await navigator.clipboard.writeText(value);
        setStatus("Recipient landing URL copied to clipboard.", "success");
      } catch {
        downloadLinkUrlInput.select();
        document.execCommand("copy");
        setStatus("Recipient landing URL copied to clipboard.", "success");
      }
    });

    closeDetailButton.addEventListener("click", () => {
      detailCard.hidden = true;
      resetDetailPanels();
    });

    filtersForm.addEventListener("submit", (event) => {
      event.preventDefault();
      state.offset = 0;
      fetchLicences();
    });

    resetFiltersButton.addEventListener("click", () => {
      filtersForm.reset();
      state.offset = 0;
      fetchLicences();
    });

    refreshButton.addEventListener("click", () => {
      fetchLicences();
    });

    fetchLicences();
  </script>
</BaseLayout>