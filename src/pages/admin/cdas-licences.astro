---
import BaseLayout from "../../layouts/BaseLayout.astro";
import AdminTokenPanel from "../../components/AdminTokenPanel.astro";

const pageTitle = "CDAS Licences Admin";
const pageDescription =
  "Read-only admin view for RelayHub Controlled Document Access System licence records.";
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <main class="rh-admin-page">
    <section class="rh-admin-hero">
      <p class="rh-eyebrow">RelayHub Admin</p>
      <h1>CDAS Licences</h1>
      <p>
        Read-only view of issued CDAS licence records and their rendered licence
        evidence. This page does not revoke or alter licence records. It can issue controlled
        one-time download links through the CDAS admin workflow.
      </p>
    </section>

    <AdminTokenPanel />

    <section class="rh-admin-grid rh-admin-summary-grid" aria-label="CDAS licence summary">
      <article class="rh-admin-metric">
        <span>Total licences</span>
        <strong id="metric-total">—</strong>
      </article>

      <article class="rh-admin-metric">
        <span>Active</span>
        <strong id="metric-active">—</strong>
      </article>

      <article class="rh-admin-metric">
        <span>Evidence captured</span>
        <strong id="metric-rendered">—</strong>
      </article>

      <article class="rh-admin-metric">
        <span>Leak flags</span>
        <strong id="metric-leaks">—</strong>
      </article>
    </section>

    <section class="rh-admin-card">
      <div class="rh-admin-section-heading">
        <div>
          <h2>Licence registry</h2>
          <p>
            Search and filter issued CDAS licence records.
          </p>
        </div>

        <div class="rh-admin-actions">
          <button class="rh-button rh-button-secondary" id="refresh-button" type="button">
            Refresh
          </button>
        </div>
      </div>

      <form class="rh-admin-filters" id="filters-form">
        <label>
          Search
          <input id="filter-q" name="q" type="search" placeholder="Licence, email, document, holder…" />
        </label>

        <label>
          Document
          <input id="filter-document" name="document_id" type="search" placeholder="relayhub-overview" />
        </label>

        <label>
          Status
          <select id="filter-status" name="status">
            <option value="">All statuses</option>
            <option value="active">active</option>
            <option value="revoked">revoked</option>
            <option value="superseded">superseded</option>
            <option value="corrected">corrected</option>
            <option value="expired">expired</option>
          </select>
        </label>

        <div class="rh-admin-filter-actions">
          <button class="rh-button rh-button-primary" type="submit">
            Apply filters
          </button>
          <button class="rh-button rh-button-secondary" id="reset-filters" type="button">
            Reset
          </button>
        </div>
      </form>

      <div class="rh-admin-status" id="status-message" role="status" aria-live="polite">
        Ready.
      </div>

      <div class="rh-admin-table-wrap">
        <table class="rh-admin-table">
          <thead>
            <tr>
              <th>Licence</th>
              <th>Holder</th>
              <th>Document</th>
              <th>Status</th>
              <th>Evidence</th>
              <th>Issued</th>
            </tr>
          </thead>
          <tbody id="licences-body">
            <tr>
              <td colspan="6" class="rh-admin-empty">
                No records loaded yet.
              </td>
            </tr>
          </tbody>
        </table>
      </div>
    </section>

    <section class="rh-admin-card rh-admin-detail-card" id="detail-card" hidden>
      <div class="rh-admin-section-heading">
        <div>
          <h2>Licence detail</h2>
          <p id="detail-subtitle">
            Selected CDAS licence record.
          </p>
        </div>

        <button class="rh-button rh-button-secondary" id="close-detail" type="button">
          Close
        </button>
      </div>

      <div class="rh-detail-sections" id="detail-sections"></div>

      <section class="rh-rendered-evidence" id="rendered-evidence-card" hidden>
        <div class="rh-rendered-heading">
          <div>
            <p class="rh-eyebrow">Captured evidence</p>
            <h3>Rendered issued licence</h3>
            <p>
              Exact licence text captured at licence issue time. This is stored
              evidence, not a live template preview.
            </p>
          </div>
        </div>

        <div class="rh-evidence-grid" id="rendered-meta"></div>

        <div class="rh-rendered-body-wrap">
          <div class="rh-rendered-body-heading">
            <h4>Exact rendered licence body</h4>
          </div>
          <pre class="rh-rendered-body" id="rendered-body"></pre>
        </div>
      </section>

      <section class="rh-generation-preview" id="generation-preview-card" hidden>
        <div class="rh-generation-heading">
          <div>
            <p class="rh-eyebrow">Generation gate</p>
            <h3>PDF generation readiness</h3>
            <p>
              Preview-only generation readiness check. This does not generate a PDF,
              write to R2, create a download link, or serve a document.
            </p>
          </div>
        </div>

        <div class="rh-generation-status" id="generation-status"></div>

        <div class="rh-generation-grid" id="generation-grid"></div>

        <div class="rh-generation-controls" id="generation-controls"></div>
      </section>

      <section class="rh-pdf-inspection" id="pdf-inspection-card" hidden>
        <div class="rh-pdf-inspection-heading">
          <div>
            <p class="rh-eyebrow">Generated PDF inspection</p>
            <h3>Generated PDF evidence check</h3>
            <p>
              Admin-only inspection of the private generated PDF object. This does not
              create a download link, serve the PDF, mutate the database, or expose
              public access.
            </p>
          </div>
        </div>

        <div class="rh-pdf-inspection-status" id="pdf-inspection-status"></div>

        <div class="rh-pdf-inspection-grid" id="pdf-inspection-grid"></div>

        <div class="rh-pdf-inspection-controls" id="pdf-inspection-controls"></div>
      </section>

      <section class="rh-download-link-issue" id="download-link-card" hidden>
        <div class="rh-download-link-heading">
          <div>
            <p class="rh-eyebrow">Controlled download workflow</p>
            <h3>Prepare and email download</h3>
            <p>
              Admin-only operator workflow for preparing a requester-specific PDF,
              activating a one-time controlled download link, and emailing the
              recipient landing page. This panel must never expose private R2 URLs.
            </p>
          </div>
        </div>

        <div class="rh-download-link-status" id="download-link-status"></div>

        <div class="rh-download-link-url-card" id="download-link-url-card" hidden>
          <label for="download-link-url">Recipient landing URL</label>
          <div class="rh-download-link-copy-row">
            <input id="download-link-url" type="text" readonly />
            <button class="rh-button rh-button-primary" id="copy-download-link" type="button">
              Copy link
            </button>
          </div>
          <p>
            This URL is returned once by the Worker and is emailed to the recipient.
            Only the token hash is stored. Do not use this link unless intentionally
            consuming the single-use download.
          </p>
        </div>

        <div class="rh-download-link-grid" id="download-link-grid"></div>

        <div class="rh-download-link-controls" id="download-link-controls"></div>
      </section>

      <section class="rh-download-history" id="download-history-card" hidden>
        <div class="rh-download-history-heading">
          <div>
            <p class="rh-eyebrow">Licence evidence trail</p>
            <h3>Download history</h3>
            <p>
              Read-only operator view of controlled download links, email events,
              download events, dangerous states, and timeline evidence for this licence.
              This panel does not generate PDFs, send email, expose raw tokens, or mutate data.
            </p>
          </div>
        </div>

        <div class="rh-download-history-status" id="download-history-status"></div>

        <div class="rh-download-history-grid" id="download-history-summary"></div>

        <div class="rh-download-history-subsection">
          <h4>Dangerous states</h4>
          <div class="rh-download-history-grid" id="download-history-dangerous-states"></div>
        </div>

        <div class="rh-download-history-subsection">
          <h4>Download links</h4>
          <div class="rh-download-history-grid" id="download-history-links"></div>
        </div>

        <div class="rh-download-history-subsection">
          <h4>Email events</h4>
          <div class="rh-download-history-grid" id="download-history-email-events"></div>
        </div>

        <div class="rh-download-history-subsection">
          <h4>Timeline</h4>
          <div class="rh-download-history-timeline" id="download-history-timeline"></div>
        </div>

        <div class="rh-download-history-controls" id="download-history-controls"></div>
      </section>

      <section class="rh-download-history" id="evidence-bundle-card" hidden>
        <div class="rh-download-history-heading">
          <div>
            <p class="rh-eyebrow">Evidence export</p>
            <h3>Licence evidence bundle</h3>
            <p>
              Read-only JSON evidence bundle for this licence. This exports the licence,
              document, generated PDF evidence, download links, email events, download events,
              dangerous-state summary, integrity summary, and timeline evidence. It does not
              generate PDFs, create links, send email, serve downloads, expose raw tokens,
              expose token hashes, or expose private R2 URLs.
            </p>
          </div>
        </div>

        <div class="rh-download-history-status" id="evidence-bundle-status"></div>

        <div class="rh-download-history-grid" id="evidence-bundle-summary"></div>

        <div class="rh-download-history-subsection">
          <h4>Integrity summary</h4>
          <div class="rh-download-history-grid" id="evidence-bundle-integrity"></div>
        </div>

        <div class="rh-download-history-subsection">
          <h4>Export preview</h4>
          <pre class="rh-rendered-body" id="evidence-bundle-preview"></pre>
        </div>

        <div class="rh-download-history-controls" id="evidence-bundle-controls"></div>
      </section>
    </section>
  </main>
  <style>
    .rh-admin-page {
      width: min(1220px, calc(100% - 2rem));
      margin: 0 auto;
      padding: 7rem 0 5rem;
    }

    .rh-admin-hero {
      margin-bottom: 1.5rem;
      padding: 2rem;
      border: 1px solid rgba(15, 23, 42, 0.12);
      border-radius: 1.5rem;
      background:
        radial-gradient(circle at top left, rgba(59, 130, 246, 0.12), transparent 36rem),
        linear-gradient(135deg, rgba(255,255,255,0.96), rgba(248,250,252,0.96));
      box-shadow: 0 24px 70px rgba(15, 23, 42, 0.08);
    }

    .rh-admin-hero h1 {
      margin: 0.35rem 0 0.75rem;
      font-size: clamp(2rem, 5vw, 3.5rem);
      line-height: 1;
      letter-spacing: -0.05em;
    }

    .rh-admin-hero p {
      max-width: 860px;
      margin: 0;
      color: rgba(15, 23, 42, 0.74);
      font-size: 1.05rem;
      line-height: 1.7;
    }

    .rh-eyebrow {
      margin: 0;
      color: #2563eb;
      font-size: 0.76rem;
      font-weight: 900;
      letter-spacing: 0.14em;
      text-transform: uppercase;
    }

    .rh-admin-card,
    .rh-admin-metric {
      border: 1px solid rgba(15, 23, 42, 0.12);
      border-radius: 1.25rem;
      background: rgba(255, 255, 255, 0.96);
      box-shadow: 0 18px 50px rgba(15, 23, 42, 0.07);
    }

    .rh-admin-card {
      padding: 1.25rem;
      margin-top: 1rem;
    }

    .rh-admin-section-heading {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 1rem;
    }

    .rh-admin-card h2,
    .rh-admin-section-heading h2 {
      margin: 0;
      color: #0f172a;
      font-size: 1.25rem;
      letter-spacing: -0.03em;
    }

    .rh-admin-card p,
    .rh-admin-section-heading p {
      margin: 0.35rem 0 0;
      color: rgba(15, 23, 42, 0.67);
      line-height: 1.6;
    }

    .rh-admin-grid {
      display: grid;
      gap: 1rem;
    }

    .rh-admin-summary-grid {
      grid-template-columns: repeat(4, minmax(0, 1fr));
      margin: 1rem 0;
    }

    .rh-admin-metric {
      padding: 1rem;
    }

    .rh-admin-metric span {
      display: block;
      color: rgba(15, 23, 42, 0.62);
      font-size: 0.82rem;
      font-weight: 800;
      letter-spacing: 0.04em;
      text-transform: uppercase;
    }

    .rh-admin-metric strong {
      display: block;
      margin-top: 0.4rem;
      color: #0f172a;
      font-size: 2rem;
      line-height: 1;
    }

    .rh-admin-actions,
    .rh-admin-filter-actions {
      display: flex;
      gap: 0.5rem;
      flex-wrap: wrap;
      justify-content: flex-end;
    }

    .rh-admin-filters {
      display: grid;
      grid-template-columns: 1.4fr 1fr 1fr;
      gap: 0.85rem;
      align-items: end;
      margin: 1.25rem 0 1rem;
    }

    .rh-admin-filters label {
      display: grid;
      gap: 0.35rem;
      color: rgba(15, 23, 42, 0.8);
      font-size: 0.88rem;
      font-weight: 700;
    }

    .rh-admin-filters input,
    .rh-admin-filters select {
      width: 100%;
      border: 1px solid rgba(15, 23, 42, 0.18);
      border-radius: 0.8rem;
      padding: 0.75rem 0.85rem;
      background: #fff;
      color: #0f172a;
      font: inherit;
    }

    .rh-admin-filter-actions {
      grid-column: 1 / -1;
    }

    .rh-button {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 2.75rem;
      border: 1px solid transparent;
      border-radius: 999px;
      padding: 0.65rem 1rem;
      font: inherit;
      font-weight: 800;
      cursor: pointer;
      transition:
        transform 150ms ease,
        background 150ms ease,
        border-color 150ms ease,
        color 150ms ease;
      white-space: nowrap;
    }

    .rh-button:hover {
      transform: translateY(-1px);
    }

    .rh-button-primary {
      background: #0f172a;
      color: #fff;
      border-color: #0f172a;
    }

    .rh-button-primary:hover {
      background: #1e293b;
      color: #fff;
    }

    .rh-button-secondary {
      background: #fff;
      color: #0f172a;
      border-color: rgba(15, 23, 42, 0.18);
    }

    .rh-button-secondary:hover {
      background: #f8fafc;
      color: #0f172a;
      border-color: rgba(15, 23, 42, 0.34);
    }

    .rh-button-warning {
      background: #92400e;
      color: #fff;
      border-color: #92400e;
    }

    .rh-button-warning:hover {
      background: #78350f;
      color: #fff;
      border-color: #78350f;
    }

    .rh-admin-status {
      margin: 1rem 0;
      padding: 0.85rem 1rem;
      border-radius: 0.9rem;
      background: #f8fafc;
      color: rgba(15, 23, 42, 0.75);
      font-size: 0.95rem;
    }

    .rh-admin-status[data-state="error"] {
      background: #fef2f2;
      color: #991b1b;
    }

    .rh-admin-status[data-state="success"] {
      background: #f0fdf4;
      color: #166534;
    }

    .rh-admin-table-wrap {
      overflow-x: auto;
      border: 1px solid rgba(15, 23, 42, 0.1);
      border-radius: 1rem;
    }

    .rh-admin-table {
      width: 100%;
      min-width: 1040px;
      border-collapse: collapse;
      background: #fff;
      font-size: 0.92rem;
    }

    .rh-admin-table th,
    .rh-admin-table td {
      padding: 0.85rem;
      border-bottom: 1px solid rgba(15, 23, 42, 0.08);
      text-align: left;
      vertical-align: top;
    }

    .rh-admin-table th {
      background: #f8fafc;
      color: rgba(15, 23, 42, 0.74);
      font-size: 0.76rem;
      font-weight: 900;
      letter-spacing: 0.06em;
      text-transform: uppercase;
    }

    .rh-admin-table tr:last-child td {
      border-bottom: 0;
    }

    .rh-admin-empty {
      text-align: center;
      color: rgba(15, 23, 42, 0.58);
    }

    .rh-admin-title-stack,
    .rh-policy-stack {
      display: grid;
      gap: 0.18rem;
    }

    .rh-admin-title-stack strong {
      color: #0f172a;
    }

    .rh-admin-title-stack span,
    .rh-policy-stack span {
      color: rgba(15, 23, 42, 0.64);
      font-size: 0.82rem;
      word-break: break-word;
    }

    .rh-licence-main-row td {
      border-bottom: 0;
    }

    .rh-licence-actions-row td {
      padding-top: 0;
      background: linear-gradient(180deg, rgba(248, 250, 252, 0.52), rgba(255, 255, 255, 1));
      border-bottom: 1px solid rgba(15, 23, 42, 0.12);
    }

    .rh-admin-row-actions {
      display: flex;
      gap: 0.55rem;
      flex-wrap: wrap;
      justify-content: flex-start;
      align-items: center;
      padding: 0.65rem 0 0.2rem;
    }

    .rh-admin-row-actions .rh-button {
      min-height: 2.35rem;
      padding: 0.52rem 0.85rem;
      font-size: 0.86rem;
    }

    .rh-admin-row-actions-note {
      flex-basis: 100%;
      margin: 0.15rem 0 0;
      color: rgba(15, 23, 42, 0.55);
      font-size: 0.82rem;
      line-height: 1.45;
    }

    .rh-badge,
    .rh-evidence-pill {
      display: inline-flex;
      align-items: center;
      width: fit-content;
      border-radius: 999px;
      padding: 0.25rem 0.55rem;
      font-size: 0.78rem;
      font-weight: 800;
      white-space: nowrap;
    }

    .rh-badge {
      background: #f1f5f9;
      color: #334155;
    }

    .rh-badge-active,
    .rh-evidence-pill {
      background: #dcfce7;
      color: #166534;
    }

    .rh-badge-revoked,
    .rh-badge-expired {
      background: #fee2e2;
      color: #991b1b;
    }

    .rh-badge-superseded,
        .rh-badge-superseded,
    .rh-badge-corrected,
    .rh-evidence-pill-missing {
      background: #fef3c7;
      color: #92400e;
    }

    .rh-hash {
      display: block;
      max-width: 36ch;
      overflow-wrap: anywhere;
      line-height: 1.45;
      color: rgba(15, 23, 42, 0.72);
    }

    .rh-admin-detail-card {
      margin-top: 1rem;
    }

    .rh-detail-sections {
      display: grid;
      gap: 1rem;
      margin-top: 1rem;
    }

    .rh-detail-section {
      border: 1px solid rgba(15, 23, 42, 0.1);
      border-radius: 1rem;
      background: #fff;
      overflow: hidden;
    }

    .rh-detail-section-header {
      padding: 0.9rem 1rem;
      border-bottom: 1px solid rgba(15, 23, 42, 0.08);
      background: #f8fafc;
    }

    .rh-detail-section-header h3 {
      margin: 0;
      color: #0f172a;
      font-size: 1rem;
      letter-spacing: -0.02em;
    }

    .rh-detail-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 0;
    }

    .rh-detail-item {
      padding: 0.9rem 1rem;
      border-bottom: 1px solid rgba(15, 23, 42, 0.06);
    }

    .rh-detail-item:nth-child(odd) {
      border-right: 1px solid rgba(15, 23, 42, 0.06);
    }

    .rh-detail-item dt {
      color: rgba(15, 23, 42, 0.55);
      font-size: 0.72rem;
      font-weight: 900;
      letter-spacing: 0.06em;
      text-transform: uppercase;
    }

    .rh-detail-item dd {
      margin: 0.28rem 0 0;
      color: #0f172a;
      word-break: break-word;
      line-height: 1.55;
    }

    .rh-detail-item-wide {
      grid-column: 1 / -1;
      border-right: 0 !important;
    }

    .rh-rendered-evidence,
    .rh-generation-preview,
    .rh-pdf-inspection,
    .rh-download-link-issue,
    .rh-download-history {
      margin-top: 1.25rem;
      border: 1px solid rgba(15, 23, 42, 0.12);
      border-radius: 1rem;
      padding: 1rem;
      background: #fff;
    }

    .rh-rendered-evidence {
      background:
        radial-gradient(circle at top left, rgba(37, 99, 235, 0.08), transparent 28rem),
        #fff;
    }

    .rh-generation-preview {
      background:
        radial-gradient(circle at top left, rgba(22, 163, 74, 0.08), transparent 28rem),
        #fff;
    }

    .rh-pdf-inspection {
      background:
        radial-gradient(circle at top left, rgba(124, 58, 237, 0.08), transparent 28rem),
        #fff;
    }

    .rh-download-link-issue {
      background:
        radial-gradient(circle at top left, rgba(14, 165, 233, 0.1), transparent 28rem),
        #fff;
    }

    .rh-download-history {
      background:
        radial-gradient(circle at top left, rgba(245, 158, 11, 0.1), transparent 28rem),
        #fff;
    }

    .rh-rendered-heading,
    .rh-generation-heading,
    .rh-pdf-inspection-heading,
    .rh-download-link-heading,
    .rh-download-history-heading {
      margin-bottom: 1rem;
    }

    .rh-rendered-heading h3,
    .rh-generation-heading h3,
    .rh-pdf-inspection-heading h3,
    .rh-download-link-heading h3,
    .rh-download-history-heading h3 {
      margin: 0.25rem 0 0;
      color: #0f172a;
      font-size: 1.3rem;
      letter-spacing: -0.04em;
    }

    .rh-rendered-heading p:last-child,
    .rh-generation-heading p:last-child,
    .rh-pdf-inspection-heading p:last-child,
    .rh-download-link-heading p:last-child,
    .rh-download-history-heading p:last-child {
      margin: 0.35rem 0 0;
      color: rgba(15, 23, 42, 0.68);
      line-height: 1.6;
    }

    .rh-evidence-grid,
    .rh-generation-grid,
    .rh-generation-controls,
    .rh-pdf-inspection-grid,
    .rh-pdf-inspection-controls,
    .rh-download-link-grid,
    .rh-download-link-controls,
    .rh-download-history-grid,
    .rh-download-history-controls {
      display: grid;
      gap: 0.75rem;
    }

    .rh-evidence-grid {
      margin-bottom: 1rem;
    }

    .rh-generation-controls,
    .rh-pdf-inspection-controls,
    .rh-download-link-controls,
    .rh-download-history-controls {
      margin-top: 1rem;
    }

    .rh-evidence-row,
    .rh-generation-row,
    .rh-pdf-row,
    .rh-download-link-row,
    .rh-download-history-row {
      display: grid;
      grid-template-columns: 240px minmax(0, 1fr);
      gap: 1rem;
      align-items: start;
      padding: 0.85rem;
      border: 1px solid rgba(15, 23, 42, 0.08);
      border-radius: 0.85rem;
      background: #f8fafc;
    }

    .rh-evidence-row {
      grid-template-columns: 220px minmax(0, 1fr);
    }

    .rh-evidence-row dt,
    .rh-generation-row dt,
    .rh-pdf-row dt,
    .rh-download-link-row dt,
