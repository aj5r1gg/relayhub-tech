    function evidenceBundleFileName(data) {
      const licenceNumber = String(data?.licence?.licence_number || "cdas-licence")
        .toLowerCase()
        .replace(/[^a-z0-9]+/g, "-")
        .replace(/^-+|-+$/g, "");

      const bundleType = String(data?.bundle_type || "evidence-bundle")
        .toLowerCase()
        .replace(/[^a-z0-9]+/g, "-")
        .replace(/^-+|-+$/g, "");

      return `${licenceNumber}-${bundleType}-v${data?.bundle_version || 1}.json`;
    }

    function downloadJsonFile(fileName, data) {
      const blob = new Blob([JSON.stringify(data, null, 2)], {
        type: "application/json;charset=utf-8",
      });

      const objectUrl = URL.createObjectURL(blob);
      const link = document.createElement("a");
      link.href = objectUrl;
      link.download = fileName;
      document.body.appendChild(link);
      link.click();
      link.remove();
      URL.revokeObjectURL(objectUrl);
    }

    function renderEvidenceBundleData(data, mode = "export") {
      const bundle = data.bundle || data;
      const exportEvidence = data.export_evidence || {};
      const archiveEvidence = data.archive_evidence || {};
      const auditRecord = data.audit_record || {};
      const r2Archive = data.r2_archive || {};
      const actionControls = data.controls || {};

      const isArchive = mode === "archive" || Boolean(data.archive_record_type);

      const summary = bundle.summary || {};
      const downloadLinkSummary = summary.download_links || {};
      const emailSummary = summary.email_events || {};
      const downloadEventSummary = summary.download_events || {};
      const dangerousSummary = summary.dangerous_states || {};
      const timelineSummary = summary.timeline || {};
      const integrity = bundle.integrity_summary || {};
      const bundleControls = bundle.controls || {};
      const interpretation = bundle.operator_interpretation || {};

      latestEvidenceBundle = bundle;

      if ((dangerousSummary.critical || 0) > 0) {
        evidenceBundleStatus.dataset.state = "error";
      } else if ((dangerousSummary.warning || 0) > 0) {
        evidenceBundleStatus.dataset.state = "warning";
      } else {
        evidenceBundleStatus.dataset.state = "success";
      }

      if (isArchive) {
        evidenceBundleStatus.textContent = r2Archive.archived
          ? "CDAS licence evidence bundle was archived to R2 and the archive event was recorded."
          : data.message || "CDAS licence evidence bundle archive completed with warnings.";
      } else {
        evidenceBundleStatus.textContent = auditRecord.recorded
          ? "CDAS licence evidence bundle export was recorded and the JSON bundle is ready to download."
          : data.message || interpretation.message || "CDAS licence evidence bundle loaded.";
      }

      evidenceBundleSummary.innerHTML = [
        downloadHistoryRow(
          isArchive ? "Archive record type" : "Export record type",
          data.archive_record_type || data.export_record_type || "direct_evidence_bundle",
          { code: true }
        ),
        downloadHistoryRow(
          isArchive ? "Archive record version" : "Export record version",
          data.archive_record_version || data.export_record_version || "—"
        ),
        downloadHistoryRow("Audit recorded", booleanText(auditRecord.recorded)),
        downloadHistoryRow("Audit event ID", auditRecord.event_id || "—", { code: true }),
        downloadHistoryRow("Audit table", auditRecord.table || "—", { code: true }),
        downloadHistoryRow(
          isArchive ? "Archived at" : "Recorded at",
          formatDate(data.archived_at || data.recorded_at || archiveEvidence.archived_at || exportEvidence.recorded_at)
        ),

        downloadHistoryRow(
          "Bundle SHA-256",
          archiveEvidence.bundle_sha256 || exportEvidence.bundle_sha256 || "—",
          { code: true }
        ),
        downloadHistoryRow(
          "Bundle size bytes",
          archiveEvidence.bundle_size_bytes || exportEvidence.bundle_size_bytes || "—"
        ),

        ...(isArchive
          ? [
              downloadHistoryRow("R2 archived", booleanText(r2Archive.archived)),
              downloadHistoryRow("R2 object key", archiveEvidence.object_key || r2Archive.object_key || "—", { code: true }),
              downloadHistoryRow("Content type", archiveEvidence.content_type || r2Archive.content_type || "—", { code: true }),
            ]
          : []),

        downloadHistoryRow("Bundle type", bundle.bundle_type, { code: true }),
        downloadHistoryRow("Bundle version", bundle.bundle_version),
        downloadHistoryRow("Bundle generated at", formatDate(bundle.generated_at)),

        downloadHistoryRow(
          "Licence",
          `${bundle.licence?.licence_number || "—"} — ${bundle.licence?.status || "—"}`
