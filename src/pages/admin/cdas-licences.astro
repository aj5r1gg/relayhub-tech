        `, { html: true }),

        downloadHistoryRow("Email events", `
          <div class="rh-download-history-mini-grid">
            ${downloadHistoryMini("Total", emailSummary.total)}
            ${downloadHistoryMini("Sent", emailSummary.sent)}
            ${downloadHistoryMini("Failed", emailSummary.failed)}
            ${downloadHistoryMini("Skipped", emailSummary.skipped)}
            ${downloadHistoryMini("Retryable", emailSummary.retryable)}
            ${downloadHistoryMini("Latest", emailSummary.latest_status)}
          </div>
        `, { html: true }),

        downloadHistoryRow("Download events", `
          <div class="rh-download-history-mini-grid">
            ${downloadHistoryMini("Total", downloadEventSummary.total)}
            ${downloadHistoryMini("Successful", downloadEventSummary.successful)}
            ${downloadHistoryMini("Failed", downloadEventSummary.failed)}
          </div>
        `, { html: true }),

        downloadHistoryRow("Admin audit events", adminAuditSummary.total),
        downloadHistoryRow("Latest Download ID", linkSummary.latest_download_reference, { code: true }),
        downloadHistoryRow("Latest email provider ID", emailSummary.latest_provider_message_id, { code: true }),
      ].join("");

      downloadHistoryDangerousStates.innerHTML = renderDangerousStates(data.dangerous_states);
      downloadHistoryLinks.innerHTML = renderHistoryLinks(data.download_links);
      downloadHistoryEmailEvents.innerHTML = renderHistoryEmailEvents(data.email_events);
      downloadHistoryTimeline.innerHTML = renderHistoryTimeline(data.timeline);

      downloadHistoryControls.innerHTML = [
        downloadHistoryRow("Read only", booleanText(controls.read_only)),
        downloadHistoryRow("Mutates database", booleanText(controls.mutates_database)),
        downloadHistoryRow("Writes to R2", booleanText(controls.writes_to_r2)),
        downloadHistoryRow("Creates download link", booleanText(controls.creates_download_link)),
        downloadHistoryRow("Sends email", booleanText(controls.sends_email)),
        downloadHistoryRow("Serves download", booleanText(controls.serves_download)),
        downloadHistoryRow("Exposes raw token", booleanText(controls.exposes_raw_token)),
        downloadHistoryRow("Exposes token hash", booleanText(controls.exposes_token_hash)),
        downloadHistoryRow("Includes private R2 URL", booleanText(controls.includes_private_r2_url)),
        downloadHistoryRow("Evidence endpoint", booleanText(controls.evidence_endpoint)),
        downloadHistoryRow("Message", data.message),
      ].join("");

      downloadHistoryCard.hidden = false;
    }

    async function renderDownloadHistory(licenceId) {
      const token = getStoredToken();

      if (!token) {
        setStatus("Admin token is missing. Open another admin page and enter it once.", "error");
        return;
      }

      detailCard.hidden = false;
      downloadHistoryCard.hidden = false;
      downloadHistoryStatus.dataset.state = "neutral";
      downloadHistoryStatus.textContent = "Loading licence download history…";
      downloadHistorySummary.innerHTML = "";
      downloadHistoryDangerousStates.innerHTML = "";
      downloadHistoryLinks.innerHTML = "";
      downloadHistoryEmailEvents.innerHTML = "";
      downloadHistoryTimeline.innerHTML = "";
      downloadHistoryControls.innerHTML = "";

      let response;
      let data;

      try {
        response = await fetch(
          `/api/admin/cdas/licences/${encodeURIComponent(licenceId)}/download-history`,
          {
            headers: {
              Authorization: `Bearer ${token}`,
            },
          }
        );

        data = await response.json();
      } catch (error) {
        downloadHistoryStatus.dataset.state = "danger";
        downloadHistoryStatus.textContent = `Could not load download history: ${error.message}`;
        return;
      }

      if (!response.ok || !data.ok) {
        downloadHistoryStatus.dataset.state = "danger";
        downloadHistoryStatus.textContent =
          data?.message || data?.error || "Download history could not be loaded.";
        return;
      }

      renderDownloadHistoryData(data);

      downloadHistoryCard.scrollIntoView({ behavior: "smooth", block: "start" });

      setStatus("Licence download history loaded.", "success");
    }

        async function renderDetail(licenceId) {
      const token = getStoredToken();

      if (!token) {
        setStatus("Admin token is missing. Open another admin page and enter it once.", "error");
        return;
      }

      setStatus("Loading licence detail…");

      let response;
      let data;

      try {
        response = await fetch(
          `/api/admin/cdas/licences/${encodeURIComponent(licenceId)}`,
          {
            headers: {
              Authorization: `Bearer ${token}`,
            },
          }
        );

        data = await response.json();
      } catch (error) {
        setStatus(`Could not load licence detail: ${error.message}`, "error");
        return;
      }

      if (!response.ok || !data.ok || !data.licence) {
        setStatus(
          data?.message || data?.error || "Licence detail could not be loaded.",
          "error"
        );
        return;
      }

      const row = data.licence;

      detailSubtitle.textContent = `${row.licence_number} — ${row.licence_holder_email_normalised}`;

      detailSections.innerHTML = [
        renderDetailSection("Core licence information", [
          detailItem("Licence number", row.licence_number),
          detailItem("Licence ID", row.id),
          detailItem("Request ID", row.request_id),
          detailItem("Status", row.status),
          detailItem("Issued at", formatDate(row.issued_at)),
          detailItem("Expires at", formatDate(row.expires_at), { hideEmpty: true }),
        ]),
        renderDetailSection("Document binding", [
          detailItem("Document ID", row.document_id),
          detailItem("Document version", row.document_version),
          detailItem("Licence terms version", row.licence_terms_version),
        ]),
        renderDetailSection("Licence holder", [
          detailItem("Holder type", row.licence_holder_type),
          detailItem("Holder name", row.licence_holder_name),
          detailItem("Organisation", row.organisation_name, { hideEmpty: true }),
          detailItem("Holder email", row.licence_holder_email),
          detailItem("Normalised email", row.licence_holder_email_normalised),
          detailItem("Contact name", row.contact_name, { hideEmpty: true }),
          detailItem("Contact email", row.contact_email, { hideEmpty: true }),
          detailItem("Recipient category", row.recipient_category),
        ]),
        renderDetailSection("Generated PDF evidence", [
          detailItem("Generated PDF status", row.generated_pdf_status),
          detailItem("Generated PDF created at", formatDate(row.generated_pdf_created_at), { hideEmpty: true }),
          detailItem("Generated PDF object key", row.generated_pdf_object_key, { hideEmpty: true, wide: true }),
          detailItem("Generated PDF filename", row.generated_pdf_filename, { hideEmpty: true }),
          detailItem("Generated PDF SHA-256", row.generated_pdf_sha256, { hideEmpty: true, wide: true }),
          detailItem("Generated PDF size", row.generated_pdf_size_bytes, { hideEmpty: true }),
          detailItem("Generated PDF content type", row.generated_pdf_content_type, { hideEmpty: true }),
          detailItem("Generated PDF error", row.generated_pdf_error, { hideEmpty: true, wide: true }),
        ]),
        renderDetailSection("Status, correction, and leak tracking", [
          detailItem("Revoked at", formatDate(row.revoked_at), { hideEmpty: true }),
          detailItem("Revoked by", row.revoked_by, { hideEmpty: true }),
          detailItem("Revocation reason", row.revocation_reason, { hideEmpty: true, wide: true }),
          detailItem("Superseded by", row.superseded_by, { hideEmpty: true }),
          detailItem("Corrected from", row.corrected_from, { hideEmpty: true }),
          detailItem("Suspected leak at", formatDate(row.suspected_leak_at), { hideEmpty: true }),
          detailItem("Confirmed leak at", formatDate(row.confirmed_leak_at), { hideEmpty: true }),
          detailItem("Notes", row.notes, { hideEmpty: true, wide: true }),
        ]),
      ].join("");

      renderRenderedEvidence(row);

      detailCard.hidden = false;
      detailCard.scrollIntoView({ behavior: "smooth", block: "start" });

      setStatus("Licence detail loaded.", "success");
    }

    function resetDetailPanels() {
      renderedEvidenceCard.hidden = true;
      renderedBody.textContent = "";
      renderedMeta.innerHTML = "";

      generationPreviewCard.hidden = true;
      generationStatus.textContent = "";
      generationStatus.dataset.state = "neutral";
      generationGrid.innerHTML = "";
      generationControls.innerHTML = "";

      pdfInspectionCard.hidden = true;
      pdfInspectionStatus.textContent = "";
      pdfInspectionStatus.dataset.state = "neutral";
      pdfInspectionGrid.innerHTML = "";
      pdfInspectionControls.innerHTML = "";

      downloadLinkCard.hidden = true;
      resetDownloadLinkPanel();

      downloadHistoryCard.hidden = true;
      downloadHistoryStatus.textContent = "";
      downloadHistoryStatus.dataset.state = "neutral";
      downloadHistorySummary.innerHTML = "";
      downloadHistoryDangerousStates.innerHTML = "";
      downloadHistoryLinks.innerHTML = "";
      downloadHistoryEmailEvents.innerHTML = "";
      downloadHistoryTimeline.innerHTML = "";
      downloadHistoryControls.innerHTML = "";

      detailSections.innerHTML = "";
      detailSubtitle.textContent = "Selected CDAS licence record.";
    }

    filtersForm.addEventListener("submit", (event) => {
      event.preventDefault();
      state.offset = 0;
      fetchLicences();
    });

    resetFiltersButton.addEventListener("click", () => {
      filtersForm.reset();
      state.offset = 0;
      fetchLicences();
    });

    refreshButton.addEventListener("click", () => {
      fetchLicences();
    });

    licencesBody.addEventListener("click", (event) => {
      const target = event.target;

      if (!(target instanceof HTMLElement)) {
        return;
      }

      const viewButton = target.closest("[data-view-licence]");

      if (viewButton instanceof HTMLElement) {
        const licenceId = viewButton.dataset.viewLicence;

        if (licenceId) {
          renderDetail(licenceId);
        }

        return;
      }

      const generationButton = target.closest("[data-generation-preview]");

      if (generationButton instanceof HTMLElement) {
        const licenceId = generationButton.dataset.generationPreview;

        if (licenceId) {
          renderGenerationPreview(licenceId);
        }

        return;
      }

      const inspectPdfButton = target.closest("[data-inspect-pdf]");

      if (inspectPdfButton instanceof HTMLElement) {
        const licenceId = inspectPdfButton.dataset.inspectPdf;

        if (licenceId) {
          renderPdfInspection(licenceId);
        }

        return;
      }

      const downloadHistoryButton = target.closest("[data-download-history]");

      if (downloadHistoryButton instanceof HTMLElement) {
        const licenceId = downloadHistoryButton.dataset.downloadHistory;

        if (licenceId) {
          renderDownloadHistory(licenceId);
        }

        return;
      }

      const prepareEmailDownloadButton = target.closest("[data-prepare-email-download]");

      if (prepareEmailDownloadButton instanceof HTMLElement) {
        const licenceId = prepareEmailDownloadButton.dataset.prepareEmailDownload;

        if (licenceId) {
          prepareAndEmailDownload(licenceId);
        }

        return;
      }

      const reissueDownloadButton = target.closest("[data-reissue-download]");

      if (reissueDownloadButton instanceof HTMLElement) {
        const licenceId = reissueDownloadButton.dataset.reissueDownload;

        if (licenceId) {
          reissueDownload(licenceId);
        }
      }
    });

    copyDownloadLinkButton.addEventListener("click", async () => {
      const value = downloadLinkUrlInput.value;

      if (!value) {
        setStatus("No recipient landing URL is available to copy.", "error");
        return;
      }

      try {
        await navigator.clipboard.writeText(value);
        setStatus("Recipient landing URL copied to clipboard.", "success");
      } catch {
        downloadLinkUrlInput.focus();
        downloadLinkUrlInput.select();
        setStatus("Could not access clipboard. The link has been selected for manual copying.", "error");
      }
    });

    closeDetailButton.addEventListener("click", () => {
      detailCard.hidden = true;
      resetDetailPanels();
    });

    const existingToken = getStoredToken();

    if (existingToken) {
      setStatus("Admin token found in this browser session. Loading CDAS licences…");
      fetchLicences();
    } else {
      setStatus("Admin token is missing. Open another admin page and enter it once.", "error");
    }

    window.relayhubAdminTokenUpdated = () => {
      if (typeof fetchDownloadLinks === "function") {
        fetchDownloadLinks();
      }

      if (typeof fetchLicences === "function") {
        fetchLicences();
      }

      if (typeof fetchDocuments === "function") {
        fetchDocuments();
      }

      if (typeof fetchLicenceTerms === "function") {
        fetchLicenceTerms();
      }

      if (typeof fetchAccessRequests === "function") {
        fetchAccessRequests();
      }

      if (typeof loadDownloads === "function") {
        loadDownloads();
      }

      if (typeof loadContacts === "function") {
        loadContacts();
      }

      if (typeof loadNewsletter === "function") {
        loadNewsletter();
      }
    };

    window.relayhubAdminTokenCleared = () => {
      location.reload();
    };
  </script>
</BaseLayout>