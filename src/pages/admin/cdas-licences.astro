    function renderHistoryLinks(links) {
      const values = Array.isArray(links) ? links : [];

      if (!values.length) {
        return downloadHistoryRow("Download links", "No download links found.");
      }

      return values
        .map((link) => {
          const emailEvents = Array.isArray(link.matching_email_events)
            ? link.matching_email_events
            : [];

          const emailSummary = emailEvents.length
            ? emailEvents
                .map((event) => {
                  const providerId = event.provider_message_id
                    ? ` — ${event.provider_message_id}`
                    : "";

                  return `${event.email_type || "email"} ${event.status || "unknown"}${providerId}`;
                })
                .join("; ")
            : "None matched";

          const miniGrid = `
            <div class="rh-download-history-mini-grid">
              ${downloadHistoryMini("Status", link.status)}
              ${downloadHistoryMini("Class", link.classification)}
              ${downloadHistoryMini("Expired", booleanText(link.expired))}
              ${downloadHistoryMini("Evidence", booleanText(link.has_generated_pdf_evidence))}
              ${downloadHistoryMini("Created", formatDate(link.created_at))}
              ${downloadHistoryMini("Used", formatDate(link.used_at))}
            </div>
          `;

          return `
            <article class="rh-download-history-row">
              <dt>
                ${escapeHtml(link.download_reference || link.id || "Download link")}
              </dt>
              <dd>
                <div class="rh-download-history-code">
                  ${escapeHtml(link.id || "")}
                </div>

                ${miniGrid}

                <p>
                  <strong>Generated PDF:</strong><br />
                  <span class="rh-download-history-code">
                    ${escapeHtml(formatValue(link.generated_pdf_object_key))}
                  </span>
                </p>

                <p>
                  <strong>SHA-256:</strong><br />
                  <span class="rh-download-history-code">
                    ${escapeHtml(formatValue(link.generated_pdf_sha256))}
                  </span>
                </p>

                <p>
                  <strong>Size:</strong>
                  ${escapeHtml(formatValue(link.generated_pdf_size_bytes))}
                </p>

                <p>
                  <strong>Email events:</strong>
                  ${escapeHtml(emailSummary)}
                </p>

                ${
                  link.failure_reason
                    ? `<p><strong>Failure reason:</strong> ${escapeHtml(link.failure_reason)}</p>`
                    : ""
                }
              </dd>
            </article>
          `;
        })
        .join("");
    }

