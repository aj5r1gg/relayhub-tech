        downloadHistoryRow(
          "Email events",
          `Total: ${emailSummary.total || 0} | Sent: ${emailSummary.sent || 0} | Failed: ${emailSummary.failed || 0} | Retryable: ${emailSummary.retryable || 0}`
        ),
        downloadHistoryRow(
          "Download events",
          `Total: ${downloadEventSummary.total || 0} | Successful: ${downloadEventSummary.successful || 0} | Failed: ${downloadEventSummary.failed || 0}`
