    function timelineState(item) {
      if (item.success === false || String(item.status || "").toLowerCase() === "failed") {
        return "failed";
      }

      if (
        String(item.event_type || "").includes("denied") ||
        String(item.type || "").includes("revoked") ||
        String(item.status || "").toLowerCase() === "revoked"
      ) {
        return "warning";
      }

      return "normal";
    }

    function renderHistoryTimeline(items) {
      const values = Array.isArray(items) ? items : [];

      if (!values.length) {
        return `
          <article class="rh-timeline-item">
            <div class="rh-timeline-title">
              <strong>No timeline events found.</strong>
            </div>
          </article>
        `;
      }

      return values
        .map((item) => {
          const stateName = timelineState(item);

          const metaParts = [
            item.type ? `type=${item.type}` : "",
            item.status ? `status=${item.status}` : "",
            item.event_type ? `event=${item.event_type}` : "",
            item.download_reference ? `download_id=${item.download_reference}` : "",
            item.download_id ? `download_link=${item.download_id}` : "",
            item.provider_message_id ? `provider_message_id=${item.provider_message_id}` : "",
          ].filter(Boolean);

          return `
            <article class="rh-timeline-item" data-state="${escapeHtml(stateName)}">
              <div class="rh-timeline-title">
                <strong>${escapeHtml(item.label || item.type || "Timeline event")}</strong>
                <span>${escapeHtml(formatDate(item.at))}</span>
              </div>
              <div class="rh-timeline-meta">
                ${escapeHtml(metaParts.join(" · ") || item.id || "")}
              </div>
            </article>
          `;
        })
        .join("");
    }

    function renderDownloadHistoryData(data) {
      const summary = data.summary || {};
      const linkSummary = summary.links || {};
      const emailSummary = summary.email_events || {};
      const dangerousSummary = summary.dangerous_states || {};
      const downloadEventSummary = summary.download_events || {};
      const adminAuditSummary = summary.admin_audit_events || {};
      const interpretation = data.operator_interpretation || {};
      const controls = data.controls || {};

      const critical = Number(dangerousSummary.critical || 0);
      const warnings = Number(dangerousSummary.warning || 0);

      if (critical > 0) {
        downloadHistoryStatus.dataset.state = "danger";
      } else if (warnings > 0) {
        downloadHistoryStatus.dataset.state = "warning";
      } else {
        downloadHistoryStatus.dataset.state = "safe";
      }

      downloadHistoryStatus.textContent =
        `${interpretation.status || "unknown"} — ${interpretation.message || "Download history loaded."}`;

      downloadHistorySummary.innerHTML = [
        downloadHistoryRow("Licence", data.licence?.licence_number),
        downloadHistoryRow("Document", data.document?.title),
        downloadHistoryRow("Operator status", interpretation.status),
        downloadHistoryRow("Recommended next action", interpretation.recommended_next_action, { code: false }),

        downloadHistoryRow("Dangerous states", `
          <div class="rh-download-history-mini-grid">
            ${downloadHistoryMini("Total", dangerousSummary.total)}
            ${downloadHistoryMini("Critical", dangerousSummary.critical)}
            ${downloadHistoryMini("Warning", dangerousSummary.warning)}
          </div>
        `, { html: true }),

        downloadHistoryRow("Download links", `
          <div class="rh-download-history-mini-grid">
            ${downloadHistoryMini("Total", linkSummary.total)}
            ${downloadHistoryMini("Active unused", linkSummary.active_unused)}
            ${downloadHistoryMini("Pending", linkSummary.pending_generation)}
            ${downloadHistoryMini("Used", linkSummary.used)}
            ${downloadHistoryMini("Failed", linkSummary.failed)}
            ${downloadHistoryMini("Evidence", linkSummary.with_generated_pdf_evidence)}
