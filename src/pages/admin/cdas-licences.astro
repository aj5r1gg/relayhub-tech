        return;
      }

      detailCard.hidden = false;
      pdfInspectionCard.hidden = false;
      pdfInspectionStatus.dataset.state = "neutral";
      pdfInspectionStatus.textContent = "Inspecting generated PDF evidence…";
      pdfInspectionGrid.innerHTML = "";
      pdfInspectionControls.innerHTML = "";

      let response;
      let data;

      try {
        response = await fetch(
          `/api/admin/cdas/licences/${encodeURIComponent(licenceId)}/generated-pdf`,
          {
