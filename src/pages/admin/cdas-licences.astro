        downloadLinkRow("Email error", email.error, { code: true }),
        downloadLinkRow("Email message", email.message),
      ].join("");

      downloadLinkControls.innerHTML = [
        downloadLinkRow("Explicit reissue workflow", booleanText(controls.explicit_reissue_workflow)),
        downloadLinkRow("Full operator workflow", booleanText(controls.full_operator_workflow)),
        downloadLinkRow("Reserves new download link", booleanText(controls.reserves_new_download_link || controls.reserves_download_link_when_needed)),
        downloadLinkRow("Creates new Download ID", booleanText(controls.creates_new_download_id)),
        downloadLinkRow("Generates Download-ID-bound PDF", booleanText(controls.generates_new_download_id_bound_pdf || controls.generates_pdf_before_email)),
        downloadLinkRow("Binds generated PDF to link", booleanText(controls.binds_generated_pdf_to_new_download_link)),
        downloadLinkRow("Activates link before email", booleanText(controls.activates_link_before_email)),
        downloadLinkRow("Emails landing page URL", booleanText(controls.landing_page_url_emailed)),
        downloadLinkRow("Emails raw R2 URL", booleanText(controls.raw_r2_url_exposed)),
        downloadLinkRow("Emails download API URL", booleanText(controls.download_api_url_emailed)),
        downloadLinkRow("Single-use preserved", booleanText(controls.single_use_download_preserved)),
        downloadLinkRow("Stores raw token", booleanText(controls.stores_raw_token)),
        downloadLinkRow("Overwrites existing R2 object", booleanText(controls.overwrites_existing_r2_object)),
        downloadLinkRow("Message", data.message),
