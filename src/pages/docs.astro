---
import BaseLayout from "../layouts/BaseLayout.astro";

const startHere = [
  {
    title: "What is RelayHub?",
    text: "A local-first ecosystem for communication, coordination, recovery, knowledge sharing, trade, governance, and resilient communities.",
    href: "/",
    label: "Home",
  },
  {
    title: "What is RelayOS?",
    text: "The appliance platform that turns NixOS, Reticulum, policy, recovery, and local management into a usable node experience.",
    href: "/relayos",
    label: "RelayOS",
  },
  {
    title: "What is a node?",
    text: "A device participating in the RelayHub ecosystem according to its hardware class, role, policy, and validation status.",
    href: "/hardware",
    label: "Hardware",
  },
];

const userGuides = [
  {
    title: "Quick start",
    text: "Plug in the node, wait for setup status, scan the QR code, claim ownership, save recovery, and reach the dashboard.",
  },
  {
    title: "First setup",
    text: "Browser-first setup, owner claim, privacy reality screen, recovery prompt, node naming, readiness check, and first dashboard.",
  },
  {
    title: "Pairing and invites",
    text: "How owners, household admins, trusted users, guests, and recovery contacts pair safely using role-aware QR flows.",
  },
  {
    title: "Status meanings",
    text: "Understand Ready, Local-Only, No Peers, Degraded, Low Power, Updating, Rolled Back, Recovering, Factory Reset, and Error.",
  },
  {
    title: "Local-only operation",
    text: "Local-only does not mean broken. It means local functions may still work even when wider paths are unavailable.",
  },
  {
    title: "Recovery guide",
    text: "Restart, rollback, repair settings, restore access, support export, reset, transfer, and last-resort reflash guidance.",
  },
];

const coreDocs = [
  {
    title: "Products",
    text: "Relay Home, Relay Radio, Relay Infrastructure, product status, support boundaries, and future application families.",
    href: "/products",
    label: "Products",
  },
  {
    title: "Hardware",
    text: "Hardware classes, compatibility status, capability limits, recovery expectations, radio reality, and product-supported claims.",
    href: "/hardware",
    label: "Hardware",
  },
  {
    title: "RelayOS",
    text: "Platform overview, local web UI, policy gates, identity, trust, recovery, updates, observability, and Reticulum integration.",
    href: "/relayos",
    label: "RelayOS",
  },
  {
    title: "Trust",
    text: "Discovery, identity, reachability, permission, reputation, federation, revocation, and safe trust-state transitions.",
    href: "/trust",
    label: "Trust model",
  },
  {
    title: "Security",
    text: "Responsible disclosure, realistic threat boundaries, service exposure, least privilege, support redaction, and security posture.",
    href: "/security",
    label: "Security",
  },
  {
    title: "Recovery",
    text: "Rollback, safe reset, identity preservation, degraded boot, support exports, and practical recovery boundaries.",
    href: "/recovery",
    label: "Recovery",
  },
  {
    title: "Validation",
    text: "Release gates, hardware class testing, recovery drills, degraded operation, supported status, and experimental boundaries.",
    href: "/validation",
    label: "Validation",
  },
  {
    title: "Governance",
    text: "Principles, policies, trust model, community autonomy, recovery expectations, validation discipline, and responsibilities.",
    href: "/governance",
    label: "Governance",
  },
  {
    title: "Support",
    text: "Local help, support levels, redacted diagnostics, recovery paths, hardware-aware support, and explicit export.",
    href: "/support",
    label: "Support",
  },
];

const communityDocs = [
  {
    title: "Communities",
    text: "Households, groups, community operation, knowledge, trade, governance, cultural continuity, and voluntary federation.",
    href: "/communities",
    label: "Communities",
  },
  {
    title: "Community directory",
    text: "Future directory concept for discovery, visibility, community identity, trust status, and federation boundaries.",
    href: "/communities-directory",
    label: "Directory",
  },
  {
    title: "Marketplace",
    text: "Local goods, services, requests, skills exchange, community noticeboards, and settlement-neutral coordination.",
    href: "/marketplace",
    label: "Marketplace",
  },
];

const statuses = [
  {
    label: "Ready",
    className: "rh-status-ready",
    title: "Your node is ready.",
    text: "The node is running and the core services for its current role are available.",
  },
  {
    label: "Local-only",
    className: "rh-status-local",
    title: "Local communication may still work.",
    text: "Wider connectivity is unavailable, but local operation is not automatically broken.",
  },
  {
    label: "No peers",
    className: "rh-status-local",
    title: "No reachable peers found.",
    text: "The node may be working correctly even if no other nodes are currently visible.",
  },
  {
    label: "Degraded",
    className: "rh-status-degraded",
    title: "Reduced capability.",
    text: "Some features are limited, paused, blocked, or waiting for recovery.",
  },
  {
    label: "Updating",
    className: "rh-status-updating",
    title: "Update in progress.",
    text: "The node should preserve identity and recovery access while applying or rolling back updates.",
  },
  {
    label: "Recovery",
    className: "rh-status-error",
    title: "This node needs attention.",
    text: "Recovery should guide the user toward safe repair, rollback, reset, transfer, or support export.",
  },
];

const offlineDocs = [
  "Quick Start Card",
  "Status Meaning Card",
  "Recovery Card",
  "Privacy Reality Card",
  "Support Export Guide",
  "Factory Reset / Transfer Warning Card",
  "Radio Warning Card where applicable",
];

const standards = [
  "Use plain language before technical language.",
  "Distinguish implemented, planned, experimental, unsupported, and product-supported behaviour.",
  "Explain degraded operation as normal, not catastrophic.",
  "Include recovery paths wherever failure is possible.",
  "Avoid exaggerated claims about anonymity, delivery, emergency coverage, or radio legality.",
  "Version guides against product, hardware class, RelayOS version, and release status.",
  "Keep documentation readable, mobile-friendly, printable, and useful under stress.",
  "Treat documentation as part of validation, not as marketing decoration.",
];

const operatorDocs = [
  {
    title: "Architecture notes",
    text: "RelayOS layers, Local API design, policy engine, Reticulum integration, observability, service boundaries, and ADRs.",
  },
  {
    title: "Hardware manifests",
    text: "Capability manifests, hardware classes, supported roles, known limits, thermal/power profiles, and compatibility status.",
  },
  {
    title: "Validation artefacts",
    text: "Boot evidence, setup proof, recovery drills, rollback tests, field trial results, support export tests, and release gates.",
  },
];
---

<BaseLayout
  title="Documentation | RelayHub"
  description="RelayHub documentation hub for onboarding, products, hardware, RelayOS, trust, security, recovery, validation, privacy, governance, and community operation."
>
  <section class="rh-hero">
    <div class="rh-container rh-hero-inner">
      <p class="rh-eyebrow">Documentation</p>

      <h1 class="rh-title">
        Documentation is part of the product.
      </h1>

      <p class="rh-subtitle">
        RelayHub documentation is designed to help ordinary people set up,
        understand, operate, recover, and safely evaluate local-first
        communication infrastructure without needing to become Linux, networking,
        Reticulum, or radio experts.
      </p>

      <div class="rh-actions">
        <a class="rh-button rh-button-primary" href="#start-here">
          Start here
        </a>
        <a class="rh-button rh-button-secondary" href="/support">
          Support
        </a>
      </div>
    </div>
  </section>

  <section id="start-here" class="rh-section">
    <div class="rh-container">
      <p class="rh-kicker">Start here</p>

      <h2 class="rh-section-title">
        The first guides should answer the first questions.
      </h2>

      <p class="rh-section-lead">
        RelayHub documentation begins with what the system is, what it is not,
        what the user can do now, what remains planned, and what to do when the
        node changes state.
      </p>

      <div class="rh-grid rh-grid-3" style="margin-top: var(--space-10);">
        {startHere.map((item) => (
          <article class="rh-card">
            <h3 class="rh-card-title">{item.title}</h3>
            <p class="rh-card-text">{item.text}</p>
            <div class="rh-actions">
              <a class="rh-button rh-button-secondary" href={item.href}>
                {item.label}
              </a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="rh-section rh-dark">
    <div class="rh-container">
      <p class="rh-kicker">User guides</p>

      <h2 class="rh-section-title">
        Guides for ordinary users.
      </h2>

      <p class="rh-section-lead">
        These guides should focus on what the user sees, what it means, what
        still works, and what action is safe.
      </p>

      <div class="rh-grid rh-grid-3" style="margin-top: var(--space-10);">
        {userGuides.map((item) => (
          <article class="rh-card rh-card-dark">
            <h3 class="rh-card-title">{item.title}</h3>
            <p class="rh-card-text">{item.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="rh-section">
    <div class="rh-container">
      <p class="rh-kicker">Documentation hub</p>

      <h2 class="rh-section-title">
        Core documentation areas.
      </h2>

      <p class="rh-section-lead">
        RelayHub documentation follows the product architecture: products,
        hardware classes, RelayOS, trust, security, recovery, validation,
        governance, and support.
      </p>

      <div class="rh-grid rh-grid-3" style="margin-top: var(--space-10);">
        {coreDocs.map((item) => (
          <article class="rh-card">
            <h3 class="rh-card-title">{item.title}</h3>
            <p class="rh-card-text">{item.text}</p>
            <div class="rh-actions">
              <a class="rh-button rh-button-secondary" href={item.href}>
                {item.label}
              </a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="rh-section rh-bg-soft">
    <div class="rh-container">
      <p class="rh-kicker">Community documentation</p>

      <h2 class="rh-section-title">
        RelayHub is more than messaging.
      </h2>

      <p class="rh-section-lead">
        Community documentation should explain coordination, knowledge sharing,
        trade, governance, culture, federation, discovery, and trust boundaries.
      </p>

      <div class="rh-grid rh-grid-3" style="margin-top: var(--space-10);">
        {communityDocs.map((item) => (
          <article class="rh-card">
            <h3 class="rh-card-title">{item.title}</h3>
            <p class="rh-card-text">{item.text}</p>
            <div class="rh-actions">
              <a class="rh-button rh-button-secondary" href={item.href}>
                {item.label}
              </a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="rh-section">
    <div class="rh-container">
      <p class="rh-kicker">Status and recovery</p>

      <h2 class="rh-section-title">
        The most important documentation explains what still works.
      </h2>

      <p class="rh-section-lead">
        RelayHub should not leave users guessing. Every degraded state should
        explain what changed, what still works, what no longer works, and what
        to do next.
      </p>

      <div class="rh-grid rh-grid-3" style="margin-top: var(--space-10);">
        {statuses.map((item) => (
          <article class="rh-card">
            <span class={`rh-status ${item.className}`}>{item.label}</span>
            <h3 class="rh-card-title" style="margin-top: var(--space-5);">
              {item.title}
            </h3>
            <p class="rh-card-text">{item.text}</p>
          </article>
        ))}
      </div>

      <div class="rh-actions">
        <a class="rh-button rh-button-secondary" href="/recovery">
          Recovery model
        </a>
        <a class="rh-button rh-button-secondary" href="/validation">
          Validation model
        </a>
      </div>
    </div>
  </section>

  <section class="rh-section rh-bg-soft">
    <div class="rh-container rh-grid rh-grid-2">
      <div>
        <p class="rh-kicker">Offline documentation</p>

        <h2 class="rh-section-title">
          Critical help should not disappear when the internet fails.
        </h2>

        <p class="rh-section-lead">
          RelayHub documentation should include online pages, local node help,
          and printable/offline material for setup, status, recovery, privacy,
          radio reality, transfer, reset, and support.
        </p>
      </div>

      <article class="rh-card">
        <ul class="rh-docs-list">
          {offlineDocs.map((item) => <li>{item}</li>)}
        </ul>
      </article>
    </div>
  </section>

  <section class="rh-section rh-dark">
    <div class="rh-container">
      <p class="rh-kicker">Documentation standards</p>

      <h2 class="rh-section-title">
        Good documentation is honest documentation.
      </h2>

      <p class="rh-section-lead">
        RelayHub documentation should make clear distinctions between what
        exists, what is planned, what is experimental, what is unsupported, and
        what is product-supported.
      </p>

      <div class="rh-grid rh-grid-4" style="margin-top: var(--space-10);">
        {standards.map((item) => (
          <article class="rh-card rh-card-dark">
            <p class="rh-card-text">{item}</p>
          </article>
        ))}
      </div>

      <div class="rh-actions">
        <a class="rh-button rh-button-accent" href="/accessibility">
          Accessibility
        </a>
        <a class="rh-button rh-button-secondary" href="/security">
          Security
        </a>
      </div>
    </div>
  </section>

  <section class="rh-section">
    <div class="rh-container">
      <p class="rh-kicker">Developer and operator docs</p>

      <h2 class="rh-section-title">
        Technical documentation should support validation, not bypass it.
      </h2>

      <p class="rh-section-lead">
        Developer and operator documentation can go deeper, but it should still
        preserve the same rules: local-first, recovery-first, capability-aware,
        policy-governed, and validation-gated.
      </p>

      <div class="rh-grid rh-grid-3" style="margin-top: var(--space-10);">
        {operatorDocs.map((item) => (
          <article class="rh-card">
            <h3 class="rh-card-title">{item.title}</h3>
            <p class="rh-card-text">{item.text}</p>
          </article>
        ))}
      </div>

      <div class="rh-actions">
        <a class="rh-button rh-button-secondary" href="/developers">
          Developer page
        </a>
        <a class="rh-button rh-button-secondary" href="/hardware">
          Hardware page
        </a>
        <a class="rh-button rh-button-secondary" href="/roadmap">
          Roadmap
        </a>
      </div>
    </div>
  </section>

  <section class="rh-section rh-bg-soft">
    <div class="rh-container rh-grid rh-grid-2">
      <div>
        <p class="rh-kicker">Current docs status</p>

        <h2 class="rh-section-title">
          Documentation will grow with validation.
        </h2>

        <p class="rh-section-lead">
          RelayHub is still in design and validation planning. Documentation
          should clearly mark draft, planned, experimental, limited, unsupported,
          and product-supported material as the project matures.
        </p>
      </div>

      <article class="rh-card">
        <h3 class="rh-card-title">Follow documentation releases</h3>
        <p class="rh-card-text">
          Register interest for updates about quick starts, recovery guides,
          hardware compatibility notes, RelayOS documentation, developer
          resources, and future community guides.
        </p>

        <div class="rh-actions">
          <a class="rh-button rh-button-accent" href="/early-access">
            Register interest
          </a>
          <a class="rh-button rh-button-secondary" href="/support">
            Support
          </a>
        </div>
      </article>
    </div>
  </section>
</BaseLayout>