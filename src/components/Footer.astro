---
const year = new Date().getFullYear();

const primaryLinks = [
  { href: "/explore", label: "Explore"},
  { href: "/products", label: "Products" },
  { href: "/hardware", label: "Hardware" },
  { href: "/relayos", label: "RelayOS" },
  { href: "/use-cases", label: "Use cases" },
  { href: "/early-access", label: "Early access" },
  { href: "/vision", label: "Vision"},
];

const ecosystemLinks = [
  { href: "/ecosystem", label: "Ecosystem" },
  { href: "/communities", label: "Communities" },
  { href: "/community-guides", label: "Community guides" },
  { href: "/marketplace", label: "Marketplace" },
  { href: "/pilot-program", label: "Pilot program" },
];

const trustLinks = [
  { href: "/trust", label: "Trust" },
  { href: "/security", label: "Security" },
  { href: "/privacy", label: "Privacy" },
  { href: "/recovery", label: "Recovery" },
  { href: "/validation", label: "Validation" },
];

const resourcesLinks = [
  { href: "/docs", label: "Docs" },
  { href: "/developers", label: "Developers" },
  { href: "/compatibility", label: "Compatibility" },
  { href: "/certification", label: "Certification" },
  { href: "/downloads", label: "Downloads" },
];

const companyLinks = [
  { href: "/status", label: "Status" },
  { href: "/roadmap", label: "Roadmap" },
  { href: "/partners", label: "Partners" },
  { href: "/media", label: "Media kit" },
  { href: "/contact", label: "Contact" },
];

const legalLinks = [
  { href: "/privacy", label: "Privacy" },
  { href: "/terms", label: "Terms" },
  { href: "/accessibility", label: "Accessibility" },
  { href: "/faq", label: "FAQ" },
];
---

<footer class="rh-footer">
  <div class="rh-container">
    <div class="rh-footer-top">
      <div class="rh-footer-main">
        <a href="/" class="rh-footer-brand">RELAYHUB</a>

        <p class="rh-footer-text">
          Local-first infrastructure for resilient communities.
        </p>

        <p class="rh-footer-small">
          RelayHub helps homes, groups, and communities communicate, coordinate,
          recover, share knowledge, trade, govern, and remain connected without
          depending entirely on centralised systems.
        </p>

        <div class="rh-footer-actions">
          <a class="rh-button rh-button-primary" href="/early-access">
            Register interest
          </a>
          <a class="rh-button rh-button-secondary" href="/contact">
            Contact
          </a>
        </div>
      </div>

      <div class="rh-footer-link-groups">
        <nav class="rh-footer-column" aria-label="Start">
          <h2 class="rh-footer-heading">Start</h2>
          {primaryLinks.map((link) => (
            <a href={link.href}>{link.label}</a>
          ))}
        </nav>

        <nav class="rh-footer-column" aria-label="Ecosystem">
          <h2 class="rh-footer-heading">Ecosystem</h2>
          {ecosystemLinks.map((link) => (
            <a href={link.href}>{link.label}</a>
          ))}
        </nav>

        <nav class="rh-footer-column" aria-label="Trust">
          <h2 class="rh-footer-heading">Trust</h2>
          {trustLinks.map((link) => (
            <a href={link.href}>{link.label}</a>
          ))}
        </nav>

        <nav class="rh-footer-column" aria-label="Resources">
          <h2 class="rh-footer-heading">Resources</h2>
          {resourcesLinks.map((link) => (
            <a href={link.href}>{link.label}</a>
          ))}
        </nav>

        <nav class="rh-footer-column" aria-label="Company">
          <h2 class="rh-footer-heading">Company</h2>
          {companyLinks.map((link) => (
            <a href={link.href}>{link.label}</a>
          ))}
        </nav>
      </div>
    </div>

    <hr class="rh-footer-divider" />

    <div class="rh-footer-bottom">
      <p>© {year} RelayHub. All rights reserved.</p>

      <div class="rh-footer-legal">
        {legalLinks.map((link) => (
          <a href={link.href}>{link.label}</a>
        ))}
      </div>
    </div>

    <p class="rh-footer-disclaimer">
      RelayHub is designed for local-first, resilient communication. It does not
      provide perfect anonymity, guaranteed delivery, universal emergency coverage,
      or automatic protection from physical, network, radio, or trust-based risks.
    </p>
  </div>
</footer>