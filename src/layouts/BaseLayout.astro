---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const {
  title = "RelayHub",
  description = "Local-first infrastructure for communication, trust, knowledge, trade, coordination, governance, and cultural continuity.",
  image = "https://www.relayhub.tech/og-image.svg",
  noindex = false,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, "https://www.relayhub.tech").toString();

const pageTitle = title.includes("RelayHub")
  ? title
  : `${title} | RelayHub`;

const structuredData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "@id": "https://www.relayhub.tech/#organization",
      name: "RelayHub",
      url: "https://www.relayhub.tech/",
      logo: image,
      description:
        "RelayHub provides local-first infrastructure for communication, trust, knowledge, trade, coordination, governance, and cultural continuity.",
      email: "hello@relayhub.tech",
    },
    {
      "@type": "WebSite",
      "@id": "https://www.relayhub.tech/#website",
      url: "https://www.relayhub.tech/",
      name: "RelayHub",
      description: "Local-first infrastructure for resilient communities.",
      publisher: {
        "@id": "https://www.relayhub.tech/#organization",
      },
    },
    {
      "@type": "WebPage",
      "@id": `${canonical}#webpage`,
      url: canonical,
      name: pageTitle,
      description,
      isPartOf: {
        "@id": "https://www.relayhub.tech/#website",
      },
      about: {
        "@id": "https://www.relayhub.tech/#organization",
      },
    },
  ],
};
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />

    <meta
      name="viewport"
      content="width=device-width, initial-scale=1"
    />

    <title>{pageTitle}</title>

    <meta
      name="description"
      content={description}
    />

    <link
      rel="canonical"
      href={canonical}
    />

    {
      noindex && (
        <meta
          name="robots"
          content="noindex,nofollow"
        />
      )
    }

    <!-- OpenGraph -->

    <meta property="og:type" content="website" />

    <meta
      property="og:site_name"
      content="RelayHub"
    />

    <meta
      property="og:title"
      content={pageTitle}
    />

    <meta
      property="og:description"
      content={description}
    />

    <meta
      property="og:url"
      content={canonical}
    />

    <meta
      property="og:image"
      content={image}
    />

    <!-- Twitter -->

    <meta
      name="twitter:card"
      content="summary_large_image"
    />

    <meta
      name="twitter:title"
      content={pageTitle}
    />

    <meta
      name="twitter:description"
      content={description}
    />

    <meta
      name="twitter:image"
      content={image}
    />

    <!-- Structured data -->

    <script
      type="application/ld+json"
      set:html={JSON.stringify(structuredData)}
    />

    <!-- Theme -->

    <meta
      name="theme-color"
      content="#0f172a"
    />

    <meta
      name="color-scheme"
      content="light"
    />

    <!-- Cloudflare Web Analytics -->
    <script
      defer
      src="https://static.cloudflareinsights.com/beacon.min.js"
      data-cf-beacon='{"token":"902ca9303a2f43a89b7cb493e3c570ce"}'
    ></script>
    <!-- End Cloudflare Web Analytics -->
    <script
      src="https://challenges.cloudflare.com/turnstile/v0/api.js"
      async
      defer
    ></script>
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="48x48" href="/favicon-48.png" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" type="image/png" sizes="192x192" href="/android-chrome-192x192.png" />
    <link rel="icon" type="image/png" sizes="512x512" href="/android-chrome-512x512.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
  </head>

  <body>
    <Header />

    <main>
      <slot />
    </main>

    <Footer />
  </body>
</html>