{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "relayhub-tech",
  "main": "worker/index.js",
  "compatibility_date": "2026-06-02",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS"
  },
  "send_email": [
    {
      "name": "RELAYHUB_EMAIL",
      "destination_address": "hello@relayhub.tech"
    }
  ]
}